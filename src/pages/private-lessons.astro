---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Awards from '../components/Awards.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Layout title="Private Training — K9 Academy Training Toronto">
  <Navbar />

  <!-- HERO -->
  <section class="relative pt-28 sm:pt-36 pb-14 sm:pb-20 overflow-hidden bg-brand-dark">
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-center mb-8">
        <div class="inline-flex items-center gap-2.5 bg-white/5 backdrop-blur-sm rounded-full px-4 py-2 border border-white/10">
          <div class="flex items-center gap-0.5">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <span class="text-sm font-semibold text-white">4.9/5</span>
          <span class="w-px h-4 bg-white/20"></span>
          <span class="text-sm text-neutral-400">250+ Google Reviews</span>
        </div>
      </div>

      <div class="text-center max-w-4xl mx-auto">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-white leading-[1.08]">
          One-on-one training
          <br />
          <span class="bg-gradient-to-r from-k9-orange to-amber-400 bg-clip-text text-transparent">for targeted results</span>
        </h1>

        <p class="mt-6 text-lg sm:text-xl text-neutral-400 max-w-2xl mx-auto leading-relaxed">
          Private sessions focused on your dog's specific issues. Advanced obedience or behaviour modification — with e-collar training, off-leash hikes, and tools included.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="#contact" class="inline-flex items-center px-8 py-4 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30 hover:shadow-xl hover:-translate-y-0.5">
            Book Private Training
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a href="tel:4377785273" class="inline-flex items-center gap-2 text-neutral-400 font-medium hover:text-white transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            Or call 437-778-5273
          </a>
        </div>

        <div class="mt-8 flex flex-wrap justify-center gap-x-6 gap-y-2">
          {['1-on-1 with a head trainer', 'E-collar + tools included', 'Off-leash hike included', 'Limited availability'].map((item) => (
            <div class="flex items-center gap-1.5 text-sm text-neutral-500">
              <svg class="w-4 h-4 text-k9-orange flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              <span>{item}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <Awards />

  <!-- PAS -->
  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Is this for you?</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900 leading-tight">
          When your dog needs focused, individual attention
        </h2>
      </div>

      <div class="mt-10 grid sm:grid-cols-2 gap-3">
        {[
          "Your dog struggles to focus around distractions — other dogs, people, noises",
          "They get overexcited toward other dogs and you cannot control it",
          "Pulling and lunging on walks makes every outing stressful",
          "Your dog jumps on everyone and will not settle",
          "Off-leash recall is non-existent — you cannot trust them",
          "Your dog is reactive, fearful, or has poor social skills",
          "Separation anxiety, territorial behaviour, or resource guarding",
        ].map((pain) => (
          <div class="flex items-start gap-3 bg-neutral-50 rounded-xl p-4 border border-neutral-200/60">
            <svg class="w-5 h-5 text-red-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
            </svg>
            <p class="text-neutral-600 text-sm leading-relaxed">{pain}</p>
          </div>
        ))}
      </div>

      <div class="mt-10 text-center">
        <h3 class="text-2xl sm:text-3xl font-extrabold text-neutral-900 mb-4">
          Private training gives your dog undivided attention on exactly what they need.
        </h3>
        <p class="text-lg text-neutral-500 max-w-2xl mx-auto leading-relaxed">
          No group distractions. No shared time. Every session is built around your dog's specific issues, your goals, and your timeline.
        </p>
      </div>
    </div>
  </section>

  <!-- PROGRAMS -->
  <section id="programs" class="py-16 sm:py-24 bg-neutral-50 border-y border-neutral-100">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Private Programs</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900">
          Two programs. One goal: real-world results.
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-5">
        <!-- 6 Session -->
        <div class="rounded-2xl p-6 sm:p-8 border border-neutral-200/60 bg-white hover:border-neutral-300 hover:shadow-md transition-all">
          <h3 class="text-2xl font-bold text-neutral-900 mb-1">Advanced Obedience</h3>
          <p class="text-k9-orange font-medium text-sm mb-3">6 sessions · Off-leash focus</p>
          <p class="text-neutral-500 text-sm mb-5 leading-relaxed">For dogs struggling with focus around distractions, overexcitement, pulling on walks, jumping, and unreliable off-leash recall. Includes e-collar, training tools, and an off-leash hike.</p>
          <ul class="space-y-2 mb-6">
            {['Focus around distractions', 'Overexcitement toward dogs + people', 'Pulling + lunging on walks', 'Jumping on people', 'Off-leash recall', 'E-collar + tools included ($350 value)'].map((d) => (
              <li class="flex items-start gap-2 text-sm text-neutral-600">
                <svg class="w-4 h-4 text-k9-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                <span>{d}</span>
              </li>
            ))}
          </ul>
          <div class="bg-neutral-50 rounded-xl p-3 mb-6">
            <p class="text-xs text-neutral-500"><strong class="text-neutral-700">Includes:</strong> Off-leash hike + e-collar and training tools (valued at $350)</p>
          </div>
          <div class="flex items-center justify-between pt-5 border-t border-neutral-100">
            <span class="text-2xl font-extrabold text-neutral-900">$1,350</span>
            <a href="#contact" class="inline-flex items-center px-5 py-2.5 text-sm font-semibold rounded-lg bg-neutral-100 text-neutral-700 hover:bg-k9-orange hover:text-white transition-all">Book Now</a>
          </div>
        </div>

        <!-- 8 Session -->
        <div class="relative rounded-2xl p-6 sm:p-8 border border-k9-orange/30 bg-k9-orange-light/40 ring-1 ring-k9-orange/10 hover:shadow-md transition-all">
          <div class="absolute -top-3 left-6">
            <span class="inline-flex items-center px-3 py-1 bg-k9-orange text-white text-xs font-bold rounded-lg uppercase tracking-wide">Most Comprehensive</span>
          </div>
          <h3 class="text-2xl font-bold text-neutral-900 mb-1 mt-2">Behaviour Modification</h3>
          <p class="text-k9-orange font-medium text-sm mb-3">8 sessions · Reactivity, aggression + fear</p>
          <p class="text-neutral-500 text-sm mb-5 leading-relaxed">For dogs with reactivity, aggression, fear, anxiety, or poor social skills. Addresses barking and lunging at dogs or strangers, resource guarding, nervousness, and socialization difficulties.</p>
          <ul class="space-y-2 mb-6">
            {['Reactivity + aggression', 'Barking + lunging at dogs/strangers', 'Resource guarding', 'Fear + nervousness', 'Socialization difficulties', 'Dog socialization sessions included'].map((d) => (
              <li class="flex items-start gap-2 text-sm text-neutral-600">
                <svg class="w-4 h-4 text-k9-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                <span>{d}</span>
              </li>
            ))}
          </ul>
          <div class="bg-white/60 rounded-xl p-3 mb-6">
            <p class="text-xs text-neutral-500"><strong class="text-neutral-700">Includes:</strong> Dog socialization, off-leash hike + e-collar and training tools (valued at $350)</p>
          </div>
          <div class="flex items-center justify-between pt-5 border-t border-neutral-100">
            <span class="text-2xl font-extrabold text-neutral-900">$1,685</span>
            <a href="#contact" class="inline-flex items-center px-5 py-2.5 text-sm font-semibold rounded-lg bg-k9-orange text-white hover:bg-k9-orange-dark shadow-sm transition-all">Book Now</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT YOU GET -->
  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">What You Get</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900">
          Every session is built around your dog
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { num: '01', title: 'Customized to your dog', desc: 'No cookie-cutter approach. Every session addresses your dog\'s specific issues, breed, temperament, and your goals.' },
          { num: '02', title: 'E-collar + tools included', desc: 'Both packages include an e-collar and professional training tools worth $350. You keep everything after the program.' },
          { num: '03', title: 'Off-leash hike', desc: 'Put your training to the test in a real-world environment. An off-leash hike is included to prove your dog\'s reliability outside the facility.' },
          { num: '04', title: 'Real-world results', desc: 'Training is proofed in parks, patios, and distracting environments. Your dog does not just perform in a facility — they perform everywhere.' },
          { num: '05', title: 'Expert trainers', desc: 'Work directly with K9 Academy\'s training team. 15+ years of experience with the breeds and behaviours most trainers cannot handle.' },
          { num: '06', title: 'Socialization (8-session)', desc: 'The Behaviour Modification package includes structured dog socialization sessions to build confidence and reduce reactivity.' },
        ].map((prop) => (
          <div class="rounded-2xl p-6 bg-neutral-50 border border-neutral-200/60 hover:border-neutral-300 transition-all">
            <div class="w-8 h-8 rounded-lg bg-k9-orange/10 flex items-center justify-center mb-4">
              <span class="text-k9-orange font-bold text-sm">{prop.num}</span>
            </div>
            <h3 class="text-base font-bold text-neutral-900 mb-2">{prop.title}</h3>
            <p class="text-neutral-500 text-sm leading-relaxed">{prop.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="py-16 sm:py-24 bg-neutral-50 border-y border-neutral-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Results</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900">
          What private training clients say
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          { headline: 'We can finally have guests over without chaos', text: 'Our doodle would jump on everyone, bark non-stop, and destroy furniture when left alone. After 6 private sessions, he is a completely different dog. We wish we had found K9 Academy sooner.', name: 'Mark & Lisa T.', detail: 'Goldendoodle, 2 years · 6-Session Advanced Obedience' },
          { headline: 'Off-leash at the park for the first time ever', text: 'I never thought I would be able to let my dog off leash. After the Advanced Obedience program, she comes when called every single time. The e-collar training was the missing piece.', name: 'Natalie R.', detail: 'Border Collie mix, 3 years · 6-Session Advanced Obedience' },
          { headline: 'From reactive mess to calm confidence', text: 'Our rescue was reactive to everything — dogs, bikes, skateboards, strangers. The Behaviour Modification program addressed each trigger individually. Eight sessions later, walks are actually enjoyable.', name: 'Tom & Andrea S.', detail: 'Pitbull mix, 4 years · 8-Session Behaviour Modification' },
        ].map((t) => (
          <div class="bg-white rounded-2xl p-6 border border-neutral-200/60 flex flex-col">
            <div class="flex items-center gap-2 mb-4">
              <svg class="w-5 h-5" viewBox="0 0 24 24">
                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" />
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
              </svg>
              <div class="flex items-center gap-0.5">
                {[1,2,3,4,5].map(() => (
                  <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
            </div>
            <h3 class="text-base font-bold text-neutral-900 mb-2">{t.headline}</h3>
            <p class="text-neutral-500 text-sm leading-relaxed flex-grow mb-4">{t.text}</p>
            <div class="pt-4 border-t border-neutral-100">
              <p class="font-semibold text-neutral-900 text-sm">{t.name}</p>
              <p class="text-xs text-neutral-400">{t.detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRIVATE VS B&T -->
  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Which Is Right?</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900">
          Private Training vs Board & Train
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-5">
        <div class="rounded-2xl p-6 border border-neutral-200/60 bg-neutral-50">
          <h3 class="text-lg font-bold text-neutral-900 mb-3">Private Training is right if:</h3>
          <ul class="space-y-2">
            {['You want to be hands-on in the process', 'Your dog has specific issues you want to target', 'You can commit to weekly sessions', 'You want to learn alongside your dog', 'Your schedule does not allow boarding'].map((d) => (
              <li class="flex items-start gap-2 text-sm text-neutral-600">
                <svg class="w-4 h-4 text-k9-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                <span>{d}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="rounded-2xl p-6 border border-neutral-200/60 bg-neutral-50">
          <h3 class="text-lg font-bold text-neutral-900 mb-3">Board & Train is right if:</h3>
          <ul class="space-y-2">
            {['You want a fully transformed dog without the daily work', 'Your dog needs immersive, full-time training', 'Behaviour issues are severe (aggression, anxiety)', 'You have tried other approaches and nothing stuck', 'You want the fastest possible results'].map((d) => (
              <li class="flex items-start gap-2 text-sm text-neutral-600">
                <svg class="w-4 h-4 text-k9-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                <span>{d}</span>
              </li>
            ))}
          </ul>
          <a href="/board-and-train" class="inline-flex items-center mt-4 text-sm font-semibold text-k9-orange hover:text-k9-orange-dark transition-colors">
            View Board & Train programs
            <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="py-16 sm:py-24 bg-brand-dark">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Getting Started</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-white">
          How private training works
        </h2>
      </div>

      <div class="grid sm:grid-cols-3 gap-6">
        {[
          { num: '01', title: 'Tell us about your dog', desc: 'Fill out the intake form or call us. Describe what you are dealing with and your goals. Be ready to be coachable — that is essential for success.' },
          { num: '02', title: 'We recommend a program', desc: 'Our team discusses your dog and recommends either the 6-session Advanced Obedience or 8-session Behaviour Modification.' },
          { num: '03', title: 'Start training', desc: 'Sessions begin at our facility. E-collar and tools are provided from day one. Off-leash hike included in both programs.' },
        ].map((step) => (
          <div class="text-center sm:text-left">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-k9-orange text-white text-sm font-bold mb-4">
              {step.num}
            </div>
            <h3 class="text-lg font-bold text-white mb-2">{step.title}</h3>
            <p class="text-neutral-400 text-sm leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>

      <div class="text-center mt-12">
        <a href="#contact" class="inline-flex items-center px-7 py-3.5 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30">
          Book Private Training
        </a>
      </div>
    </div>
  </section>

  <ContactForm />
  <Footer />
</Layout>
