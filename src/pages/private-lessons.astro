---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Awards from '../components/Awards.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Layout title="Private Training — K9 Academy Training Toronto">
  <Navbar />

  <!-- HERO -->
  <section class="relative pt-28 sm:pt-32 pb-14 sm:pb-20 overflow-hidden bg-brand-dark">
    <div class="absolute inset-0 bg-gradient-to-br from-k9-orange/5 via-transparent to-transparent pointer-events-none"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">

        <!-- LEFT: Copy -->
        <div>
          <div class="inline-flex items-center gap-2.5 bg-white/5 backdrop-blur-sm rounded-full px-4 py-2 border border-white/10 mb-6">
            <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            <div class="flex items-center gap-0.5">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <span class="text-sm font-semibold text-white">4.9/5</span>
            <span class="w-px h-4 bg-white/20"></span>
            <span class="text-sm text-neutral-400">250+ Google Reviews</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[3.4rem] font-extrabold tracking-tight text-white leading-[1.05]">
            Fix the behaviour
            <span class="bg-gradient-to-r from-k9-orange to-amber-400 bg-clip-text text-transparent">other trainers couldn't</span>
            <span class="block mt-2 text-3xl sm:text-4xl lg:text-[2.5rem] text-neutral-300 font-bold">— in as little as 6 weeks.</span>
          </h1>

          <p class="mt-6 text-base sm:text-lg text-neutral-400 max-w-xl leading-relaxed">
            Private 1-on-1 sessions for the issues that make life hard — aggression, separation anxiety, resource guarding, reactivity, leash pulling, incessant barking, or off-leash reliability. We fix the root cause, not the symptom.
          </p>

          <!-- Outcomes -->
          <div class="mt-7 grid sm:grid-cols-2 gap-2.5 max-w-xl">
            {[
              'Aggression + resource guarding',
              'Separation anxiety',
              'Reactivity + lunging',
              'Leash pulling + barking',
              'Off-leash recall',
              'Calm + obedient at home',
            ].map((item) => (
              <div class="flex items-center gap-2.5 text-sm text-neutral-300">
                <div class="w-5 h-5 rounded-full bg-k9-orange/15 flex items-center justify-center flex-shrink-0">
                  <svg class="w-3 h-3 text-k9-orange" fill="none" stroke="currentColor" stroke-width="3.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                  </svg>
                </div>
                <span>{item}</span>
              </div>
            ))}
          </div>

          <!-- CTAs -->
          <div class="mt-8 flex flex-col sm:flex-row items-start sm:items-center gap-4">
            <a href="#contact" class="inline-flex items-center px-7 py-4 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30 hover:shadow-xl hover:-translate-y-0.5">
              Book Private Training
              <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
            <a href="tel:4377785273" class="inline-flex items-center gap-2 text-neutral-400 font-medium hover:text-white transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              Or call 437-778-5273
            </a>
          </div>

          <!-- Trust line -->
          <div class="mt-6 flex flex-wrap items-center gap-x-5 gap-y-1.5 text-xs text-neutral-500">
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5 text-k9-orange" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              E-collar + tools included
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5 text-k9-orange" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              Off-leash hike included
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5 text-k9-orange" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              Limited spots monthly
            </span>
          </div>
        </div>

        <!-- RIGHT: Hero Media -->
        <div class="relative">
          <div class="relative rounded-3xl overflow-hidden border border-white/10 shadow-2xl shadow-black/50 bg-neutral-800 aspect-[4/5] sm:aspect-video lg:aspect-[4/5]">
            <!-- TODO: Replace with hero video or photo.
                 Video: <video autoplay muted loop playsinline class="absolute inset-0 w-full h-full object-cover"><source src="/hero.mp4" type="video/mp4"/></video>
                 Photo: <img src="/hero.jpg" alt="..." class="absolute inset-0 w-full h-full object-cover" /> -->
            <div class="absolute inset-0 bg-gradient-to-br from-neutral-700 via-neutral-800 to-neutral-900 flex items-center justify-center">
              <div class="text-center p-6">
                <div class="w-20 h-20 rounded-full bg-k9-orange/20 border-2 border-k9-orange/40 flex items-center justify-center mx-auto mb-4">
                  <svg class="w-9 h-9 text-k9-orange ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </div>
                <p class="text-white font-semibold text-sm">Hero video / photo</p>
                <p class="text-neutral-400 text-xs mt-1">Drop asset at <code class="bg-white/5 px-1.5 py-0.5 rounded">/public/hero.mp4</code></p>
              </div>
            </div>

            <!-- Floating badge -->
            <div class="absolute bottom-4 left-4 right-4 sm:right-auto">
              <div class="inline-flex items-center gap-3 bg-white/95 backdrop-blur-sm rounded-2xl px-4 py-3 shadow-xl">
                <div class="flex -space-x-2">
                  <div class="w-8 h-8 rounded-full bg-blue-500 border-2 border-white flex items-center justify-center text-white text-xs font-bold">M</div>
                  <div class="w-8 h-8 rounded-full bg-rose-500 border-2 border-white flex items-center justify-center text-white text-xs font-bold">N</div>
                  <div class="w-8 h-8 rounded-full bg-emerald-500 border-2 border-white flex items-center justify-center text-white text-xs font-bold">T</div>
                </div>
                <div class="text-xs">
                  <p class="font-bold text-neutral-900">10,000+ dogs trained</p>
                  <p class="text-neutral-500">Toronto's top-rated</p>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <Awards />

  <!-- PAS -->
  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Is this for you?</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900 leading-tight">
          When your dog needs focused, individual attention
        </h2>
      </div>

      <div class="mt-10 grid sm:grid-cols-2 gap-3">
        {[
          "Your dog struggles to focus around distractions — other dogs, people, noises",
          "They get overexcited toward other dogs and you cannot control it",
          "Pulling and lunging on walks makes every outing stressful",
          "Your dog jumps on everyone and will not settle",
          "Off-leash recall is non-existent — you cannot trust them",
          "Your dog is reactive, fearful, or has poor social skills",
          "Separation anxiety, territorial behaviour, or resource guarding",
        ].map((pain) => (
          <div class="flex items-start gap-3 bg-neutral-50 rounded-xl p-4 border border-neutral-200/60">
            <svg class="w-5 h-5 text-red-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
            </svg>
            <p class="text-neutral-600 text-sm leading-relaxed">{pain}</p>
          </div>
        ))}
      </div>

      <div class="mt-10 text-center">
        <h3 class="text-2xl sm:text-3xl font-extrabold text-neutral-900 mb-4">
          Private training gives your dog undivided attention on exactly what they need.
        </h3>
        <p class="text-lg text-neutral-500 max-w-2xl mx-auto leading-relaxed">
          No group distractions. No shared time. Every session is built around your dog's specific issues, your goals, and your timeline.
        </p>
      </div>
    </div>
  </section>

  <!-- PROGRAMS -->
  <section id="programs" class="py-16 sm:py-24 bg-neutral-50 border-y border-neutral-100">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Private Programs</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900">
          Two programs. One goal: real-world results.
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-5">
        <!-- 6 Session -->
        <div class="rounded-2xl p-6 sm:p-8 border border-neutral-200/60 bg-white hover:border-neutral-300 hover:shadow-md transition-all">
          <h3 class="text-2xl font-bold text-neutral-900 mb-1">Advanced Obedience</h3>
          <p class="text-k9-orange font-medium text-sm mb-3">6 sessions · Off-leash focus</p>
          <p class="text-neutral-500 text-sm mb-5 leading-relaxed">For dogs struggling with focus around distractions, overexcitement, pulling on walks, jumping, and unreliable off-leash recall. Includes e-collar, training tools, and an off-leash hike.</p>
          <ul class="space-y-2 mb-6">
            {['Focus around distractions', 'Overexcitement toward dogs + people', 'Pulling + lunging on walks', 'Jumping on people', 'Off-leash recall', 'E-collar + tools included ($350 value)'].map((d) => (
              <li class="flex items-start gap-2 text-sm text-neutral-600">
                <svg class="w-4 h-4 text-k9-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                <span>{d}</span>
              </li>
            ))}
          </ul>
          <div class="bg-neutral-50 rounded-xl p-3 mb-6">
            <p class="text-xs text-neutral-500"><strong class="text-neutral-700">Includes:</strong> Off-leash hike + e-collar and training tools (valued at $350)</p>
          </div>
          <div class="flex items-center justify-between pt-5 border-t border-neutral-100">
            <span class="text-2xl font-extrabold text-neutral-900">$1,350</span>
            <a href="#contact" class="inline-flex items-center px-5 py-2.5 text-sm font-semibold rounded-lg bg-neutral-100 text-neutral-700 hover:bg-k9-orange hover:text-white transition-all">Book Now</a>
          </div>
        </div>

        <!-- 8 Session -->
        <div class="relative rounded-2xl p-6 sm:p-8 border border-k9-orange/30 bg-k9-orange-light/40 ring-1 ring-k9-orange/10 hover:shadow-md transition-all">
          <div class="absolute -top-3 left-6">
            <span class="inline-flex items-center px-3 py-1 bg-k9-orange text-white text-xs font-bold rounded-lg uppercase tracking-wide">Most Comprehensive</span>
          </div>
          <h3 class="text-2xl font-bold text-neutral-900 mb-1 mt-2">Behaviour Modification</h3>
          <p class="text-k9-orange font-medium text-sm mb-3">8 sessions · Reactivity, aggression + fear</p>
          <p class="text-neutral-500 text-sm mb-5 leading-relaxed">For dogs with reactivity, aggression, fear, anxiety, or poor social skills. Addresses barking and lunging at dogs or strangers, resource guarding, nervousness, and socialization difficulties.</p>
          <ul class="space-y-2 mb-6">
            {['Reactivity + aggression', 'Barking + lunging at dogs/strangers', 'Resource guarding', 'Fear + nervousness', 'Socialization difficulties', 'Dog socialization sessions included'].map((d) => (
              <li class="flex items-start gap-2 text-sm text-neutral-600">
                <svg class="w-4 h-4 text-k9-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                <span>{d}</span>
              </li>
            ))}
          </ul>
          <div class="bg-white/60 rounded-xl p-3 mb-6">
            <p class="text-xs text-neutral-500"><strong class="text-neutral-700">Includes:</strong> Dog socialization, off-leash hike + e-collar and training tools (valued at $350)</p>
          </div>
          <div class="flex items-center justify-between pt-5 border-t border-neutral-100">
            <span class="text-2xl font-extrabold text-neutral-900">$1,685</span>
            <a href="#contact" class="inline-flex items-center px-5 py-2.5 text-sm font-semibold rounded-lg bg-k9-orange text-white hover:bg-k9-orange-dark shadow-sm transition-all">Book Now</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT YOU GET -->
  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">What You Get</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900">
          Every session is built around your dog
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { num: '01', title: 'Customized to your dog', desc: 'No cookie-cutter approach. Every session addresses your dog\'s specific issues, breed, temperament, and your goals.' },
          { num: '02', title: 'E-collar + tools included', desc: 'Both packages include an e-collar and professional training tools worth $350. You keep everything after the program.' },
          { num: '03', title: 'Off-leash hike', desc: 'Put your training to the test in a real-world environment. An off-leash hike is included to prove your dog\'s reliability outside the facility.' },
          { num: '04', title: 'Real-world results', desc: 'Training is proofed in parks, patios, and distracting environments. Your dog does not just perform in a facility — they perform everywhere.' },
          { num: '05', title: 'Expert trainers', desc: 'Work directly with K9 Academy\'s training team. 15+ years of experience with the breeds and behaviours most trainers cannot handle.' },
          { num: '06', title: 'Socialization (8-session)', desc: 'The Behaviour Modification package includes structured dog socialization sessions to build confidence and reduce reactivity.' },
        ].map((prop) => (
          <div class="rounded-2xl p-6 bg-neutral-50 border border-neutral-200/60 hover:border-neutral-300 transition-all">
            <div class="w-8 h-8 rounded-lg bg-k9-orange/10 flex items-center justify-center mb-4">
              <span class="text-k9-orange font-bold text-sm">{prop.num}</span>
            </div>
            <h3 class="text-base font-bold text-neutral-900 mb-2">{prop.title}</h3>
            <p class="text-neutral-500 text-sm leading-relaxed">{prop.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SESSION FLOW -->
  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">The Training Progression</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900">
          How private sessions usually flow
        </h2>
        <p class="mt-4 text-lg text-neutral-500 max-w-2xl mx-auto leading-relaxed">
          Every dog moves through the same progression — we only advance once they are reliable at each stage.
        </p>
      </div>

      <div class="relative">
        <div class="hidden md:block absolute left-[27px] top-2 bottom-2 w-0.5 bg-gradient-to-b from-k9-orange via-k9-orange/40 to-neutral-200"></div>

        <div class="space-y-5">
          {[
            {
              num: '01',
              phase: 'Phase 1',
              title: 'Fix major control issues',
              desc: 'We start with the fundamentals that make your dog livable: loose-leash walking, on-leash reactivity, and foundational obedience. No advanced work until these hold.',
              tags: ['Leash walking', 'On-leash reactivity', 'Sit / down / place', 'Focus + engagement'],
            },
            {
              num: '02',
              phase: 'Phase 2',
              title: 'Introduce off-leash control with the e-collar',
              desc: 'Once your dog is reliable on-leash, we layer in the e-collar to condition off-leash responsiveness in a controlled environment. Low-level, clear, and fair.',
              tags: ['E-collar conditioning', 'Recall foundations', 'Off-leash heel', 'Remote guidance'],
            },
            {
              num: '03',
              phase: 'Phase 3',
              title: 'Increase on-leash pressure',
              desc: 'Now we proof the basics under real distractions — other dogs, people, noise, movement. Your dog learns to hold obedience when the environment is not cooperating.',
              tags: ['Distraction proofing', 'Real-world settings', 'Duration + distance', 'Handler confidence'],
            },
            {
              num: '04',
              phase: 'Phase 4',
              title: 'Increase off-leash pressure',
              desc: 'With the e-collar as backup, we expose your dog to progressively harder off-leash challenges. The goal: your dog chooses you over every distraction.',
              tags: ['Off-leash distraction work', 'Reliable recall', 'Real environments', 'E-collar as communication'],
            },
            {
              num: '05',
              phase: 'Phase 5',
              title: 'Socialize + off-leash at the park',
              desc: 'Once your dog is reliable, we socialize structured and take them off-leash in public spaces — parks, trails, patios. This is the reward for the work above.',
              tags: ['Structured socialization', 'Park work', 'Patio manners', 'Real-world graduation'],
            },
            {
              num: '06',
              phase: 'If needed',
              title: 'Home visit',
              desc: 'If problems persist in your home environment — door manners, guests, resource guarding, separation — we come to you and address it where it actually happens.',
              tags: ['In-home assessment', 'Door + guest work', 'Environment-specific issues', 'Household integration'],
              optional: true,
            },
          ].map((step) => (
            <div class={`relative flex gap-5 rounded-2xl p-5 sm:p-6 border transition-all ${step.optional ? 'border-dashed border-neutral-300 bg-neutral-50' : 'border-neutral-200/60 bg-neutral-50/70 hover:border-k9-orange/30 hover:shadow-md'}`}>
              <div class="flex-shrink-0">
                <div class={`w-14 h-14 rounded-2xl flex items-center justify-center font-extrabold text-lg relative z-10 ${step.optional ? 'bg-white border-2 border-dashed border-neutral-300 text-neutral-500' : 'bg-k9-orange text-white shadow-lg shadow-k9-orange/20'}`}>
                  {step.num}
                </div>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <span class={`text-xs font-bold uppercase tracking-wide ${step.optional ? 'text-neutral-400' : 'text-k9-orange'}`}>{step.phase}</span>
                </div>
                <h3 class="text-lg sm:text-xl font-bold text-neutral-900 mb-2">{step.title}</h3>
                <p class="text-neutral-600 text-sm sm:text-base leading-relaxed mb-4">{step.desc}</p>
                <div class="flex flex-wrap gap-2">
                  {step.tags.map((tag) => (
                    <span class="inline-flex items-center px-3 py-1 rounded-full bg-white border border-neutral-200 text-xs font-medium text-neutral-600">{tag}</span>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="mt-10 rounded-2xl bg-k9-orange-light/40 border border-k9-orange/20 p-6 text-center">
        <p class="text-neutral-700 text-sm sm:text-base leading-relaxed">
          <strong class="text-neutral-900">We only advance when your dog is ready.</strong> Rushing stages is how trainers get brittle results. The progression above is the standard flow — your dog's pace is their own.
        </p>
      </div>
    </div>
  </section>

  <!-- SOCIAL PROOF -->
  <section class="py-16 sm:py-24 bg-neutral-50 border-y border-neutral-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Results</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900">
          Real clients. Real transformations.
        </h2>
