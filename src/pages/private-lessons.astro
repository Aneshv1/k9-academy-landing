---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Awards from '../components/Awards.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
import GuideBanner from '../components/GuideBanner.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';
import '../styles/global.css';
---

<Layout title="Private Dog Training Toronto. 1-on-1 Behaviour Modification | K9 Academy" description="Private dog training in Toronto for aggression, reactivity, separation anxiety, and off-leash recall. 6 and 8 session programs. Results other trainers can't deliver.">
  <Navbar />

  <!-- HERO -->
  <section class="relative pt-28 sm:pt-32 pb-14 sm:pb-20 overflow-hidden bg-brand-dark">
    <div class="absolute inset-0 bg-gradient-to-br from-k9-orange/5 via-transparent to-transparent pointer-events-none"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">

        <!-- LEFT: Copy -->
        <div>
          <div class="inline-flex items-center gap-2.5 bg-white/5 backdrop-blur-sm rounded-full px-4 py-2 border border-white/10 mb-6">
            <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            <div class="flex items-center gap-0.5">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <span class="text-sm font-semibold text-white">4.9/5</span>
            <span class="w-px h-4 bg-white/20"></span>
            <span class="text-sm text-neutral-400">250+ Google Reviews</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[3.4rem] font-extrabold tracking-tight text-white leading-[1.05]">
            Fix the behaviour
            <span class="bg-gradient-to-r from-k9-orange to-amber-400 bg-clip-text text-transparent">other trainers couldn't</span>
            <span class="block mt-2 text-3xl sm:text-4xl lg:text-[2.5rem] text-neutral-300 font-bold">in as little as 6 sessions.</span>
          </h1>

          <p class="mt-6 text-base sm:text-lg text-neutral-400 max-w-xl leading-relaxed">
            Private 1-on-1 sessions for the issues that make life hard. aggression, separation anxiety, resource guarding, reactivity, leash pulling, incessant barking, or off-leash reliability. We fix the root cause, not the symptom.
          </p>

          <!-- Outcomes -->
          <div class="mt-7 grid sm:grid-cols-2 gap-2.5 max-w-xl">
            {[
              'Leash reactivity + lunging',
              'Dog-to-dog aggression',
              'Multi-dog households with fighting',
              'Aggression toward people',
              'In-home reactivity (doors, guests, sounds)',
              'Separation anxiety + destructive behaviour',
              'On-leash + off-leash obedience',
              'Human socialization + stranger fear',
              'Resource guarding',
              'Off-leash recall + e-collar training',
            ].map((item) => (
              <div class="flex items-center gap-2.5 text-sm text-neutral-300">
                <div class="w-5 h-5 rounded-full bg-k9-orange/15 flex items-center justify-center flex-shrink-0">
                  <svg class="w-3 h-3 text-k9-orange" fill="none" stroke="currentColor" stroke-width="3.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                  </svg>
                </div>
                <span>{item}</span>
              </div>
            ))}
          </div>

          <!-- CTAs -->
          <div class="mt-8 flex flex-col sm:flex-row items-start sm:items-center gap-4">
            <a href="#contact" class="inline-flex items-center px-7 py-4 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30 hover:shadow-xl hover:-translate-y-0.5">
              Book Private Training
              <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
            <a href="tel:4377785273" class="inline-flex items-center gap-2 text-neutral-400 font-medium hover:text-white transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              Or call 437-778-5273
            </a>
          </div>

          <!-- Trust line -->
          <div class="mt-6 flex flex-wrap items-center gap-x-5 gap-y-1.5 text-xs text-neutral-500">
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5 text-k9-orange" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              E-collar + tools included
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5 text-k9-orange" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              Off-leash hike included
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5 text-k9-orange" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              Limited spots monthly
            </span>
          </div>
        </div>

        <!-- RIGHT: Hero Media -->
        <div class="relative">
          <div class="relative rounded-3xl overflow-hidden border border-white/10 shadow-2xl shadow-black/50 bg-neutral-800">
            <YouTubeEmbed videoId="zqd66o8dr2k" title="K9 Academy Private Training" />

            <!-- Floating badge -->
            <div class="absolute bottom-4 left-4 right-4 sm:right-auto">
              <div class="inline-flex items-center gap-3 bg-white/95 backdrop-blur-sm rounded-2xl px-4 py-3 shadow-xl">
                <div class="flex -space-x-2">
                  <div class="w-8 h-8 rounded-full bg-blue-500 border-2 border-white flex items-center justify-center text-white text-xs font-bold">M</div>
                  <div class="w-8 h-8 rounded-full bg-rose-500 border-2 border-white flex items-center justify-center text-white text-xs font-bold">N</div>
                  <div class="w-8 h-8 rounded-full bg-emerald-500 border-2 border-white flex items-center justify-center text-white text-xs font-bold">T</div>
                </div>
                <div class="text-xs">
                  <p class="font-bold text-neutral-900">10,000+ dogs trained</p>
                  <p class="text-neutral-500">Toronto's top-rated</p>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <Awards />

  <!-- PAS -->
  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Sound familiar?</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900 leading-tight">
          You know your dog can be better. You just need the right guidance.
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-5 mb-10">
        {[
          {
            pain: 'Group classes didn\'t cut it',
            detail: 'Your dog sat nicely in class but the second you got home, nothing transferred. You need something more focused.',
            iconPath: 'M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636',
          },
          {
            pain: 'You want to learn, not outsource',
            detail: 'Board and train isn\'t for everyone. You want to understand your dog, handle them yourself, and build the relationship through training.',
            iconPath: 'M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.62 48.62 0 0112 20.904a48.62 48.62 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5',
          },
          {
            pain: 'Your dog has specific issues',
            detail: 'Reactivity, aggression, resource guarding, separation anxiety. Cookie-cutter programs can\'t address what your dog specifically needs.',
            iconPath: 'M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z',
          },
        ].map((item) => (
          <div class="rounded-2xl bg-neutral-50 border border-neutral-200 p-6 text-center hover:border-red-200 hover:bg-red-50/30 transition-all group">
            <div class="w-12 h-12 rounded-full bg-red-50 border border-red-100 flex items-center justify-center mx-auto mb-4 group-hover:bg-red-100 transition-colors">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d={item.iconPath} />
              </svg>
            </div>
            <h3 class="text-lg font-extrabold text-neutral-900 mb-2">{item.pain}</h3>
            <p class="text-neutral-500 text-sm leading-relaxed">{item.detail}</p>
          </div>
        ))}
      </div>

      <!-- Photo + Quote -->
      <div class="rounded-2xl bg-neutral-50 border border-neutral-200 overflow-hidden mb-10 grid md:grid-cols-[1fr_1.5fr]">
        <div class="aspect-square md:aspect-auto">
          <img src="/images/private-training.jpg" alt="Private training session at K9 Academy" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="p-6 sm:p-8 flex flex-col justify-center">
          <div class="flex items-center gap-0.5 mb-3">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
            <span class="text-sm text-neutral-400 ml-2">Google Review</span>
          </div>
          <blockquote class="text-lg font-semibold text-neutral-900 leading-relaxed mb-3">
            "I am a 5 foot woman with a GSD/cane corso mix who used to lunge at everything. I stopped walking her. You told us you'd fix her leash walking on day 1 and I thought that was insane. It was not insane. I take her on public walks now. By myself. With confidence."
          </blockquote>
          <p class="text-neutral-400 text-sm">J. S. · Reactivity · Private Lessons</p>
        </div>
      </div>

      <!-- Photo + Quote 2 -->
      <div class="rounded-2xl bg-neutral-50 border border-neutral-200 overflow-hidden mb-10 grid md:grid-cols-[1.5fr_1fr]">
        <div class="p-6 sm:p-8 flex flex-col justify-center order-2 md:order-1">
          <div class="flex items-center gap-0.5 mb-3">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <blockquote class="text-lg font-semibold text-neutral-900 leading-relaxed mb-3">
            "First they fixed my dog's leash pulling. Then they fixed the reactivity, which I thought wasn't possible. And then they even socialized him with dogs. He hadn't met a dog in years."
          </blockquote>
          <p class="text-neutral-400 text-sm">Lincoln's owner · Golden Retriever, 5 years · Private Lessons</p>
        </div>
        <div class="aspect-square md:aspect-auto order-1 md:order-2">
          <img src="/images/socialization-golden-gsd.jpg" alt="Dog socialization after private training at K9 Academy" class="w-full h-full object-cover" loading="lazy" />
        </div>
      </div>

      <div class="text-center">
        <h3 class="text-2xl sm:text-3xl font-extrabold text-neutral-900 mb-3">
          Every session is 100% about your dog.
        </h3>
        <p class="text-neutral-500 max-w-xl mx-auto mb-6">
          No group distractions. No shared time. Just your dog, your trainer, and a plan built around the specific issues you're dealing with.
        </p>
        <a href="#contact" class="inline-flex items-center px-8 py-4 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30 hover:shadow-xl hover:-translate-y-0.5">
          Book Private Training
          <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
        <p class="text-neutral-400 text-xs mt-3">E-collar and all tools included. No extra costs.</p>
      </div>
    </div>
  </section>

  <!-- SOCIAL PROOF -->
  <section class="py-16 sm:py-24 bg-neutral-50 border-y border-neutral-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Results</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900">
          Real clients. Real transformations.
        </h2>
        <p class="mt-4 text-lg text-neutral-500 max-w-2xl mx-auto">
          Aggression, separation anxiety, resource guarding, reactivity, pulling, barking, off-leash recall. whatever you're dealing with, we've fixed it before.
        </p>

        <div class="mt-6 flex flex-wrap items-center justify-center gap-2">
          {[
            'Leash reactivity',
            'Dog-to-dog aggression',
            'Multi-dog fighting',
            'Human aggression',
            'In-home reactivity',
            'Separation anxiety',
            'Resource guarding',
            'Off-leash recall',
            'Stranger fear',
          ].map((tag) => (
            <span class="inline-flex items-center px-3 py-1.5 rounded-full bg-white border border-neutral-200 text-xs font-semibold text-neutral-700">
              {tag}
            </span>
          ))}
        </div>
        <div class="mt-6 flex flex-wrap items-center justify-center gap-6 text-sm">
          <div class="flex items-center gap-2">
            <div class="flex items-center gap-0.5">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              ))}
            </div>
            <span class="font-semibold text-neutral-900">4.9/5 Google</span>
          </div>
          <span class="text-neutral-300">·</span>
          <span class="text-neutral-600"><strong class="text-neutral-900">250+</strong> reviews</span>
          <span class="text-neutral-300">·</span>
          <span class="text-neutral-600"><strong class="text-neutral-900">10,000+</strong> dogs trained</span>
        </div>
      </div>

      <!-- Google Reviews -->
      <div class="mb-16">
        <div class="flex items-center justify-center gap-2 mb-8">
          <svg class="w-5 h-5" viewBox="0 0 24 24">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" />
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
          </svg>
          <h3 class="text-sm font-bold uppercase tracking-wide text-neutral-500">Google Reviews</h3>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {[
            { initial: 'A', bg: 'bg-purple-500', issue: 'Reactivity', headline: 'We were essentially gifted a new dog', text: 'Miles came to us from Mexico as the most anxious dog in his litter. Leash reactive to dogs and humans, aggressive with strangers in our home. Anesh and his team gave us tools to communicate with him and we followed every word. He is confident, non-reactive and trustworthy now. If any of that sounds familiar. this is the place.', name: 'Andrew M.', detail: 'Rescue · Private sessions', when: '2 months ago' },
            { initial: 'J', bg: 'bg-amber-500', issue: 'Reactivity', headline: 'I can walk my dog again', text: 'I am a 5ft woman with a german shepherd/cane corso mix. She was reactive to everything and I had stopped taking her out. They told me they would fix her leash walking on day 1 and I thought they were out of their minds. They were not. I walk her in public now with complete control and confidence.', name: 'Jennifer S.', detail: 'GSD/Cane Corso mix · Private sessions', when: '3 weeks ago' },
            { initial: 'I', bg: 'bg-blue-500', issue: 'General obedience', headline: 'After two years and multiple trainers', text: 'Struggled for almost two years with multiple trainers across Toronto and the GTA. Nobody could properly train our Husky. Anesh did what felt almost impossible. Sky is extremely well behaved, listens perfectly, walks without pulling. We still send him for refreshers because Anesh is always accommodating.', name: 'Inderpal O.', detail: 'Husky · Board and train + refreshers', when: '1 month ago' },
            { initial: 'H', bg: 'bg-emerald-500', issue: 'Recall + impulse control', headline: 'Off leash in 2 months', text: 'Anesh came to our place the first day we brought home our 8 month old Golden Doodle. 5 sessions later. impulse control, loose leash walking, 100% recall. He can be let off leash at the park. The prong and e-collar made a world of difference when used properly. Breaks down training concepts super clearly.', name: 'Hanaa H.', detail: 'Golden Doodle · Private sessions', when: '3 months ago' },
            { initial: 'A', bg: 'bg-orange-500', issue: 'Separation anxiety', headline: 'Board and train was the best investment we made', text: 'Our cockapoo\'s anxiety was out of control after we relocated to Toronto. Could not leave him alone. After 4 weeks board and train he is a much calmer and happier version of himself. Walking at heel, crate trained, situations we used to avoid are now enjoyable. Weekly updates with photos throughout the program.', name: 'Annie & Sam', detail: 'Cockapoo · 4-week board and train', when: '2 months ago' },
            { initial: 'G', bg: 'bg-teal-500', issue: 'Reactivity + resource guarding', headline: 'Calmer, happier, more confident', text: 'My mini goldendoodle only listened if there was a treat involved. Poor recall, reactive on leash, anxious, and showed signs of resource guarding. After one month board and train he came home a completely different dog. Listens to all commands and consistently looks to me for direction now.', name: 'Greg M.', detail: 'Mini Goldendoodle · Board and train', when: '5 weeks ago' },
