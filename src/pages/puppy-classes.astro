---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Awards from '../components/Awards.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
import GuideBanner from '../components/GuideBanner.astro';
import QuizForm from '../components/QuizForm.astro';
import '../styles/global.css';
---

<Layout title="Puppy Training Classes Toronto — Start Early | K9 Academy" description="Puppy training classes in Toronto. Build the foundation before bad habits form. Socialization, crate training, and basic obedience for puppies under 1 year.">
  <Navbar />

  <!-- HERO -->
  <section class="relative pt-28 sm:pt-36 pb-14 sm:pb-20 overflow-hidden bg-brand-dark">
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-center mb-8">
        <div class="inline-flex items-center gap-2.5 bg-white/5 backdrop-blur-sm rounded-full px-4 py-2 border border-white/10">
          <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          <div class="flex items-center gap-0.5">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <span class="text-sm font-semibold text-white">4.9/5</span>
          <span class="w-px h-4 bg-white/20"></span>
          <span class="text-sm text-neutral-400">250+ Google Reviews</span>
        </div>
      </div>

      <div class="text-center max-w-4xl mx-auto">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-white leading-[1.08]">
          A puppy class where they
          <br />
          <span class="bg-gradient-to-r from-k9-orange to-amber-400 bg-clip-text text-transparent">actually learn</span>
        </h1>

        <div class="mt-6 inline-flex items-center gap-2.5 bg-white/5 border border-white/10 rounded-full px-4 py-2">
          <span class="text-sm text-neutral-300 italic">"Finally a puppy class worth going to."</span>
        </div>

        <p class="mt-5 text-lg sm:text-xl text-neutral-400 max-w-2xl mx-auto leading-relaxed">
          Most puppy classes are glorified playtime. Ours teaches real skills — commands, socialization, no-bite training, and house manners — that stick for life. Four sessions, recommended under 5.5 months.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="#contact" class="inline-flex items-center px-8 py-4 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30 hover:shadow-xl hover:-translate-y-0.5">
            Get on the Waitlist
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a href="tel:4377785273" class="inline-flex items-center gap-2 text-neutral-400 font-medium hover:text-white transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            Or call 437-778-5273
          </a>
        </div>

        <div class="mt-8 flex flex-wrap justify-center gap-x-6 gap-y-2">
          {['For puppies under 5.5 months', '4 one-hour sessions', 'Handbook + clicker included', 'Spots are limited'].map((item) => (
            <div class="flex items-center gap-1.5 text-sm text-neutral-500">
              <svg class="w-4 h-4 text-k9-orange flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              <span>{item}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <Awards />

  <!-- OLDER DOG REDIRECT -->
  <section class="bg-neutral-50 border-b border-neutral-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-3">
        <p class="text-sm text-neutral-700"><strong>Dog older than 6 months?</strong> Our Obedience Classes (Beginner + Advanced) are a better fit.</p>
        <a href="/group-classes" class="inline-flex items-center px-4 py-2 text-sm font-semibold text-k9-orange border border-k9-orange/30 rounded-lg hover:bg-k9-orange hover:text-white transition-all whitespace-nowrap">
          View Obedience Classes
          <svg class="ml-1.5 w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- PAS — WHY START EARLY -->
  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Why start now?</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900 leading-tight">
          The first 6 months shape the next 10+ years
        </h2>
      </div>

      <div class="mt-10 grid sm:grid-cols-2 gap-3">
        {[
          "Your puppy is nipping, jumping, and ignoring you — and it's getting worse every week",
          "You're not sure if what you're doing is right or making things worse",
          "Every YouTube video gives different advice and none of it sticks",
          "You're worried about socialization but don't know how to do it properly",
          "Your puppy is already developing habits you know will be a problem later",
          "You want to start right but don't know where to begin",
        ].map((pain) => (
          <div class="flex items-start gap-3 bg-neutral-50 rounded-xl p-4 border border-neutral-200/60">
            <svg class="w-5 h-5 text-red-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
            </svg>
            <p class="text-neutral-600 text-sm leading-relaxed">{pain}</p>
          </div>
        ))}
      </div>

      <div class="mt-10 text-center">
        <h3 class="text-2xl sm:text-3xl font-extrabold text-neutral-900 mb-4">
          It's easier to build good habits than to fix bad ones.
        </h3>
        <p class="text-lg text-neutral-500 max-w-2xl mx-auto leading-relaxed">
          Our Puppy Program gives your dog the structure, socialization, and skills they need — taught by professionals who have raised thousands of puppies.
        </p>
      </div>
    </div>
  </section>

  <!-- PROGRAMS -->
  <section id="programs" class="py-16 sm:py-24 bg-neutral-50 border-y border-neutral-100">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Puppy Programs</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900">
          Three ways to give your puppy the best start
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-5">
        <!-- Puppy Class -->
        <div class="rounded-2xl p-6 sm:p-8 border border-neutral-200/60 bg-white hover:border-neutral-300 hover:shadow-md transition-all">
          <h3 class="text-2xl font-bold text-neutral-900 mb-1">Puppy Program</h3>
          <p class="text-k9-orange font-medium text-sm mb-3">4 one-hour sessions · Under 5.5 months</p>
          <p class="text-neutral-500 text-sm mb-5 leading-relaxed">Build a strong foundation with socialization, basic commands, and house manners — before problems have a chance to develop. Includes the K9 Academy Puppy Handbook, clicker, and certificate of completion.</p>
          <ul class="space-y-2 mb-6">
            {['Sit, down, place, come commands', 'Puppy biting + destructive behaviour', 'Leash walking fundamentals', 'Potty + crate training', 'Recall training + agility intro', 'Proper socialization techniques'].map((d) => (
              <li class="flex items-start gap-2 text-sm text-neutral-600">
                <svg class="w-4 h-4 text-k9-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                <span>{d}</span>
              </li>
            ))}
          </ul>
          <div class="flex items-center justify-between pt-5 border-t border-neutral-100">
            <span class="text-2xl font-extrabold text-neutral-900">$450</span>
            <a href="#contact" class="inline-flex items-center px-5 py-2.5 text-sm font-semibold rounded-lg bg-neutral-100 text-neutral-700 hover:bg-k9-orange hover:text-white transition-all">Get on the List</a>
          </div>
        </div>

        <!-- Foundation Program -->
        <div class="relative rounded-2xl p-6 sm:p-8 border border-k9-orange/30 bg-k9-orange-light/40 ring-1 ring-k9-orange/10 hover:shadow-md transition-all">
          <div class="absolute -top-3 left-6">
            <span class="inline-flex items-center px-3 py-1 bg-k9-orange text-white text-xs font-bold rounded-lg uppercase tracking-wide">Best Value</span>
          </div>
          <h3 class="text-2xl font-bold text-neutral-900 mb-1 mt-2">Foundation Program</h3>
          <p class="text-k9-orange font-medium text-sm mb-3">Puppy + Level One combined — 10 classes total</p>
          <p class="text-neutral-500 text-sm mb-5 leading-relaxed">The complete package. Start with puppy fundamentals, then graduate seamlessly into Level One obedience. Your puppy gets the strongest possible start — and you save $260. Includes handbook, clicker, and certificate.</p>
          <ul class="space-y-2 mb-6">
            {['Everything in the Puppy Program', 'Plus full Level One obedience curriculum', 'Loose leash walking (heel position)', 'Reliable sit, down, stay', 'Recall fundamentals', '10 classes total — one seamless program'].map((d) => (
              <li class="flex items-start gap-2 text-sm text-neutral-600">
                <svg class="w-4 h-4 text-k9-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                <span>{d}</span>
              </li>
            ))}
          </ul>
          <div class="flex items-center gap-3 pt-5 border-t border-neutral-100">
            <span class="text-2xl font-extrabold text-neutral-900">$785</span>
            <span class="text-sm text-k9-orange font-semibold">Save $260</span>
            <a href="#contact" class="ml-auto inline-flex items-center px-5 py-2.5 text-sm font-semibold rounded-lg bg-k9-orange text-white hover:bg-k9-orange-dark shadow-sm transition-all">Get on the List</a>
          </div>
        </div>

        <!-- Puppy Start Right — Board & Train -->
        <div class="rounded-2xl p-6 sm:p-8 border border-neutral-200/60 bg-white hover:border-neutral-300 hover:shadow-md transition-all">
          <div class="inline-flex items-center px-3 py-1 bg-neutral-900 text-white text-xs font-bold rounded-lg uppercase tracking-wide mb-3">Premium</div>
          <h3 class="text-2xl font-bold text-neutral-900 mb-1">Puppy Start Right</h3>
          <p class="text-k9-orange font-medium text-sm mb-3">3 × 2-week stays across the first year</p>
          <p class="text-neutral-500 text-sm mb-5 leading-relaxed">Three stays timed to your puppy's development — not one long board and train too young. Each stay builds on the last as your puppy matures. Socialization first, then obedience, then full off-leash reliability.</p>
          <ul class="space-y-2 mb-6">
            {['Stay 1: Socialization + confidence + manners', 'Stay 2: Leash walking + obedience + calmness', 'Stay 3: Full off-leash reliability', 'Handover session after every stay', 'Photo + video updates throughout', 'Training that grows with your puppy'].map((d) => (
              <li class="flex items-start gap-2 text-sm text-neutral-600">
                <svg class="w-4 h-4 text-k9-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                <span>{d}</span>
              </li>
            ))}
          </ul>
          <div class="flex items-center justify-between pt-5 border-t border-neutral-100">
            <span class="text-2xl font-extrabold text-neutral-900">$3,995</span>
            <a href="/puppy-start-right" class="inline-flex items-center px-5 py-2.5 text-sm font-semibold rounded-lg bg-neutral-100 text-neutral-700 hover:bg-k9-orange hover:text-white transition-all">Learn More</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT YOUR PUPPY LEARNS -->
  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">What They Learn</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900">
          Skills that last a lifetime — built in the first 6 months
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { num: '01', title: 'Foundational commands', desc: 'Sit, down, place, and come — taught properly from the start so they become reliable habits, not tricks that only work sometimes.' },
          { num: '02', title: 'No-bite training', desc: 'Your puppy learns that teeth never go on humans — period. We stop biting and mouthing before it becomes a habit that is 10x harder to fix at 6 months.' },
          { num: '03', title: 'Potty + crate training', desc: 'House training done right from the start. Crate training, potty schedule, and the habits that make living with your puppy easy.' },
          { num: '04', title: 'Leash walking fundamentals', desc: 'Introduction to walking on leash without pulling. Start before bad habits form and you will never have to fix them later.' },
          { num: '05', title: 'Socialization techniques', desc: 'Structured interaction with other puppies and people. Not a free-for-all — guided socialization that builds confidence, not fear.' },
          { num: '06', title: 'Recall + agility intro', desc: 'Build reliable recall from day one, plus an introduction to agility to build coordination and confidence in young dogs.' },
        ].map((prop) => (
          <div class="rounded-2xl p-6 bg-neutral-50 border border-neutral-200/60 hover:border-neutral-300 transition-all">
            <div class="w-8 h-8 rounded-lg bg-k9-orange/10 flex items-center justify-center mb-4">
              <span class="text-k9-orange font-bold text-sm">{prop.num}</span>
            </div>
            <h3 class="text-base font-bold text-neutral-900 mb-2">{prop.title}</h3>
            <p class="text-neutral-500 text-sm leading-relaxed">{prop.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="py-16 sm:py-24 bg-neutral-50 border-y border-neutral-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">What Puppy Owners Say</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900">
          The best investment you can make in your puppy
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          { headline: 'Best thing we did as new dog owners', text: 'We had no idea what we were doing with our first puppy. K9 Academy gave us the structure and confidence we needed. By 5 months old our puppy was better behaved than most adult dogs we see at the park.', name: 'Priya S.', detail: 'Lab mix, started at 12 weeks · Foundation Program' },
          { headline: 'Wish we started even sooner', text: 'We waited until our puppy was 4 months and already had some nipping issues. Within two weeks of the Puppy Class, the biting stopped completely. The socialization alone was worth the entire price.', name: 'Alex & Jen M.', detail: 'Golden Retriever, 4 months · Puppy Class' },
          { headline: 'Our vet noticed the difference', text: 'At our last vet visit, they actually commented on how well-behaved our puppy was compared to most dogs they see. That is all from K9 Academy. The Foundation Program set him up for life.', name: 'Marcus T.', detail: 'Bernese Mountain Dog, 14 weeks · Foundation Program' },
        ].map((t) => (
          <div class="bg-white rounded-2xl p-6 border border-neutral-200/60 flex flex-col">
            <div class="flex items-center gap-2 mb-4">
              <svg class="w-5 h-5" viewBox="0 0 24 24">
                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" />
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
              </svg>
              <div class="flex items-center gap-0.5">
                {[1,2,3,4,5].map(() => (
                  <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
            </div>
            <h3 class="text-base font-bold text-neutral-900 mb-2">{t.headline}</h3>
            <p class="text-neutral-500 text-sm leading-relaxed flex-grow mb-4">{t.text}</p>
            <div class="pt-4 border-t border-neutral-100">
              <p class="font-semibold text-neutral-900 text-sm">{t.name}</p>
              <p class="text-xs text-neutral-400">{t.detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CURRICULUM DOWNLOAD -->
  <section class="py-16 sm:py-24 bg-brand-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div>
          <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Free Download</p>
          <h2 class="text-2xl sm:text-3xl font-extrabold text-white mb-4">
            Download the Puppy Program curriculum
          </h2>
          <p class="text-neutral-400 leading-relaxed mb-6">
            See exactly what your puppy will learn week by week. Get the full breakdown of our Puppy Class and Foundation Program so you know what to expect.
          </p>
          <ul class="space-y-2 mb-6">
            {['Full week-by-week skill breakdown', 'What to practice at home between classes', 'Puppy Class vs Foundation Program comparison'].map((item) => (
              <li class="flex items-center gap-2 text-sm text-neutral-300">
                <svg class="w-4 h-4 text-k9-orange flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-2xl p-6">
          <h3 class="text-lg font-bold text-white mb-1">Get the free curriculum</h3>
          <p class="text-sm text-neutral-400 mb-4">Enter your email and we send it right over.</p>
          <form id="puppy-curriculum-form" class="space-y-3">
            <input type="text" name="pcurr_name" required placeholder="Your name"
              class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-k9-orange/30 focus:border-k9-orange transition text-sm" />
            <input type="email" name="pcurr_email" required placeholder="Your email"
              class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-k9-orange/30 focus:border-k9-orange transition text-sm" />
            <button type="submit" id="pcurr-submit-btn"
              class="w-full py-3 bg-k9-orange text-white text-sm font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/20 disabled:opacity-50">
              Download the Curriculum
            </button>
            <p class="text-xs text-neutral-500 text-center">No spam. Just the curriculum and helpful puppy tips.</p>
          </form>
          <div id="pcurr-success" class="hidden text-center py-6">
            <svg class="w-10 h-10 mx-auto mb-3 text-k9-orange" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
            <p class="text-white font-semibold">Check your email!</p>
            <p class="text-neutral-400 text-sm mt-1">The curriculum is on its way.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    const pForm = document.getElementById('puppy-curriculum-form') as HTMLFormElement;
    const pBtn = document.getElementById('pcurr-submit-btn') as HTMLButtonElement;
    const pSuccess = document.getElementById('pcurr-success') as HTMLDivElement;

    pForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      pBtn.disabled = true;
      pBtn.textContent = 'Sending...';

      const formData = new FormData(pForm);
      const name = formData.get('pcurr_name') as string;
      const email = formData.get('pcurr_email') as string;

      try {
        // Server-side submission (survives ad blockers)
        await fetch('/api/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name,
            email,
            phone: '',
            service: 'curriculum_download_puppy',
            message: 'Downloaded puppy curriculum',
            dog_info: '',
          }),
        }).catch(() => {});

        // Push to Klaviyo (client-side backup)
        const _learnq = (window as any)._learnq || [];
        _learnq.push(['identify', {
          '$email': email,
          '$first_name': name.split(' ')[0] || '',
          '$last_name': name.split(' ').slice(1).join(' ') || '',
          'Source': 'Puppy Curriculum Download',
        }]);
        _learnq.push(['track', 'Curriculum Download', {
          'Name': name,
          'Email': email,
          'Curriculum': 'Puppy Classes',
        }]);

        pForm.classList.add('hidden');
        pSuccess.classList.remove('hidden');

        if (typeof fbq !== 'undefined') {
          (window as any).fbq('track', 'Lead', { content_name: 'Puppy Curriculum Download' });
        }
        if (typeof gtag !== 'undefined') {
          (window as any).gtag('event', 'generate_lead', { event_category: 'curriculum', event_label: 'puppy_classes' });
        }
      } catch {
        pBtn.disabled = false;
        pBtn.textContent = 'Download the Curriculum';
      }
    });
  </script>

  <!-- HOW IT WORKS -->
