---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Awards from '../components/Awards.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Layout title="Group Classes — K9 Academy Training Toronto">
  <Navbar />

  <!-- HERO -->
  <section class="relative pt-28 sm:pt-36 pb-14 sm:pb-20 overflow-hidden bg-brand-dark">
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-center mb-8">
        <div class="inline-flex items-center gap-2.5 bg-white/5 backdrop-blur-sm rounded-full px-4 py-2 border border-white/10">
          <div class="flex items-center gap-0.5">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <span class="text-sm font-semibold text-white">4.9/5</span>
          <span class="w-px h-4 bg-white/20"></span>
          <span class="text-sm text-neutral-400">250+ Google Reviews</span>
        </div>
      </div>

      <div class="text-center max-w-4xl mx-auto">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-white leading-[1.08]">
          A trained dog and a community
          <br />
          <span class="bg-gradient-to-r from-k9-orange to-amber-400 bg-clip-text text-transparent">of owners who get it</span>
        </h1>

        <p class="mt-6 text-lg sm:text-xl text-neutral-400 max-w-2xl mx-auto leading-relaxed">
          Beginner and Advanced obedience classes at our Leaside location. Small groups, real skills, expert instructors.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="#contact" class="inline-flex items-center px-8 py-4 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30 hover:shadow-xl hover:-translate-y-0.5">
            Join the Waitlist
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a href="tel:4377785273" class="inline-flex items-center gap-2 text-neutral-400 font-medium hover:text-white transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            Or call 437-778-5273
          </a>
        </div>

        <div class="mt-8 flex flex-wrap justify-center gap-x-6 gap-y-2">
          {['Saturdays + Wednesdays', 'Leaside location', 'Small group sizes', 'All levels'].map((item) => (
            <div class="flex items-center gap-1.5 text-sm text-neutral-500">
              <svg class="w-4 h-4 text-k9-orange flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              <span>{item}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <Awards />

  <!-- PUPPY REDIRECT BANNER -->
  <section class="bg-k9-orange-light border-b border-k9-orange/10">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-3">
        <p class="text-sm text-neutral-700"><strong>Got a puppy under 6 months?</strong> Our Puppy Program is designed specifically for young dogs.</p>
        <a href="/puppy-classes" class="inline-flex items-center px-4 py-2 text-sm font-semibold text-k9-orange border border-k9-orange/30 rounded-lg hover:bg-k9-orange hover:text-white transition-all whitespace-nowrap">
          View Puppy Classes
          <svg class="ml-1.5 w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CLASS OPTIONS -->
  <section id="classes" class="py-16 sm:py-24 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Our Obedience Classes</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900">
          Pick the right level for your dog
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-5">
        <!-- Beginner -->
        <div class="rounded-2xl p-6 sm:p-8 border border-neutral-200/60 bg-white hover:border-neutral-300 hover:shadow-md transition-all">
          <h3 class="text-2xl font-bold text-neutral-900 mb-1">Beginner Class</h3>
          <p class="text-k9-orange font-medium text-sm mb-3">Build reliable obedience from the ground up</p>
          <p class="text-neutral-500 text-sm mb-5 leading-relaxed">For dogs of any age who need foundational obedience. Leash manners, recall, sit, down, stay — the essentials that make life with your dog easier.</p>
          <ul class="space-y-2 mb-6">
            {['Leash manners + loose leash walking', 'Reliable sit, down, stay', 'Recall fundamentals', 'Distraction training', 'New classes open regularly — spots are limited'].map((d) => (
              <li class="flex items-start gap-2 text-sm text-neutral-600">
                <svg class="w-4 h-4 text-k9-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                <span>{d}</span>
              </li>
            ))}
          </ul>
          <div class="flex items-center justify-between pt-5 border-t border-neutral-100">
            <span class="text-2xl font-extrabold text-neutral-900">$595</span>
            <a href="#contact" class="inline-flex items-center px-5 py-2.5 text-sm font-semibold rounded-lg bg-neutral-100 text-neutral-700 hover:bg-k9-orange hover:text-white transition-all">Get on the List</a>
          </div>
        </div>

        <!-- Advanced -->
        <div class="rounded-2xl p-6 sm:p-8 border border-neutral-200/60 bg-white hover:border-neutral-300 hover:shadow-md transition-all">
          <h3 class="text-2xl font-bold text-neutral-900 mb-1">Advanced Class</h3>
          <p class="text-k9-orange font-medium text-sm mb-3">Off-leash reliability in real-world situations</p>
          <p class="text-neutral-500 text-sm mb-5 leading-relaxed">For dogs who have completed Beginner or have solid foundations. Advanced recall, off-leash work, duration commands, and real-world proofing.</p>
          <ul class="space-y-2 mb-6">
            {['Off-leash obedience', 'Advanced recall under distraction', 'Duration commands', 'Real-world proofing', 'New classes open regularly — spots are limited'].map((d) => (
              <li class="flex items-start gap-2 text-sm text-neutral-600">
                <svg class="w-4 h-4 text-k9-green flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                <span>{d}</span>
              </li>
            ))}
          </ul>
          <div class="flex items-center justify-between pt-5 border-t border-neutral-100">
            <span class="text-2xl font-extrabold text-neutral-900">$595</span>
            <a href="#contact" class="inline-flex items-center px-5 py-2.5 text-sm font-semibold rounded-lg bg-neutral-100 text-neutral-700 hover:bg-k9-orange hover:text-white transition-all">Get on the List</a>
          </div>
        </div>
      </div>

      <!-- Bundle -->
      <div class="mt-8">
        <div class="relative rounded-2xl p-6 sm:p-8 border border-k9-orange/30 bg-k9-orange-light/40 ring-1 ring-k9-orange/10 hover:shadow-md transition-all">
          <div class="absolute -top-3 left-6">
            <span class="inline-flex items-center px-3 py-1 bg-k9-orange text-white text-xs font-bold rounded-lg uppercase tracking-wide">Best Value</span>
          </div>
          <div class="md:flex md:items-center md:justify-between mt-2">
            <div>
              <h3 class="text-2xl font-bold text-neutral-900 mb-1">Beginner + Advanced Bundle</h3>
              <p class="text-k9-orange font-medium text-sm mb-2">From zero to off-leash reliable — the full journey</p>
              <p class="text-neutral-500 text-sm leading-relaxed max-w-lg">Complete the full obedience program. Beginner builds the foundation, Advanced takes it to real-world, off-leash reliability.</p>
            </div>
            <div class="flex items-center gap-3 mt-4 md:mt-0">
              <div class="text-right">
                <span class="text-2xl font-extrabold text-neutral-900">$995</span>
                <span class="block text-sm text-k9-orange font-semibold">Save $195</span>
              </div>
              <a href="#contact" class="inline-flex items-center px-5 py-2.5 text-sm font-semibold rounded-lg bg-k9-orange text-white hover:bg-k9-orange-dark shadow-sm transition-all">Get on the List</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SCHEDULE -->
  <section class="py-16 sm:py-24 bg-neutral-50 border-y border-neutral-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Schedule</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900">
          We open new classes regularly — spots fill fast
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 gap-5">
        <div class="bg-white rounded-2xl p-6 border border-neutral-200/60">
          <div class="w-12 h-12 rounded-xl bg-k9-orange/10 flex items-center justify-center mb-4">
            <span class="text-k9-orange font-bold text-sm">SAT</span>
          </div>
          <h3 class="text-lg font-bold text-neutral-900 mb-1">Saturday Classes</h3>
          <p class="text-neutral-500 text-sm">9:00 AM – 4:00 PM</p>
          <p class="text-neutral-400 text-sm mt-2">Leaside — 16-30 Canvarco Rd, Toronto</p>
        </div>
        <div class="bg-white rounded-2xl p-6 border border-neutral-200/60">
          <div class="w-12 h-12 rounded-xl bg-k9-orange/10 flex items-center justify-center mb-4">
            <span class="text-k9-orange font-bold text-sm">WED</span>
          </div>
          <h3 class="text-lg font-bold text-neutral-900 mb-1">Wednesday Classes</h3>
          <p class="text-neutral-500 text-sm">7:00 PM – 9:00 PM</p>
          <p class="text-neutral-400 text-sm mt-2">Leaside — 16-30 Canvarco Rd, Toronto</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CURRICULUM DOWNLOAD LEAD MAGNET -->
  <section class="py-16 sm:py-24 bg-brand-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div>
          <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Free Download</p>
          <h2 class="text-2xl sm:text-3xl font-extrabold text-white mb-4">
            See exactly what your dog will learn — download the class curriculum
          </h2>
          <p class="text-neutral-400 leading-relaxed mb-6">
            Get a breakdown of every skill covered in our Beginner and Advanced programs. See the full week-by-week curriculum so you know exactly what to expect.
          </p>
          <ul class="space-y-2 mb-6">
            {['Full curriculum for Beginner + Advanced', 'Week-by-week skill breakdown', 'What to practice between classes'].map((item) => (
              <li class="flex items-center gap-2 text-sm text-neutral-300">
                <svg class="w-4 h-4 text-k9-orange flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-2xl p-6">
          <h3 class="text-lg font-bold text-white mb-1">Get the free curriculum</h3>
          <p class="text-sm text-neutral-400 mb-4">Enter your email and we'll send it right over.</p>
          <form id="curriculum-form" class="space-y-3">
            <input type="text" name="curr_name" required placeholder="Your name"
              class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-k9-orange/30 focus:border-k9-orange transition text-sm" />
            <input type="email" name="curr_email" required placeholder="Your email"
              class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-k9-orange/30 focus:border-k9-orange transition text-sm" />
            <button type="submit" id="curr-submit-btn"
              class="w-full py-3 bg-k9-orange text-white text-sm font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/20 disabled:opacity-50">
              Download the Curriculum
            </button>
            <p class="text-xs text-neutral-500 text-center">No spam. Just the curriculum and helpful training tips.</p>
          </form>
          <div id="curr-success" class="hidden text-center py-6">
            <svg class="w-10 h-10 mx-auto mb-3 text-k9-orange" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
            <p class="text-white font-semibold">Check your email!</p>
            <p class="text-neutral-400 text-sm mt-1">The curriculum is on its way.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    const currForm = document.getElementById('curriculum-form') as HTMLFormElement;
    const currBtn = document.getElementById('curr-submit-btn') as HTMLButtonElement;
    const currSuccess = document.getElementById('curr-success') as HTMLDivElement;

    currForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      currBtn.disabled = true;
      currBtn.textContent = 'Sending...';

      const formData = new FormData(currForm);
      const name = formData.get('curr_name') as string;
      const email = formData.get('curr_email') as string;

      try {
        // Push to Klaviyo
        const _learnq = (window as any)._learnq || [];
        _learnq.push(['identify', {
          '$email': email,
          '$first_name': name.split(' ')[0] || '',
          '$last_name': name.split(' ').slice(1).join(' ') || '',
          'Source': 'Curriculum Download',
        }]);
        _learnq.push(['track', 'Curriculum Download', {
          'Name': name,
          'Email': email,
          'Curriculum': 'Group Classes',
        }]);

        currForm.classList.add('hidden');
        currSuccess.classList.remove('hidden');

        // Fire tracking events
        if (typeof fbq !== 'undefined') {
          (window as any).fbq('track', 'Lead', { content_name: 'Curriculum Download' });
        }
        if (typeof gtag !== 'undefined') {
          (window as any).gtag('event', 'generate_lead', { event_category: 'curriculum', event_label: 'group_classes' });
        }
      } catch {
        currBtn.disabled = false;
        currBtn.textContent = 'Download the Curriculum';
      }
    });
  </script>

  <!-- WHY GROUP -->
  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Why Group Classes</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900">
          Training your dog shouldn't feel like you're doing it alone
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { num: '01', title: 'Real-world distractions built in', desc: 'Other dogs, people, noises — group classes simulate the environments your dog actually needs to perform in.' },
          { num: '02', title: 'Socialization that actually works', desc: 'Structured interaction with other dogs under professional guidance. Not a dog park free-for-all.' },
          { num: '03', title: 'Expert instruction every session', desc: 'Led by K9 Academy\'s training team — 15+ years experience, 10,000+ dogs trained.' },
          { num: '04', title: 'A community that gets it', desc: 'You\'re surrounded by other owners working through the same challenges. Support makes the difference.' },
          { num: '05', title: 'Affordable path to obedience', desc: 'Group classes deliver real results at a fraction of the cost of private lessons. Bundles save even more.' },
          { num: '06', title: 'New classes open frequently', desc: 'Classes run every week. We open new classes regularly and fill them fast. Get on the list to be first to know.' },
        ].map((prop) => (
          <div class="rounded-2xl p-6 bg-neutral-50 border border-neutral-200/60 hover:border-neutral-300 transition-all">
            <div class="w-8 h-8 rounded-lg bg-k9-orange/10 flex items-center justify-center mb-4">
              <span class="text-k9-orange font-bold text-sm">{prop.num}</span>
            </div>
            <h3 class="text-base font-bold text-neutral-900 mb-2">{prop.title}</h3>
            <p class="text-neutral-500 text-sm leading-relaxed">{prop.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="py-16 sm:py-24 bg-neutral-50 border-y border-neutral-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">What Owners Say</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900">
          Group class results that speak for themselves
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          { headline: 'Our puppy graduated top of the class', text: 'We enrolled our 14-week-old lab in the Puppy class and then straight into Beginner. The structure was exactly what she needed. By the end of the Foundation Program she was walking on a loose leash and sitting on command every time.', name: 'Priya S.', detail: 'Lab mix, 14 weeks · Foundation Program' },
          { headline: 'Got kicked out of another class. Thrived here.', text: 'Our shepherd mix was asked to leave another training program because he was "too much." K9 Academy took him in, worked with him in the group setting, and he went from being the problem dog to the one other owners were asking about.', name: 'Dan & Sarah R.', detail: 'Shepherd mix, 2 years · Beginner + Advanced' },
          { headline: 'The group setting made all the difference', text: 'We tried training at home for months. Nothing stuck. The group classes gave our dog real distractions to work through — other dogs, noises, people. That was the missing piece. She actually listens outside now, not just in our living room.', name: 'Michelle K.', detail: 'Doodle, 1 year · Beginner Class' },
        ].map((t) => (
          <div class="bg-white rounded-2xl p-6 border border-neutral-200/60 flex flex-col">
            <div class="flex items-center gap-2 mb-4">
              <svg class="w-5 h-5" viewBox="0 0 24 24">
                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" />
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
              </svg>
              <div class="flex items-center gap-0.5">
                {[1,2,3,4,5].map(() => (
                  <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
            </div>
            <h3 class="text-base font-bold text-neutral-900 mb-2">{t.headline}</h3>
            <p class="text-neutral-500 text-sm leading-relaxed flex-grow mb-4">{t.text}</p>
            <div class="pt-4 border-t border-neutral-100">
              <p class="font-semibold text-neutral-900 text-sm">{t.name}</p>
              <p class="text-xs text-neutral-400">{t.detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="py-16 sm:py-24 bg-brand-dark">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Getting Started</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-white">
          Getting started takes 30 seconds
        </h2>
      </div>

