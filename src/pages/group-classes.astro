---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Awards from '../components/Awards.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
import GuideBanner from '../components/GuideBanner.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';
import '../styles/global.css';
---

<Layout title="Group Dog Obedience Classes Toronto | Level 1, 2 & 3 | K9 Academy" description="Group dog obedience classes in Toronto. Small groups, real-world distractions, off-leash reliability. Level 1 ($595), Level 2, Level 3: Leaside location.">
  <Navbar />

  <!-- HERO -->
  <section class="relative pt-28 sm:pt-32 pb-14 sm:pb-20 overflow-hidden bg-brand-dark">
    <div class="absolute inset-0 bg-gradient-to-br from-k9-orange/5 via-transparent to-transparent pointer-events-none"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">

        <!-- LEFT: Copy -->
        <div>
          <div class="inline-flex items-center gap-2.5 bg-white/5 backdrop-blur-sm rounded-full px-4 py-2 border border-white/10 mb-6">
            <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            <div class="flex items-center gap-0.5">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <span class="text-sm font-semibold text-white">4.9/5</span>
            <span class="w-px h-4 bg-white/20"></span>
            <span class="text-sm text-neutral-400">250+ Google Reviews</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[3.4rem] font-extrabold tracking-tight text-white leading-[1.05]">
            From leash pulling to
            <span class="bg-gradient-to-r from-k9-orange to-amber-400 bg-clip-text text-transparent">off-leash reliable</span>
          </h1>

          <div class="mt-6 inline-flex items-center gap-2.5 bg-white/5 border border-white/10 rounded-full px-4 py-2">
            <span class="text-sm text-neutral-300 italic">"The class that replaces every other class you've ever tried."</span>
          </div>

          <p class="mt-5 text-base sm:text-lg text-neutral-400 max-w-xl leading-relaxed">
            Three levels of real-world obedience. trained around the exact distractions your dog struggles with. Small groups, expert instructors, and a community of owners working through the same stuff.
          </p>

          <!-- Outcomes -->
          <div class="mt-7 grid sm:grid-cols-2 gap-2.5 max-w-xl">
            {[
              'Loose-leash walking',
              'Calm around other dogs',
              'Obedience under distraction',
              'Full off-leash reliability',
              'No more reactivity',
              'Real-world, not living room',
            ].map((item) => (
              <div class="flex items-center gap-2.5 text-sm text-neutral-300">
                <div class="w-5 h-5 rounded-full bg-k9-orange/15 flex items-center justify-center flex-shrink-0">
                  <svg class="w-3 h-3 text-k9-orange" fill="none" stroke="currentColor" stroke-width="3.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                  </svg>
                </div>
                <span>{item}</span>
              </div>
            ))}
          </div>

          <!-- CTAs -->
          <div class="mt-8 flex flex-col sm:flex-row items-start sm:items-center gap-4">
            <a href="#contact" class="inline-flex items-center px-7 py-4 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30 hover:shadow-xl hover:-translate-y-0.5">
              Join the Waitlist
              <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
            <a href="tel:4377785273" class="inline-flex items-center gap-2 text-neutral-400 font-medium hover:text-white transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              Or call 437-778-5273
            </a>
          </div>

          <!-- Trust line -->
          <div class="mt-6 flex flex-wrap items-center gap-x-5 gap-y-1.5 text-xs text-neutral-500">
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5 text-k9-orange" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              Saturdays + Wednesdays
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5 text-k9-orange" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              Leaside, Toronto
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5 text-k9-orange" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              15+ years experience
            </span>
          </div>
        </div>

        <!-- RIGHT: Hero Video -->
        <div class="relative">
          <div class="rounded-2xl overflow-hidden border border-white/10 shadow-2xl shadow-black/50">
            <YouTubeEmbed videoId="rxf3wxky8qg" title="K9 Academy Group Classes" />
          </div>
          <div class="absolute -bottom-4 -left-4 sm:-bottom-5 sm:-left-5 bg-white rounded-xl px-4 py-3 shadow-xl">
            <p class="text-2xl font-black text-k9-orange">$595</p>
            <p class="text-xs text-neutral-500">per level</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- PUPPY REDIRECT BANNER -->
  <section class="bg-neutral-950 border-b border-white/5">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <div>
          <p class="text-lg font-bold text-white">Got a puppy?</p>
          <p class="text-sm text-neutral-400">Our Puppy Group Classes are designed specifically for young dogs, start before bad habits form.</p>
        </div>
        <div class="flex items-center gap-3">
          <a href="/puppy-classes" class="inline-flex items-center px-5 py-2.5 text-sm font-semibold bg-k9-orange text-white rounded-lg hover:bg-k9-orange-dark transition-all whitespace-nowrap">
            View Puppy Classes
            <svg class="ml-1.5 w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <Awards />

  <!-- ============================================================ -->
  <!-- LEVEL 1. THE FOUNDATION                                     -->
  <!-- ============================================================ -->
  <section id="level-1" class="py-16 sm:py-24 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Section Header -->
      <div class="text-center mb-12 sm:mb-16">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-k9-orange/10 rounded-full mb-4">
          <span class="w-2.5 h-2.5 rounded-full bg-k9-orange animate-pulse"></span>
          <span class="text-k9-orange font-bold text-sm uppercase tracking-wide">Where Everyone Starts</span>
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-neutral-900 leading-tight">
          Level 1: Basic Obedience
        </h2>
        <p class="mt-4 text-lg text-neutral-500 max-w-2xl mx-auto">
          6 weeks that cover more than most training centres teach in their entire program. Your dog walks on a loose leash by the end of session one.
        </p>
        <div class="mt-4 flex items-center justify-center gap-4 text-sm">
          <span class="font-extrabold text-3xl text-neutral-900">$595</span>
          <span class="text-neutral-300">·</span>
          <span class="text-neutral-500">6 weeks</span>
          <span class="text-neutral-300">·</span>
          <span class="text-neutral-500">Leaside, Toronto</span>
        </div>
      </div>

      <!-- What You Get + Test Videos -->
      <div class="grid md:grid-cols-2 gap-6 mb-12">
        <div class="space-y-4">
          <h3 class="text-xl font-bold text-neutral-900">What your dog will be able to do</h3>
          {[
            { skill: 'Loose-leash walking in heel position', note: 'Leash pulling is addressed from the very first session' },
            { skill: 'Sit, down, place, and stay commands', note: 'Under real-world distractions, not just your living room' },
            { skill: 'Mild reactivity management', note: 'Walk past other dogs without losing it' },
            { skill: 'Impulse control and focus', note: 'Your dog looks to you instead of reacting to everything' },
            { skill: 'Structured walk protocol', note: 'Walks become enjoyable instead of stressful' },
            { skill: 'Calm settling at home', note: 'Your dog learns to relax and switch off, not pace and whine' },
            { skill: 'Reliable recall under distraction', note: 'Your dog listens outside despite dogs, people, and noise around them' },
          ].map((item) => (
            <div class="flex items-start gap-3 p-4 bg-neutral-50 rounded-xl border border-neutral-100">
              <div class="w-6 h-6 rounded-full bg-k9-orange/15 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5 text-k9-orange" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-neutral-900 text-sm">{item.skill}</p>
                <p class="text-neutral-500 text-sm mt-0.5">{item.note}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Level 1 Test Videos -->
        <div>
          <h3 class="text-xl font-bold text-neutral-900 mb-2">The Level 1 Test</h3>
          <p class="text-neutral-500 text-sm mb-4">Every Level 1 graduate takes this test. Real dogs, real distractions, real results.</p>
          <div class="space-y-4">
            <div class="rounded-2xl overflow-hidden border border-neutral-200 shadow-sm">
              <YouTubeEmbed videoId="3N_QU9tk5Bs" title="Level 1 Test. Example 1" />
            </div>
            <div class="rounded-2xl overflow-hidden border border-neutral-200 shadow-sm">
              <YouTubeEmbed videoId="bUkxQEh7Omo" title="Level 1 Test. Example 2" />
            </div>
          </div>
        </div>
      </div>

      <!-- Comparison Chart -->
      <div class="mb-12">
        <div class="text-center mb-8">
          <h3 class="text-2xl font-extrabold text-neutral-900">How we compare</h3>
          <p class="mt-2 text-neutral-500 max-w-xl mx-auto text-sm">Most places distract the dog or manage symptoms. We fix the actual problem, and deliver results other companies charge 3–4x more for.</p>
        </div>

        <div class="overflow-x-auto -mx-4 px-4 sm:mx-0 sm:px-0">
          <table class="w-full border-collapse text-sm">
            <thead>
              <tr>
                <th class="text-left p-3 sm:p-4 text-neutral-500 font-medium text-xs uppercase tracking-wide"></th>
                <th class="p-3 sm:p-4 text-center rounded-t-xl bg-k9-orange text-white font-bold text-xs uppercase tracking-wide">K9 Academy Group</th>
                <th class="p-3 sm:p-4 text-center text-neutral-500 font-medium text-xs uppercase tracking-wide bg-neutral-50">Other Group Classes</th>
              </tr>
            </thead>
            <tbody>
              {[
                { feature: 'Price', k9: '$595', other: '$300–$600', highlight: false },
                { feature: 'Fixes the root problem', k9: true, other: false, highlight: false },
                { feature: 'Leash pulling addressed', k9: 'Session 1', other: 'Weeks 4–6', highlight: false },
                { feature: 'Real-world distractions', k9: true, other: false, highlight: false },
                { feature: 'Off-leash reliability', k9: 'Level 2', other: false, highlight: false },
                { feature: 'Owner learns too', k9: true, other: 'Minimal', highlight: false },
                { feature: 'Reactivity management', k9: true, other: false, highlight: false },
                { feature: 'Socialization built in', k9: true, other: 'Limited', highlight: false },
                { feature: 'Structured test & graduation', k9: true, other: false, highlight: false },
                { feature: 'E-collar training', k9: 'Level 2', other: false, highlight: false },
                { feature: 'Results guarantee', k9: true, other: false, highlight: false },
                { feature: 'Clear, visible results from day one', k9: 'Yes. every session', other: 'Rarely', highlight: true },
              ].map((row, i) => (
                <tr class={row.highlight ? 'bg-k9-orange/10 border-t-2 border-k9-orange/30' : i % 2 === 0 ? 'bg-white' : 'bg-neutral-50/50'}>
                  <td class={`p-3 sm:p-4 text-sm whitespace-nowrap ${row.highlight ? 'font-extrabold text-neutral-900' : 'font-medium text-neutral-900'}`}>{row.feature}</td>
                  <td class={`p-3 sm:p-4 text-center font-semibold ${row.highlight ? 'bg-k9-orange/15' : 'bg-k9-orange/5'} text-neutral-900`}>
                    {row.k9 === true ? (
                      <svg class="w-5 h-5 text-k9-orange mx-auto" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                    ) : typeof row.k9 === 'string' ? (
                      <span class={`font-bold ${row.highlight ? 'text-k9-orange text-base' : 'text-k9-orange'}`}>{row.k9}</span>
                    ) : (
                      <svg class="w-5 h-5 text-neutral-300 mx-auto" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                    )}
                  </td>
                  <td class={`p-3 sm:p-4 text-center ${row.highlight ? 'text-red-400 font-semibold' : 'text-neutral-500'}`}>
                    {row.other === true ? (
                      <svg class="w-5 h-5 text-emerald-500 mx-auto" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                    ) : row.other === false ? (
                      <svg class="w-5 h-5 text-neutral-300 mx-auto" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                    ) : (
                      <span>{row.other}</span>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Level 1 CTA -->
      <div class="text-center">
        <a href="#contact" class="inline-flex items-center px-7 py-4 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30 hover:shadow-xl hover:-translate-y-0.5">
          Join Level 1 Waitlist — $595
          <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
        <p class="mt-3 text-sm text-neutral-400">No prerequisites. Any breed. Any age.</p>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- LEVEL 2. OFF-LEASH RELIABLE                                 -->
  <!-- ============================================================ -->
  <section id="level-2" class="py-16 sm:py-24 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center mb-12 sm:mb-16">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-50 rounded-full mb-4">
          <span class="w-2.5 h-2.5 rounded-full bg-emerald-500"></span>
          <span class="text-emerald-700 font-bold text-sm uppercase tracking-wide">The Next Step</span>
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-neutral-900 leading-tight">
          Level 2: Complete Off-Leash Control
        </h2>
        <p class="mt-4 text-lg text-neutral-500 max-w-2xl mx-auto">
          Full off-leash control that finally gives you complete freedom. parks, trails, patios, anywhere. E-collar training, bulletproof recall, and obedience under heavy distraction, ending with a graduation hike where your dog proves it in the real world.
        </p>
        <div class="mt-4 flex items-center justify-center gap-4 text-sm">
          <span class="font-extrabold text-3xl text-neutral-900">$595</span>
          <span class="text-neutral-300">·</span>
          <span class="text-neutral-500">6 weeks + test</span>
          <span class="text-neutral-300">·</span>
          <span class="text-neutral-500">Requires Level 1</span>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-6 mb-12">
        <!-- What you learn -->
        <div class="space-y-4">
          <h3 class="text-xl font-bold text-neutral-900">What Level 2 adds</h3>
          {[
            { skill: 'E-collar introduction and training', note: 'You purchase the e-collar separately. we teach you exactly how to use it humanely and effectively' },
            { skill: 'Bulletproof off-leash recall', note: 'Your dog comes back on command, every time, even mid-sprint toward a squirrel' },
            { skill: 'Obedience under heavy distraction', note: 'Sit-stays and down-stays while other dogs, people, and chaos happen around them' },
            { skill: 'Distance commands', note: 'Control your dog from 30+ feet away with verbal and e-collar cues' },
            { skill: 'Off-leash graduation hike', note: 'The final session is a real trail hike where your dog proves off-leash reliability in the wild' },
          ].map((item) => (
            <div class="flex items-start gap-3 p-4 bg-neutral-50 rounded-xl border border-neutral-100">
              <div class="w-6 h-6 rounded-full bg-emerald-50 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5 text-emerald-600" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-neutral-900 text-sm">{item.skill}</p>
                <p class="text-neutral-500 text-sm mt-0.5">{item.note}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- The test + graduation -->
        <div class="space-y-4">
          <h3 class="text-xl font-bold text-neutral-900">The Level 2 Test</h3>
          <div class="p-5 bg-neutral-50 rounded-xl border border-neutral-100">
            <p class="text-neutral-700 text-sm leading-relaxed mb-4">
              Level 2 ends with a scored test that covers everything: recall under distraction, distance commands, e-collar obedience, and handler control. You need to <strong>pass to graduate</strong>.
            </p>
            <p class="text-neutral-700 text-sm leading-relaxed mb-4">
              The final session is a <strong>graduation hike</strong>. a real off-leash trail walk with the entire class. Your dog walks off-leash alongside other dogs in an uncontrolled environment. This is where it all comes together.
            </p>
            <div class="p-4 bg-white rounded-lg border border-neutral-200">
              <p class="text-sm font-semibold text-neutral-900 mb-2">What Level 2 graduates can do:</p>
              <ul class="space-y-1.5">
                {[
                  'Walk off-leash in busy parks and trails',
                  'Recall mid-chase (squirrels, other dogs)',
                  'Hold sit/down stays in chaotic environments',
                  'Respond to distance commands at 30+ feet',
                  'Hike off-leash with other dogs confidently',
                ].map((item) => (
                  <li class="flex items-center gap-2 text-sm text-neutral-600">
                    <svg class="w-3.5 h-3.5 text-emerald-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                    </svg>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <div class="p-4 bg-k9-orange/5 rounded-xl border border-k9-orange/20">
            <p class="text-sm text-neutral-700 leading-relaxed">
              <strong class="text-neutral-900">Prerequisite:</strong> Must pass Level 1 or pass an assessment. Level 2 builds directly on the foundation. there are no shortcuts.
            </p>
          </div>
        </div>
      </div>

      <!-- Level 2 CTA -->
      <div class="text-center">
        <a href="#contact" class="inline-flex items-center px-7 py-4 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30 hover:shadow-xl hover:-translate-y-0.5">
          Join Level 2 Waitlist — $595
          <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
