---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Dog Training Blog — Tips & Guides | K9 Academy Toronto" description="Expert dog training tips from Toronto's top-rated trainers. Guides on aggression, reactivity, leash pulling, puppy training, board and train, and more.">
  <Navbar />

  <!-- Hero -->
  <section class="pt-28 sm:pt-32 pb-10 sm:pb-14 bg-brand-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-k9-orange font-semibold text-xs tracking-wide uppercase mb-3">From the Trainers</p>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white">Dog Training Tips & Guides</h1>
      <p class="mt-4 text-neutral-500 max-w-2xl mx-auto">Honest advice from 15+ years and 10,000+ dogs. No fluff — just what actually works.</p>
    </div>
  </section>

  <!-- Post Grid -->
  <section class="py-12 sm:py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post) => {
          const dateStr = post.data.date.toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' });
          return (
            <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="group block rounded-2xl border border-neutral-200/60 bg-white p-6 hover:shadow-lg hover:border-neutral-300 transition-all">
              <div class="flex flex-wrap gap-1.5 mb-3">
                {post.data.tags.slice(0, 2).map((tag) => (
                  <span class="text-[11px] font-semibold tracking-wide uppercase text-k9-orange bg-k9-orange/10 px-2 py-0.5 rounded-full">{tag}</span>
                ))}
              </div>
              <h2 class="text-lg font-bold text-neutral-900 group-hover:text-k9-orange transition-colors leading-snug">{post.data.title}</h2>
              <p class="text-sm text-neutral-500 mt-2 leading-relaxed line-clamp-3">{post.data.description}</p>
              <div class="mt-4 flex items-center justify-between">
                <span class="text-xs text-neutral-400">{dateStr}</span>
                <span class="text-xs font-semibold text-k9-orange group-hover:underline">Read more &rarr;</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <Footer />
</Layout>
