---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';
import Awards from '../components/Awards.astro';
import '../styles/global.css';
---

<Layout title="In-Home Dog Training Toronto | Private Trainer Comes to You | K9 Academy" description="Private in-home dog training in Toronto. Our senior trainers come to your house to fix reactivity, aggression, separation anxiety, and doorbell reactivity where it actually happens. $525+/session. 15+ years, 10,000+ dogs.">
  <Navbar />

  <!-- HERO. Above the fold -->
  <section class="relative pt-28 sm:pt-36 pb-16 sm:pb-24 bg-neutral-950 overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_30%,rgba(232,97,26,0.06),transparent_60%)] pointer-events-none"></div>

    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <!-- Google rating pill -->
      <div class="inline-flex items-center gap-2.5 bg-white/5 backdrop-blur-sm rounded-full px-4 py-2 border border-white/10 mb-6">
        <svg class="w-5 h-5" viewBox="0 0 24 24">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" />
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
        </svg>
        <div class="flex items-center gap-0.5">
          {[1,2,3,4,5].map(() => (
            <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <span class="text-sm font-semibold text-white">4.9/5</span>
        <span class="w-px h-4 bg-white/20"></span>
        <span class="text-sm text-neutral-400">250+ Reviews</span>
      </div>

      <!-- Headline: End Result + Time + Emotional Payoff -->
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white leading-tight mb-5">
        Your dog trained in your home<br/>
        <span class="bg-gradient-to-r from-k9-orange to-amber-400 bg-clip-text text-transparent">by the people who built K9 Academy</span>
      </h1>

      <!-- Sub-headline: Pain + Differentiator -->
      <p class="text-lg text-neutral-400 max-w-xl mx-auto leading-relaxed mb-8">
        Most training falls apart the second your dog gets home. We skip that step entirely. One-on-one sessions in your environment with Anesh or a senior trainer. Trusted by professionals, executives, and public figures across the GTA who need real results and complete discretion.
      </p>

      <!-- CTA -->
      <a href="#apply" class="inline-flex items-center px-8 py-4 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30 hover:shadow-xl hover:-translate-y-0.5">
        Apply for In-Home Training
        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>

      <!-- FUD reducers -->
      <div class="mt-6 flex flex-wrap justify-center gap-x-5 gap-y-2">
        {['Same-day response from Anesh', 'No obligation', 'Pay per session'].map((item) => (
          <div class="flex items-center gap-1.5 text-sm text-neutral-500">
            <svg class="w-4 h-4 text-k9-orange flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
            <span>{item}</span>
          </div>
        ))}
      </div>

      <!-- Badge -->
      <div class="mt-10 inline-flex items-center gap-2 px-4 py-2 bg-white/5 border border-white/10 rounded-full">
        <span class="w-2 h-2 rounded-full bg-k9-orange"></span>
        <span class="text-neutral-400 font-semibold text-[10px] uppercase tracking-[0.2em]">By Application Only. Limited Availability</span>
      </div>
    </div>
  </section>

  <Awards />

  <!-- PAS. Pain, Agitate, Solve -->
  <section class="py-16 sm:py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-extrabold text-neutral-900 mb-4 text-center">
        Your dog behaves at the trainer's facility.<br/>Then you get home and it all falls apart.
      </h2>
      <p class="text-neutral-500 text-center max-w-xl mx-auto mb-10 leading-relaxed">
        You've spent thousands on group classes and private sessions. Your dog sits perfectly at the training centre. But the second the doorbell rings, a guest walks in, or you try to leave the house, it's like the training never happened.
      </p>
      <div class="rounded-2xl bg-neutral-50 border border-neutral-200 p-8 text-center">
        <p class="text-k9-orange font-semibold text-sm uppercase tracking-wide mb-3">Here's what's different</p>
        <p class="text-neutral-900 font-bold text-lg mb-3">We train your dog where the problems actually happen.</p>
        <p class="text-neutral-500 text-sm leading-relaxed max-w-lg mx-auto">
          Doorbell reactivity? We're at your front door. Separation anxiety? We're in your living room. Aggression with guests? We bring the triggers to you. Your dog learns in the environment where it needs to perform, not a controlled classroom they'll never see again.
        </p>
      </div>

      <!-- Mid-page CTA -->
      <div class="mt-8 text-center">
        <a href="#apply" class="inline-flex items-center px-7 py-3.5 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30">
          Apply for In-Home Training
        </a>
        <p class="mt-3 text-sm text-neutral-400">Or call <a href="tel:4377785273" class="text-k9-orange hover:underline font-semibold">437-778-5273</a> to speak with Anesh directly</p>
      </div>
    </div>
  </section>

  <!-- VALUE PROPS -->
  <section class="py-16 sm:py-20 bg-neutral-50 border-y border-neutral-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid sm:grid-cols-2 gap-5">
        {[
          {
            title: 'Train with the people who built K9 Academy, not a junior hire',
            desc: 'Anesh or one of our senior trainers. 15+ years, 10,000+ dogs. The same people behind every program, every result, every 5-star review.',
          },
          {
            title: 'Results in your environment, not a training room you\'ll never visit again',
            desc: 'Most training fails at home because it was never trained at home. We fix that by working where the problems actually happen.',
          },
          {
            title: 'Completely private. Your session, your schedule, your terms',
            desc: 'No other dogs. No other clients. No driving across the city. We come to you, when it works for you.',
          },
          {
            title: 'Complete discretion for high-profile clients',
            desc: 'We train dogs for professionals, executives, and public figures who need results without the spotlight. No social media posts. No name drops. Just results.',
          },
        ].map((item) => (
          <div class="flex gap-4 p-5 rounded-2xl bg-white border border-neutral-100">
            <svg class="w-5 h-5 text-k9-orange mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
            <div>
              <h3 class="text-sm font-bold text-neutral-900 mb-1">{item.title}</h3>
              <p class="text-neutral-500 text-sm leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="py-16 sm:py-20 bg-brand-dark">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">How It Works</p>
        <h2 class="text-2xl sm:text-3xl font-extrabold text-white">Four steps to a transformed dog</h2>
      </div>
      <div class="grid sm:grid-cols-4 gap-6">
        {[
          { num: '01', title: 'Apply', desc: 'Fill out the form below. Tell us about your dog, your situation, and your goals.' },
          { num: '02', title: 'We call you', desc: 'Anesh reviews every application personally and calls you to discuss your dog\'s specific needs.' },
          { num: '03', title: 'First session at your home', desc: 'We come to you. Assessment, training plan, and real work starts on day one. Results from session one.' },
          { num: '04', title: 'Ongoing support', desc: 'Pay per session. No contracts. We keep working until you and your dog are where you want to be.' },
        ].map((step) => (
          <div class="text-center sm:text-left">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-k9-orange text-white text-sm font-bold mb-4">
              {step.num}
            </div>
            <h3 class="text-lg font-bold text-white mb-2">{step.title}</h3>
            <p class="text-neutral-400 text-sm leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="#apply" class="inline-flex items-center px-7 py-3.5 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30">
          Start Your Application
        </a>
      </div>
    </div>
  </section>

  <!-- SOCIAL PROOF — Multiple testimonials -->
  <section class="py-16 sm:py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Client Results</p>
        <h2 class="text-2xl sm:text-3xl font-extrabold text-neutral-900">Real stories from in-home clients</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {[
          {
            quote: 'We had Anesh come to our house because our dog was aggressive with anyone who walked through the front door. Two sessions. Two. The dog that used to lunge at our guests now sits and waits for them to come in. My wife cried.',
            name: 'In-home client',
            detail: 'Rosedale · German Shepherd, 4 years',
            issue: 'Door aggression',
          },
          {
            quote: 'Our dog had severe separation anxiety. Couldn\'t leave the house without him destroying something. Anesh came to our home, worked with him in the exact rooms where the anxiety happened, and within three sessions we could leave for hours. No destruction. No barking. It\'s a different dog.',
            name: 'In-home client',
            detail: 'Forest Hill · Labrador, 2 years',
            issue: 'Separation anxiety',
          },
          {
            quote: 'We needed someone discreet and professional. Anesh trained our dog in our home, on our schedule, and never once asked to post about it online. The results speak for themselves. Our dog is calm, obedient, and a completely different animal than the one we started with.',
            name: 'In-home client',
            detail: 'The Bridle Path · Doberman, 3 years',
            issue: 'Obedience + discretion',
          },
        ].map((t) => (
          <div class="bg-neutral-50 rounded-2xl p-6 border border-neutral-200 flex flex-col">
            <div class="flex items-center gap-0.5 mb-3">
              {[1,2,3,4,5].map(() => (
                <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <span class="inline-flex items-center self-start px-2 py-1 rounded-full bg-k9-orange/10 text-k9-orange text-[10px] font-bold uppercase tracking-wide mb-3">{t.issue}</span>
            <blockquote class="text-sm font-semibold text-neutral-900 leading-relaxed flex-grow mb-4">"{t.quote}"</blockquote>
            <p class="text-xs text-neutral-400 pt-3 border-t border-neutral-100">{t.name} · {t.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- RESULTS VIDEOS -->
  <section class="py-16 sm:py-20 bg-neutral-950">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Real Results</p>
        <h2 class="text-2xl sm:text-3xl font-extrabold text-white">See what our training looks like</h2>
        <p class="mt-3 text-neutral-400 max-w-xl mx-auto">The same trainers. The same methods. These results happen in your home too.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <div class="rounded-2xl overflow-hidden border border-white/10 shadow-lg">
            <YouTubeEmbed videoId="76P1n4JgNRQ" title="K9 Academy Training Overview" />
          </div>
          <p class="text-neutral-500 text-xs mt-2 text-center">Full training program overview</p>
        </div>
        <div>
          <div class="rounded-2xl overflow-hidden border border-white/10 shadow-lg">
            <YouTubeEmbed videoId="gfnMuWAA-LM" title="Doberman Board & Train Transformation" />
          </div>
          <p class="text-neutral-500 text-xs mt-2 text-center">Doberman transformation</p>
        </div>
        <div>
          <div class="rounded-2xl overflow-hidden border border-white/10 shadow-lg">
            <YouTubeEmbed videoId="3B-EavE1l_U" title="Malinois Board & Train Transformation" />
          </div>
          <p class="text-neutral-500 text-xs mt-2 text-center">Malinois transformation</p>
        </div>
        <div>
          <div class="rounded-2xl overflow-hidden border border-white/10 shadow-lg">
            <YouTubeEmbed videoId="YkufSLdxWSw" title="Golden Retriever Board & Train Transformation" />
          </div>
          <p class="text-neutral-500 text-xs mt-2 text-center">Golden Retriever transformation</p>
        </div>
      </div>
      <div class="text-center mt-8">
        <a href="#apply" class="inline-flex items-center px-7 py-3.5 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30">
          Apply for In-Home Training
        </a>
        <p class="mt-3 text-sm text-neutral-500">Or call <a href="tel:4377785273" class="text-k9-orange hover:underline font-semibold">437-778-5273</a></p>
      </div>
    </div>
  </section>

  <!-- WHY THE INVESTMENT -->
  <section class="py-16 sm:py-20 bg-neutral-900">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Why In-Home</p>
        <h2 class="text-2xl sm:text-3xl font-extrabold text-white mb-4">You're not paying for a session. You're paying for who shows up.</h2>
        <p class="text-neutral-400 leading-relaxed max-w-2xl mx-auto">
          K9 Academy is trusted by celebrities, professional athletes, executives, and public figures across the GTA. Our in-home program exists for clients who need the best trainers in the industry to come to them. We only take a handful of in-home clients at a time because our senior trainers' schedules are limited. When we come to your home, you're getting the same people who built one of Canada's top training programs, working one-on-one with your dog in the environment that matters most.
        </p>
      </div>

      <div class="grid sm:grid-cols-3 gap-4 mb-12">
        {[
          { stat: '15+', label: 'Years of experience' },
          { stat: '10,000+', label: 'Dogs trained' },
          { stat: 'Limited', label: 'In-home spots per month' },
        ].map((item) => (
          <div class="text-center p-5 bg-white/5 border border-white/10 rounded-xl">
            <p class="text-2xl font-extrabold text-k9-orange">{item.stat}</p>
            <p class="text-neutral-400 text-xs mt-1">{item.label}</p>
          </div>
        ))}
      </div>

      <div class="max-w-md mx-auto">
        <div class="rounded-2xl p-8 bg-white text-center shadow-2xl">
          <p class="text-k9-orange font-semibold text-xs uppercase tracking-widest mb-4">Investment</p>
          <p class="text-5xl font-extrabold text-neutral-900 mb-1">$525+</p>
          <p class="text-neutral-400 text-sm mb-6">per session · 60 minutes · in your home</p>
          <ul class="space-y-3 text-sm text-neutral-600 text-left mb-6">
            {[
              'One-on-one with Anesh or a senior trainer',
              'Training in your actual environment',
              'Custom plan built around your dog\'s specific issues',
              'E-collar and all tools included',
              'No commitment. Pay per session',
              'Results in the place that matters most',
            ].map((item) => (
              <li class="flex items-start gap-2.5">
                <svg class="w-4 h-4 text-k9-orange mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                {item}
              </li>
            ))}
          </ul>
          <a href="#apply" class="inline-flex items-center justify-center w-full py-4 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/20">
            Apply Now
          </a>
          <p class="text-neutral-400 text-xs mt-3">A travel fee may apply for locations outside the Toronto core.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- AREAS SERVED — SEO -->
  <section class="py-12 sm:py-16 bg-neutral-50 border-y border-neutral-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-xl font-extrabold text-neutral-900 mb-2">In-home dog training across Toronto's premier neighbourhoods</h2>
      <p class="text-neutral-500 text-sm mb-6">We come to you. Serving Rosedale, Forest Hill, Yorkville, The Bridle Path, Lawrence Park, Moore Park, Summerhill, Leaside, The Annex, Casa Loma, Hoggs Hollow, and surrounding areas.</p>
      <div class="flex flex-wrap justify-center gap-2">
        {['Rosedale', 'Forest Hill', 'Yorkville', 'The Bridle Path', 'Lawrence Park', 'Moore Park', 'Summerhill', 'Leaside', 'The Annex', 'Casa Loma', 'Hoggs Hollow', 'Davisville', 'Midtown', 'North Toronto', 'Don Mills'].map((area) => (
          <span class="px-3 py-1.5 bg-white border border-neutral-200 rounded-full text-xs text-neutral-600">{area}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- WHO THIS IS FOR -->
  <section class="py-16 sm:py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-extrabold text-neutral-900 mb-8 text-center">This isn't for everyone.</h2>
      <div class="grid sm:grid-cols-2 gap-4">
        <div class="rounded-2xl p-6 bg-emerald-50 border border-emerald-100">
          <p class="text-emerald-700 font-bold text-sm mb-3">This is for you if:</p>
          <ul class="space-y-2">
            {[
              'You want the best, not the most convenient',
              'Your schedule doesn\'t fit group class times',
              'Your dog\'s issues happen at home, not a facility',
              'Privacy and discretion matter to you',
              'You\'ve tried other trainers and need someone who delivers',
            ].map((item) => (
              <li class="flex items-start gap-2 text-sm text-emerald-800">
                <svg class="w-4 h-4 text-emerald-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="rounded-2xl p-6 bg-red-50 border border-red-100">
          <p class="text-red-700 font-bold text-sm mb-3">This is not for you if:</p>
          <ul class="space-y-2">
            {[
              'You\'re shopping for the cheapest option',
              'You want a quick fix without putting in the work',
              'You\'re not willing to follow through between sessions',
              'You expect results without consistency',
              'You\'re looking for a dog walker, not a trainer',
            ].map((item) => (
              <li class="flex items-start gap-2 text-sm text-red-800">
                <svg class="w-4 h-4 text-red-400 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
      <div class="mt-8 text-center">
        <a href="#apply" class="inline-flex items-center px-7 py-3.5 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30">
          Apply Now
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 sm:py-20 bg-neutral-50 border-t border-neutral-100">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Common Questions</p>
        <h2 class="text-2xl font-extrabold text-neutral-900">Before you apply</h2>
      </div>
      <div class="space-y-4">
        {[
          {
            q: 'Why is in-home training more expensive than group classes?',
            a: 'You\'re getting a senior trainer with 15+ years of experience, one-on-one, in your home, on your schedule. Our in-home spots are extremely limited because the same people who built K9 Academy are the ones showing up at your door. You\'re not paying more for convenience. You\'re paying for the best trainers in the industry giving your dog their undivided attention in the environment where it matters most.',
          },
          {
            q: 'How many sessions will my dog need?',
            a: 'It depends on the issues. Some clients see dramatic results in 2-3 sessions. More complex behaviour problems like aggression or severe separation anxiety may take 6-8 sessions. We\'ll give you an honest estimate after the first session. There are no packages and no contracts. You pay per session and stop when you\'re satisfied.',
          },
          {
            q: 'What if my dog is aggressive?',
            a: 'Aggression is our specialty. We handle dogs that other trainers have refused. Anesh has worked with severe aggression cases for over 15 years. Your home is actually the best place to address it because we can work with the real triggers in the real environment.',
          },
          {
            q: 'Who will be training my dog?',
            a: 'Anesh personally reviews every in-home application. Depending on your dog\'s needs and location, the sessions will be conducted by Anesh or one of our most senior trainers. We never send junior trainers to in-home clients.',
          },
          {
            q: 'Do you keep our information private?',
            a: 'Completely. We work with high-profile clients across the GTA who require discretion. We never post about in-home clients on social media, never share names, and never discuss your dog or your home with anyone outside our team.',
          },
          {
            q: 'What tools do you use?',
            a: 'We use whatever tools are needed to get results. This may include an e-collar, prong collar, slip lead, muzzle, or crate. All tools are included in the session price. We\'ll explain everything before we use it.',
          },
          {
            q: 'What areas do you serve?',
            a: 'We serve Toronto and surrounding areas including Rosedale, Forest Hill, Yorkville, The Bridle Path, Lawrence Park, Moore Park, Leaside, and more. A travel fee may apply for locations outside the Toronto core.',
          },
        ].map((faq) => (
          <details class="group rounded-2xl border border-neutral-200/60 bg-white hover:border-neutral-300 transition-all">
            <summary class="flex items-center justify-between cursor-pointer p-5 sm:p-6 text-left">
              <span class="font-semibold text-neutral-900 text-sm sm:text-base pr-4">{faq.q}</span>
              <svg class="w-5 h-5 text-neutral-400 flex-shrink-0 group-open:rotate-45 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
              </svg>
            </summary>
            <div class="px-5 sm:px-6 pb-5 sm:pb-6 -mt-1">
              <p class="text-neutral-600 text-sm leading-relaxed">{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- APPLICATION FORM -->
  <section id="apply" class="py-16 sm:py-20 bg-neutral-50 border-t border-neutral-100">
    <div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8">
        <h2 class="text-2xl font-extrabold text-neutral-900 mb-2">Apply for In-Home Training</h2>
        <p class="text-neutral-500 text-sm">Spots are limited. Tell us about your dog and we'll confirm availability within 24 hours.</p>
      </div>

      <div class="bg-white rounded-2xl p-6 sm:p-8 shadow-md border border-neutral-200">
        <form id="inhome-form" class="space-y-4">
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="ih-name" class="block text-sm font-medium text-neutral-700 mb-1">Your Name</label>
              <input type="text" id="ih-name" name="name" required
                class="w-full px-4 py-3 border border-neutral-200 rounded-xl text-neutral-900 placeholder-neutral-300 focus:outline-none focus:ring-2 focus:ring-k9-orange/30 focus:border-k9-orange transition text-sm"
                placeholder="First & last name" />
            </div>
            <div>
              <label for="ih-phone" class="block text-sm font-medium text-neutral-700 mb-1">Phone</label>
              <input type="tel" id="ih-phone" name="phone" required
                class="w-full px-4 py-3 border border-neutral-200 rounded-xl text-neutral-900 placeholder-neutral-300 focus:outline-none focus:ring-2 focus:ring-k9-orange/30 focus:border-k9-orange transition text-sm"
                placeholder="(416) 555-1234" />
            </div>
          </div>

          <div>
            <label for="ih-email" class="block text-sm font-medium text-neutral-700 mb-1">Email</label>
            <input type="email" id="ih-email" name="email" required
              class="w-full px-4 py-3 border border-neutral-200 rounded-xl text-neutral-900 placeholder-neutral-300 focus:outline-none focus:ring-2 focus:ring-k9-orange/30 focus:border-k9-orange transition text-sm"
              placeholder="you@email.com" />
          </div>

          <div>
            <label for="ih-address" class="block text-sm font-medium text-neutral-700 mb-1">Your Neighbourhood</label>
            <input type="text" id="ih-address" name="address"
              class="w-full px-4 py-3 border border-neutral-200 rounded-xl text-neutral-900 placeholder-neutral-300 focus:outline-none focus:ring-2 focus:ring-k9-orange/30 focus:border-k9-orange transition text-sm"
              placeholder="e.g. Forest Hill, Rosedale, Yorkville, Lawrence Park" />
          </div>

          <div>
            <label for="ih-dog" class="block text-sm font-medium text-neutral-700 mb-1">What are you dealing with?</label>
            <textarea id="ih-dog" name="dog_info" rows="3"
              class="w-full px-4 py-3 border border-neutral-200 rounded-xl text-neutral-900 placeholder-neutral-300 focus:outline-none focus:ring-2 focus:ring-k9-orange/30 focus:border-k9-orange transition resize-none text-sm"
              placeholder="Dog's breed, age, and the specific issues. reactivity, aggression, separation anxiety, recall, etc."></textarea>
          </div>

          <button type="submit" id="ih-submit"
            class="w-full py-4 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/20 hover:shadow-xl disabled:opacity-50 disabled:cursor-not-allowed">
            Submit Application
          </button>
          <p class="text-center text-neutral-400 text-xs">We respond to every application personally. Usually within hours.</p>
        </form>

        <div id="ih-success" class="hidden text-center py-8">
          <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-k9-orange/10 flex items-center justify-center">
            <svg class="w-8 h-8 text-k9-orange" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-neutral-900 mb-2">Application received.</h3>
          <p class="text-neutral-500">We'll review your application and be in touch within 24 hours.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sticky Mobile CTA -->
  <div id="sticky-cta" class="fixed bottom-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-t border-neutral-200 shadow-[0_-4px_20px_rgba(0,0,0,0.1)] translate-y-full transition-transform duration-300 lg:hidden">
    <div class="max-w-lg mx-auto px-4 py-3 flex items-center justify-between gap-3">
      <div class="min-w-0">
        <p class="font-bold text-neutral-900 text-sm truncate">In-Home Training. $525+</p>
        <a href="tel:4377785273" class="text-xs text-neutral-500 hover:text-k9-orange transition-colors">437-778-5273</a>
      </div>
      <a href="#apply" class="inline-flex items-center px-5 py-2.5 bg-k9-orange text-white text-sm font-bold rounded-lg hover:bg-k9-orange-dark transition-all shadow-sm whitespace-nowrap flex-shrink-0">
        Apply Now
      </a>
    </div>
  </div>

  <Footer />
</Layout>

<script>
  const form = document.getElementById('inhome-form') as HTMLFormElement;
  const submitBtn = document.getElementById('ih-submit') as HTMLButtonElement;
  const successMsg = document.getElementById('ih-success') as HTMLDivElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    try {
      const res = await fetch('/api/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: data.name,
          email: data.email,
          phone: data.phone,
          dog_info: data.dog_info,
          service: 'in_home_private',
          message: `IN-HOME APPLICATION\nNeighbourhood: ${data.address || '—'}\nIssues: ${data.dog_info || '—'}`,
        }),
      });

      // Klaviyo tracking
      try {
        (window as any)._learnq = (window as any)._learnq || [];
        (window as any)._learnq.push(['identify', {
          '$email': data.email,
          '$first_name': (data.name as string)?.split(' ')[0] || '',
          '$last_name': (data.name as string)?.split(' ').slice(1).join(' ') || '',
          '$phone_number': data.phone,
          'Dog Info': data.dog_info || '',
          'Neighbourhood': data.address || '',
          'Service Interest': 'In-Home Training',
          'Source': 'In-Home Training',
        }]);
        (window as any)._learnq.push(['track', 'In-Home Inquiry', {
          'Name': data.name,
          'Email': data.email,
          'Phone': data.phone,
          'Dog Info': data.dog_info || '',
          'Neighbourhood': data.address || '',
          'Service': 'In-Home Training',
        }]);
      } catch {}

      if (res.ok) {
        form.classList.add('hidden');
        successMsg.classList.remove('hidden');

        if (typeof fbq !== 'undefined') {
          (window as any).fbq('track', 'Lead', { content_name: 'In-Home Training' });
        }
        if (typeof gtag !== 'undefined') {
          (window as any).gtag('event', 'generate_lead', { event_category: 'form', event_label: 'in_home' });
        }
      } else {
        throw new Error('Failed');
      }
    } catch {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit Application';
      alert('Something went wrong. Please call us at 437-778-5273.');
    }
  });

  // Sticky CTA
  const stickyCta = document.getElementById('sticky-cta');
  const heroCta = document.querySelector('section a[href="#apply"]');
  if (stickyCta && heroCta) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          stickyCta.classList.add('translate-y-full');
        } else {
          stickyCta.classList.remove('translate-y-full');
        }
      },
      { threshold: 0 }
    );
    observer.observe(heroCta);
  }
</script>
