---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Awards from '../components/Awards.astro';
import Testimonials from '../components/Testimonials.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Layout title="K9 Academy Training — Toronto's Dog Training Specialists">
  <Navbar />

  <!-- HERO -->
  <section class="relative pt-28 sm:pt-36 pb-14 sm:pb-20 overflow-hidden bg-brand-dark">
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-center mb-8">
        <div class="inline-flex items-center gap-2.5 bg-white/5 backdrop-blur-sm rounded-full px-4 py-2 border border-white/10">
          <div class="flex items-center gap-0.5">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <span class="text-sm font-semibold text-white">4.9/5</span>
          <span class="w-px h-4 bg-white/20"></span>
          <span class="text-sm text-neutral-400">250+ Google Reviews</span>
        </div>
      </div>

      <div class="text-center max-w-4xl mx-auto">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-white leading-[1.08]">
          A dog you're proud of —
          <br />
          <span class="bg-gradient-to-r from-k9-orange to-amber-400 bg-clip-text text-transparent">in as little as 4 weeks</span>
        </h1>

        <p class="mt-6 text-lg sm:text-xl text-neutral-400 max-w-2xl mx-auto leading-relaxed">
          K9 Academy has trained over 10,000 dogs in the last 15 years. Board & Train, Private Lessons, Group Classes — we have the right program for every dog and every owner.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="#programs" class="inline-flex items-center px-8 py-4 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30 hover:shadow-xl hover:-translate-y-0.5">
            Find the Right Program
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3" />
            </svg>
          </a>
          <a href="tel:4377785273" class="inline-flex items-center gap-2 text-neutral-400 font-medium hover:text-white transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            Or call 437-778-5273
          </a>
        </div>

        <div class="mt-8 flex flex-wrap justify-center gap-x-6 gap-y-2">
          {['We typically respond within hours', 'Serious inquiries only', '10,000+ dogs trained', 'Results guaranteed'].map((item) => (
            <div class="flex items-center gap-1.5 text-sm text-neutral-500">
              <svg class="w-4 h-4 text-k9-orange flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              <span>{item}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Video -->
      <div class="mt-14 sm:mt-18 max-w-5xl mx-auto">
        <div class="relative rounded-2xl overflow-hidden border border-white/10 shadow-2xl shadow-black/40 aspect-video">
          <iframe
            src="https://www.youtube.com/embed/76P1n4JgNRQ?rel=0"
            title="K9 Academy Training"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            class="absolute inset-0 w-full h-full"
            loading="lazy"
          ></iframe>
        </div>
      </div>

      <!-- Stats -->
      <div class="mt-14 sm:mt-18 grid grid-cols-2 sm:grid-cols-4 gap-8 max-w-3xl mx-auto">
        {[
          { stat: '10,000+', label: 'Dogs Trained' },
          { stat: '15+', label: 'Years Experience' },
          { stat: '4.9', label: 'Google Rating' },
          { stat: '100+', label: 'Publications' },
        ].map(({ stat, label }) => (
          <div class="text-center">
            <div class="text-3xl sm:text-4xl font-extrabold text-white">{stat}</div>
            <div class="text-sm text-neutral-500 mt-1 font-medium">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Awards />

  <!-- FIND YOUR PROGRAM -->
  <section id="programs" class="py-16 sm:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Our Programs</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900">
          Find the right program for your dog
        </h2>
        <p class="mt-4 text-neutral-500 max-w-2xl mx-auto">
          Every dog is different. We assess individually and recommend the program that fits your dog's breed, temperament, and specific needs.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {[
          {
            title: 'Board & Train',
            tagline: 'A transformed dog — without doing it yourself',
            desc: '2–8 week immersive programs. Your dog lives with us, trains daily, and comes home reliable. For reactivity, aggression, anxiety, and obedience.',
            price: 'From $2,995',
            link: '/board-and-train',
            cta: 'Learn More',
            highlight: true,
          },
          {
            title: 'Private Lessons',
            tagline: 'One-on-one training for targeted results',
            desc: '6 or 8 session packages. Advanced obedience or behaviour modification with e-collar training and off-leash hikes included.',
            price: 'From $1,350',
            link: '/private-lessons',
            cta: 'Learn More',
            highlight: false,
          },
          {
            title: 'Group Classes',
            tagline: 'Three levels of obedience — basic to elite',
            desc: 'Level One, Two, and Three group obedience at our Leaside location. Small groups, 6–8 weeks per level. E-collar and off-leash work in Level Two+.',
            price: 'From $595',
            link: '/group-classes',
            cta: 'Learn More',
            highlight: false,
          },
          {
            title: 'Puppy Program',
            tagline: 'Start right before bad habits form',
            desc: 'For puppies under 5.5 months. 4 one-hour sessions covering commands, socialization, bite inhibition, and house manners. Handbook + clicker included.',
            price: 'From $450',
            link: '/puppy-classes',
            cta: 'Learn More',
            highlight: false,
          },
        ].map((s) => (
          <a href={s.link} class={`group rounded-2xl p-6 border transition-all hover:shadow-lg hover:-translate-y-0.5 flex flex-col ${s.highlight ? 'border-k9-orange/30 bg-k9-orange-light/30 ring-1 ring-k9-orange/10' : 'border-neutral-200/60 bg-white hover:border-neutral-300'}`}>
            <h3 class="text-xl font-bold text-neutral-900 mb-1">{s.title}</h3>
            <p class="text-k9-orange font-medium text-xs mb-3">{s.tagline}</p>
            <p class="text-neutral-500 text-sm leading-relaxed flex-grow mb-5">{s.desc}</p>
            <div class="flex items-center justify-between pt-4 border-t border-neutral-100">
              <span class="text-lg font-extrabold text-neutral-900">{s.price}</span>
              <span class="inline-flex items-center text-sm font-semibold text-k9-orange group-hover:translate-x-1 transition-transform">
                {s.cta}
                <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- NOT SURE WHICH PROGRAM -->
  <section class="py-12 sm:py-16 bg-neutral-50 border-y border-neutral-100">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl font-extrabold text-neutral-900 mb-4">
        Not sure which program is right?
      </h2>
      <p class="text-neutral-500 mb-6">
        Tell us about your dog and what you are dealing with. We will recommend the right program — no guesswork.
      </p>
      <a href="#contact" class="inline-flex items-center px-7 py-3.5 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30">
        Tell Us About Your Dog
      </a>
    </div>
  </section>

  <!-- VIDEO CAROUSEL -->
  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">See It in Action</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900">
          Watch what K9 Academy training looks like
        </h2>
      </div>

      <div class="space-y-3" id="main-video-carousel">
        <div class="rounded-2xl overflow-hidden border border-neutral-200/60 shadow-md aspect-video">
          <iframe
            src="https://www.youtube.com/embed/gfnMuWAA-LM?rel=0"
            title="K9 Academy Training"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            class="w-full h-full"
            loading="lazy"
            id="main-carousel-player"
          ></iframe>
        </div>

        <div class="flex gap-2">
          <button data-video="gfnMuWAA-LM" class="main-video-thumb flex-1 rounded-lg overflow-hidden border-2 border-k9-orange opacity-100 transition-all">
            <img src="https://img.youtube.com/vi/gfnMuWAA-LM/mqdefault.jpg" alt="Video 1" class="w-full aspect-video object-cover" loading="lazy" />
          </button>
          <button data-video="3B-EavE1l_U" class="main-video-thumb flex-1 rounded-lg overflow-hidden border-2 border-transparent opacity-60 hover:opacity-100 transition-all">
            <img src="https://img.youtube.com/vi/3B-EavE1l_U/mqdefault.jpg" alt="Video 2" class="w-full aspect-video object-cover" loading="lazy" />
          </button>
          <button data-video="76P1n4JgNRQ" class="main-video-thumb flex-1 rounded-lg overflow-hidden border-2 border-transparent opacity-60 hover:opacity-100 transition-all">
            <img src="https://img.youtube.com/vi/76P1n4JgNRQ/mqdefault.jpg" alt="Video 3" class="w-full aspect-video object-cover" loading="lazy" />
          </button>
        </div>
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll('.main-video-thumb').forEach((btn) => {
      btn.addEventListener('click', () => {
        const videoId = (btn as HTMLElement).dataset.video;
        const player = document.getElementById('main-carousel-player') as HTMLIFrameElement;
        player.src = `https://www.youtube.com/embed/${videoId}?rel=0&autoplay=1`;

        document.querySelectorAll('.main-video-thumb').forEach((b) => {
          b.classList.remove('border-k9-orange');
          b.classList.add('border-transparent', 'opacity-60');
        });
        btn.classList.add('border-k9-orange');
        btn.classList.remove('border-transparent', 'opacity-60');
        btn.classList.add('opacity-100');
      });
    });
  </script>

  <Testimonials />

  <!-- WHY K9 -->
  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Why K9 Academy</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900">
          What makes us different
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { num: '01', title: '15+ years, 10,000+ dogs', desc: 'This is not a side hustle. K9 Academy has been training at the highest level for over 15 years across the GTA.' },
          { num: '02', title: 'The dogs others gave up on', desc: 'We specialize in the cases other trainers refuse. Bite histories, severe reactivity, working breeds — that is our expertise.' },
          { num: '03', title: 'Balanced training that works', desc: 'We use e-collar protocols and balanced methods because the results speak for themselves. Not trendy — effective.' },
          { num: '04', title: 'Two dedicated facilities', desc: 'Leaside for lessons and classes. Stouffville for Board & Train and daycare. Professional environments built for training.' },
          { num: '05', title: 'Results that hold', desc: 'We keep working until your dog performs reliably in real-world situations. If results slip, we are here.' },
          { num: '06', title: 'Award-winning and published', desc: 'Featured in 100+ publications. Readers\' Choice winner. Consumer Choice Award. ThreeBest Rated. Top 10 in Toronto.' },
        ].map((prop) => (
          <div class="rounded-2xl p-6 bg-neutral-50 border border-neutral-200/60 hover:border-neutral-300 transition-all">
            <div class="w-8 h-8 rounded-lg bg-k9-orange/10 flex items-center justify-center mb-4">
              <span class="text-k9-orange font-bold text-sm">{prop.num}</span>
            </div>
            <h3 class="text-base font-bold text-neutral-900 mb-2">{prop.title}</h3>
            <p class="text-neutral-500 text-sm leading-relaxed">{prop.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <ContactForm />
  <Footer />
</Layout>
