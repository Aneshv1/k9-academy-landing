---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
// Awards now integrated directly into hero section
import Testimonials from '../components/Testimonials.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
import QuizForm from '../components/QuizForm.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';
import '../styles/global.css';
---

<Layout title="K9 Academy | Dog Training Toronto | 10,000+ Dogs Trained" description="Toronto's top-rated dog training. private lessons, group classes, and board & train programs. 4.9/5 on Google with 250+ reviews. Leaside location. 437-778-5273.">
  <Navbar />

  <!-- HERO. Split Layout, Dark -->
  <section class="relative pt-20 sm:pt-32 pb-0 overflow-hidden bg-neutral-950">
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">

        <!-- LEFT. Copy -->
        <div class="max-w-xl">
          <!-- Google Review Pill -->
          <div class="inline-flex items-center gap-2.5 bg-white/5 backdrop-blur-sm rounded-full px-4 py-2 border border-white/10 mb-6">
            <svg class="w-5 h-5" viewBox="0 0 24 24">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" />
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
            </svg>
            <div class="flex items-center gap-0.5">
              {[1,2,3,4,5].map(() => (
                <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <span class="text-sm font-semibold text-white">4.9/5</span>
            <span class="w-px h-4 bg-white/20"></span>
            <span class="text-sm text-neutral-400">250+ Reviews</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[3.5rem] font-extrabold tracking-tight text-white leading-[1.1]">
            A calm, confident dog
            <span class="bg-gradient-to-r from-k9-orange to-amber-400 bg-clip-text text-transparent"> in as little as 4 weeks</span>
          </h1>

          <p class="mt-5 text-lg text-neutral-400 leading-relaxed hidden sm:block">
            Reactivity, aggression, anxiety, zero recall. we've seen it all and fixed it all. 15 years, 10,000+ dogs, and proven systems that deliver real-world results other trainers can't.
          </p>

          <!-- CTAs -->
          <div class="mt-8 flex flex-col sm:flex-row items-start gap-3">
            <a href="#contact" class="inline-flex items-center px-7 py-3.5 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30 hover:shadow-xl hover:-translate-y-0.5">
              Get a Free Consultation
              <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
            <a href="tel:4377785273" class="inline-flex items-center gap-2 px-7 py-3.5 text-neutral-400 font-medium hover:text-white transition-colors border border-white/10 rounded-xl hover:border-white/20">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              437-778-5273
            </a>
          </div>

          <!-- Trust Indicators -->
          <div class="mt-6 flex flex-wrap gap-x-5 gap-y-2 hidden sm:flex">
            {['Usually same-day response', 'Free consultation', '10,000+ dogs trained'].map((item) => (
              <div class="flex items-center gap-1.5 text-sm text-neutral-500">
                <svg class="w-4 h-4 text-k9-orange flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                <span>{item}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- RIGHT. Video -->
        <div class="relative">
          <div class="rounded-2xl overflow-hidden border border-white/10 shadow-2xl shadow-black/50">
            <YouTubeEmbed videoId="LC8puPzXFbY" title="K9 Academy Training" />
          </div>
          <!-- Floating Badge -->
          <div class="absolute -bottom-4 -left-4 sm:-bottom-5 sm:-left-5 bg-white rounded-xl px-4 py-3 shadow-xl">
            <p class="text-2xl font-black text-k9-orange">15+</p>
            <p class="text-xs text-neutral-500">Years Experience</p>
          </div>
        </div>
      </div>

      <!-- Stats + Awards. compact trust strip -->
      <div class="mt-12 sm:mt-16 border-t border-white/5 pt-6 pb-8 sm:pb-10">
        <div class="flex flex-wrap items-center justify-center gap-x-6 sm:gap-x-8 gap-y-1 mb-5">
          {[
            { stat: '10,000+', label: 'Dogs' },
            { stat: '15+', label: 'Years' },
            { stat: '4.9★', label: 'Google' },
            { stat: '100+', label: 'Press' },
          ].map(({ stat, label }, i) => (
            <div class="flex items-center gap-1.5">
              <span class="text-lg sm:text-xl font-extrabold text-white">{stat}</span>
              <span class="text-xs text-neutral-500 uppercase tracking-wide">{label}</span>
              {i < 3 && <span class="ml-4 sm:ml-6 w-px h-4 bg-white/10 hidden sm:block"></span>}
            </div>
          ))}
        </div>
        <div class="flex flex-wrap items-center justify-center gap-x-6 sm:gap-x-8 gap-y-3">
          <span class="text-[11px] font-semibold text-neutral-500 uppercase tracking-widest mr-2">Award-winning from multiple publications</span>
          {[
            { src: '/badges/readers-choice.png', alt: "Toronto Star Readers' Choice 2023" },
            { src: '/badges/quality-2025.jpg', alt: '2025 Quality Business Awards' },
            { src: '/badges/consumer-choice.png', alt: 'Consumer Choice Award' },
            { src: '/badges/threebest-rated.png', alt: 'ThreeBest Rated 2025' },
            { src: '/badges/trustanalytica.png', alt: 'Top 10 Toronto. TrustAnalytica' },
            { src: '/badges/canadian-choice-trophy.png', alt: 'Canadian Choice Award' },
          ].map((award) => (
            <img
              src={award.src}
              alt={award.alt}
              class="h-9 sm:h-10 w-auto object-contain grayscale brightness-150 opacity-70 hover:grayscale-0 hover:brightness-100 hover:opacity-100 transition-all duration-300"
              loading="lazy"
            />
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- PAS SECTION. Problem → Proof → Action -->
  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- PROBLEM. 3 hard-hitting pain points -->
      <div class="text-center mb-10">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-4">Sound Familiar?</p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-neutral-900 leading-tight">
          You love your dog.<br/>But you don't trust them.
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-5 mb-14">
        {[
          {
            pain: 'Every walk is a fight',
            detail: 'Lunging, barking, pulling toward every dog, person, or squirrel. You\'ve stopped walking certain routes. You dread leaving the house.',
            iconPath: 'M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z',
          },
          {
            pain: 'Other trainers failed you',
            detail: 'You spent thousands on "positive only" methods, YouTube tips, or trainers who ghosted after 3 sessions. Nothing stuck.',
            iconPath: 'M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636',
          },
          {
            pain: 'It\'s getting worse, not better',
            detail: 'The aggression is escalating. Guests can\'t come over. You\'re scared of what happens next. a bite, a lawsuit, or worse.',
            iconPath: 'M2.25 6L9 12.75l4.286-4.286a11.948 11.948 0 014.306 6.43l.776 2.898m0 0l3.182-5.511m-3.182 5.51l-5.511-3.181',
          },
        ].map((item) => (
          <div class="rounded-2xl bg-neutral-50 border border-neutral-200 p-6 text-center hover:border-red-200 hover:bg-red-50/30 transition-all group">
            <div class="w-12 h-12 rounded-full bg-red-50 border border-red-100 flex items-center justify-center mx-auto mb-4 group-hover:bg-red-100 transition-colors">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d={item.iconPath} />
              </svg>
            </div>
            <h3 class="text-lg font-extrabold text-neutral-900 mb-2">{item.pain}</h3>
            <p class="text-neutral-500 text-sm leading-relaxed">{item.detail}</p>
          </div>
        ))}
      </div>

      <!-- BEFORE → AFTER TRANSFORMATION -->
      <div class="rounded-2xl overflow-hidden border border-neutral-200 mb-14">
        <div class="grid md:grid-cols-2">
          <!-- Before -->
          <div class="bg-neutral-900 p-8 sm:p-10">
            <p class="text-red-400 text-xs font-bold uppercase tracking-widest mb-4">Before K9 Academy</p>
            <ul class="space-y-3">
              {['Can\'t walk past another dog', 'Pulls so hard your shoulder hurts', 'Barks and lunges at strangers', 'Zero recall. won\'t come when called', 'Other trainers said "he\'s too far gone"'].map((item) => (
                <li class="flex items-start gap-2.5 text-neutral-300 text-sm">
                  <svg class="w-4 h-4 text-red-400 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
          <!-- After -->
          <div class="bg-emerald-950 p-8 sm:p-10">
            <p class="text-emerald-400 text-xs font-bold uppercase tracking-widest mb-4">After K9 Academy</p>
            <ul class="space-y-3">
              {['Walks calmly past dogs, people, bikes', 'Loose leash. no more pulling', 'Relaxed around guests and strangers', 'Reliable off-leash recall', 'Other owners ask "how did you do that?"'].map((item) => (
                <li class="flex items-start gap-2.5 text-emerald-100 text-sm">
                  <svg class="w-4 h-4 text-emerald-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      <!-- FEATURED REVIEW. real proof -->
      <div class="rounded-2xl bg-neutral-50 border border-neutral-200 overflow-hidden mb-14 grid md:grid-cols-[1fr_1.5fr]">
        <div class="aspect-square md:aspect-auto">
          <img src="/images/husky.jpg" alt="Husky trained at K9 Academy" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="p-8 sm:p-10 flex flex-col justify-center">
        <div class="flex items-center gap-2 mb-4">
          <svg class="w-6 h-6" viewBox="0 0 24 24">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" />
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
          </svg>
          <div class="flex items-center gap-0.5">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <span class="text-sm text-neutral-400 ml-1">Google Review</span>
        </div>
        <blockquote class="text-lg sm:text-xl font-semibold text-neutral-900 leading-relaxed mb-4">
          "My dog bit someone. I was told to consider euthanasia. The K9 Academy team took the time to understand what was going on. 8 weeks later, my dog is safe, calm, and part of the family again."
        </blockquote>
        <div class="flex items-center justify-between flex-wrap gap-4">
          <div>
            <p class="font-bold text-neutral-900 text-sm">Rachel D.</p>
            <p class="text-xs text-neutral-400">Husky mix, 5 years · Board & Train. 8 weeks</p>
          </div>
          <a href="#contact" class="inline-flex items-center px-6 py-3 bg-k9-orange text-white text-sm font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30 hover:-translate-y-0.5">
            Get the Same Results
            <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="text-center">
        <h3 class="text-2xl sm:text-3xl font-extrabold text-neutral-900 mb-3">
          Your dog isn't a lost cause.
        </h3>
        <p class="text-neutral-500 max-w-xl mx-auto mb-6">
          The dogs other trainers gave up on are our specialty. Tell us what you're dealing with. we'll tell you exactly how we'd fix it.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          <a href="#contact" class="inline-flex items-center px-8 py-4 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30 hover:shadow-xl hover:-translate-y-0.5">
            Get a Free Consultation
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a href="tel:4377785273" class="inline-flex items-center gap-2 px-7 py-4 text-neutral-500 font-medium hover:text-neutral-900 transition-colors border border-neutral-200 rounded-xl hover:border-neutral-300">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            437-778-5273
          </a>
        </div>
      </div>

    </div>
  </section>

  <QuizForm />

  <!-- FIND YOUR PROGRAM -->
  <section id="programs" class="py-16 sm:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Programs That Get Real Results</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900">
          From Reactive to Reliable. Pick the Program That Fits
        </h2>
        <p class="mt-4 text-neutral-500 max-w-2xl mx-auto">
          Every dog is assessed individually. We recommend the program that matches your dog's breed, temperament, and the specific issues you're dealing with.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {[
          {
            title: 'Board & Train',
            tagline: 'A transformed dog. without doing it yourself',
            desc: '2–8 week immersive programs. Your dog lives with us, trains daily, and comes home reliable. For reactivity, aggression, anxiety, and obedience.',
            price: 'From $2,995',
            link: '/board-and-train',
            cta: 'Learn More',
            highlight: true,
            img: '/images/hero-training.jpg',
          },
          {
            title: 'Private Lessons',
            tagline: 'One-on-one training for targeted results',
            desc: '6 or 8 session packages. Advanced obedience or behaviour modification with e-collar training and off-leash hikes included.',
            price: 'From $1,350',
            link: '/private-lessons',
            cta: 'Learn More',
            highlight: false,
            img: '/images/private-training.jpg',
          },
          {
            title: 'Group Classes',
            tagline: 'Three levels of obedience. basic to elite',
            desc: 'Level One, Two, and Three group obedience at our Leaside location. Small groups, 6–8 weeks per level. E-collar and off-leash work in Level Two+.',
            price: 'From $595',
            link: '/group-classes',
            cta: 'Learn More',
            highlight: false,
            img: '/images/group-class.jpg',
          },
          {
            title: 'Puppy Program',
            tagline: 'Start right before bad habits form',
            desc: 'For puppies under 5.5 months. 4 one-hour sessions covering commands, socialization, no-bite training, and house manners. Handbook + clicker included.',
            price: 'From $450',
            link: '/puppy-classes',
            cta: 'Learn More',
            highlight: false,
            img: '/images/dogs-playing.jpg',
          },
        ].map((s) => (
          <a href={s.link} class={`group rounded-2xl overflow-hidden border transition-all hover:shadow-lg hover:-translate-y-0.5 flex flex-col ${s.highlight ? 'border-k9-orange/30 bg-k9-orange-light/30 ring-1 ring-k9-orange/10' : 'border-neutral-200/60 bg-white hover:border-neutral-300'}`}>
            <div class="aspect-[4/3] overflow-hidden">
              <img src={s.img} alt={s.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
            <div class="p-6 flex flex-col flex-grow">
            <h3 class="text-xl font-bold text-neutral-900 mb-1">{s.title}</h3>
            <p class="text-k9-orange font-medium text-xs mb-3">{s.tagline}</p>
            <p class="text-neutral-500 text-sm leading-relaxed flex-grow mb-5">{s.desc}</p>
            <div class="flex items-center justify-between pt-4 border-t border-neutral-100">
              <span class="text-lg font-extrabold text-neutral-900">{s.price}</span>
              <span class="inline-flex items-center text-sm font-semibold text-k9-orange group-hover:translate-x-1 transition-transform">
                {s.cta}
                <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </span>
            </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- NOT SURE WHICH PROGRAM -->
  <section class="py-12 sm:py-16 bg-neutral-50 border-y border-neutral-100">
