---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import ContactForm from '../../components/ContactForm.astro';
import Footer from '../../components/Footer.astro';
import { areas } from '../../data/areas';
import '../../styles/global.css';

export function getStaticPaths() {
  return areas.map((area) => ({
    params: { area: area.slug },
    props: { area },
  }));
}

const { area } = Astro.props;
const otherAreas = areas.filter((a) => area.nearbyAreas.includes(a.slug));
---

<Layout title={area.title} description={area.description}>
  <Navbar />

  <!-- Hero -->
  <section class="pt-28 sm:pt-36 pb-14 sm:pb-20 bg-brand-dark">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <!-- Google pill -->
      <div class="inline-flex items-center gap-2.5 bg-white/5 backdrop-blur-sm rounded-full px-4 py-2 border border-white/10 mb-5">
        <svg class="w-5 h-5" viewBox="0 0 24 24">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" />
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
        </svg>
        <span class="text-sm font-semibold text-white">4.9/5</span>
        <span class="w-px h-4 bg-white/20"></span>
        <span class="text-sm text-neutral-400">250+ Reviews</span>
      </div>

      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-tight">Dog Training in {area.name}</h1>
      <p class="mt-5 text-neutral-400 max-w-2xl mx-auto text-base leading-relaxed">{area.heroText}</p>

      <!-- CTA -->
      <div class="mt-7 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="#contact" class="inline-flex items-center px-7 py-3.5 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30 hover:shadow-xl hover:-translate-y-0.5">
          Get a Free Consultation
          <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
        <a href="tel:4377785273" class="inline-flex items-center gap-2 px-7 py-3.5 text-neutral-400 font-medium hover:text-white transition-colors border border-white/10 rounded-xl hover:border-white/20">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
          437-778-5273
        </a>
      </div>

      <!-- FUD reducers -->
      <div class="mt-5 flex flex-wrap justify-center gap-x-5 gap-y-2">
        {['Same-day response', 'Free consultation', `${area.distance}`].map((item) => (
          <div class="flex items-center gap-1.5 text-sm text-neutral-500">
            <svg class="w-4 h-4 text-k9-orange flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
            <span>{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- About the neighbourhood -->
  <section class="py-14 sm:py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <h2 class="text-2xl font-extrabold text-neutral-900 mb-4">Training in {area.name}</h2>
          <p class="text-neutral-600 leading-relaxed mb-4">{area.neighbourhoodContext}</p>
          <p class="text-neutral-600 leading-relaxed">{area.trainingContext}</p>
        </div>
        <div>
          <h3 class="text-lg font-bold text-neutral-900 mb-3">Local Parks for Training</h3>
          <div class="space-y-2">
            {area.nearbyParks.map((park) => (
              <div class="flex items-center gap-2.5 p-3 rounded-xl bg-neutral-50 border border-neutral-100">
                <svg class="w-5 h-5 text-green-600 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" /></svg>
                <span class="text-sm font-medium text-neutral-700">{park}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Programs -->
  <section class="py-14 sm:py-20 bg-neutral-950">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-k9-orange font-semibold text-xs tracking-widest uppercase mb-3">Programs Available</p>
      <h2 class="text-2xl font-extrabold text-white mb-8">Training Programs for {area.name} Dog Owners</h2>

      <div class="grid sm:grid-cols-2 gap-5">
        <a href="/private-lessons" class="group block rounded-2xl bg-white/5 border border-white/10 p-6 hover:border-k9-orange/30 transition-all">
          <h3 class="text-lg font-bold text-white group-hover:text-k9-orange transition-colors mb-2">Private Training</h3>
          <p class="text-sm text-neutral-400 mb-3">1-on-1 sessions for aggression, reactivity, separation anxiety, and advanced obedience.</p>
          <div class="flex items-center justify-between">
            <span class="text-xs text-neutral-500">6-8 sessions</span>
            <span class="text-sm font-bold text-k9-orange">From $1,350</span>
          </div>
        </a>

        <a href="/group-classes" class="group block rounded-2xl bg-white/5 border border-white/10 p-6 hover:border-k9-orange/30 transition-all">
          <h3 class="text-lg font-bold text-white group-hover:text-k9-orange transition-colors mb-2">Group Classes</h3>
          <p class="text-sm text-neutral-400 mb-3">Level 1, 2 & 3 group obedience. Small groups, real-world distractions, 6-week programs.</p>
          <div class="flex items-center justify-between">
            <span class="text-xs text-neutral-500">6 weeks per level</span>
            <span class="text-sm font-bold text-k9-orange">$595/level</span>
          </div>
        </a>

        <a href="/board-and-train" class="group block rounded-2xl bg-white/5 border border-white/10 p-6 hover:border-k9-orange/30 transition-all">
          <h3 class="text-lg font-bold text-white group-hover:text-k9-orange transition-colors mb-2">Board & Train</h3>
          <p class="text-sm text-neutral-400 mb-3">Your dog lives with us for 2-8 weeks. Daily training, socialization, and real-world proofing.</p>
          <div class="flex items-center justify-between">
            <span class="text-xs text-neutral-500">2-8 weeks</span>
            <span class="text-sm font-bold text-k9-orange">From $2,995</span>
          </div>
        </a>

        <a href="/puppy-classes" class="group block rounded-2xl bg-white/5 border border-white/10 p-6 hover:border-k9-orange/30 transition-all">
          <h3 class="text-lg font-bold text-white group-hover:text-k9-orange transition-colors mb-2">Puppy Classes</h3>
          <p class="text-sm text-neutral-400 mb-3">Socialization, crate training, house training, and basic obedience for puppies.</p>
          <div class="flex items-center justify-between">
            <span class="text-xs text-neutral-500">4 sessions</span>
            <span class="text-sm font-bold text-k9-orange">$595</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- In-Home Training Promo -->
  <section class="py-12 sm:py-16 bg-white border-b border-neutral-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-k9-orange/20 bg-k9-orange/5 p-6 sm:p-8 sm:flex sm:items-center sm:justify-between gap-6">
        <div>
          <p class="text-k9-orange font-semibold text-xs uppercase tracking-wide mb-1">Premium Option</p>
          <h3 class="text-lg font-bold text-neutral-900 mb-1">Want a trainer to come to your {area.name} home?</h3>
          <p class="text-neutral-500 text-sm">Private in-home sessions with our senior trainers. $625/session. Your home, your schedule.</p>
        </div>
        <a href="/in-home" class="inline-flex items-center mt-4 sm:mt-0 px-6 py-3 bg-k9-orange text-white text-sm font-bold rounded-xl hover:bg-k9-orange-dark transition-all whitespace-nowrap shadow-lg shadow-k9-orange/20">
          Learn More
        </a>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="py-12 sm:py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl bg-neutral-50 border border-neutral-200 p-6 sm:p-8">
        <div class="flex items-center gap-2 mb-3">
          <svg class="w-5 h-5" viewBox="0 0 24 24">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" />
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
          </svg>
          <div class="flex items-center gap-0.5">
            {[1,2,3,4,5].map(() => (
              <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
        </div>
        <blockquote class="text-base sm:text-lg font-semibold text-neutral-900 leading-relaxed mb-3">
          "Just got back from a walk. She saw two dogs and didn't react to either one. That's it. That's the email. Thank you."
        </blockquote>
        <p class="text-neutral-500 text-sm">B. W. · Reactivity · Private Lessons</p>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-10 sm:py-14 bg-neutral-50 border-y border-neutral-100">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-2 text-sm">
        <span><strong class="text-xl font-extrabold text-neutral-900">10,000+</strong> <span class="text-neutral-500">dogs trained</span></span>
        <span class="w-px h-6 bg-neutral-200 hidden sm:block"></span>
        <span><strong class="text-xl font-extrabold text-neutral-900">15+</strong> <span class="text-neutral-500">years</span></span>
        <span class="w-px h-6 bg-neutral-200 hidden sm:block"></span>
        <span><strong class="text-xl font-extrabold text-neutral-900">4.9★</strong> <span class="text-neutral-500">Google (250+ reviews)</span></span>
      </div>
    </div>
  </section>

  <!-- Nearby areas -->
  <section class="py-10 sm:py-14 bg-neutral-50 border-t border-neutral-100">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h3 class="text-sm font-bold text-neutral-400 uppercase tracking-wide mb-4">Also Serving Nearby</h3>
      <div class="flex flex-wrap gap-2">
        {areas.filter((a) => a.slug !== area.slug).map((a) => (
          <a href={`/areas/${a.slug}`} class="text-sm px-4 py-2 rounded-full bg-white border border-neutral-200 text-neutral-600 hover:border-k9-orange hover:text-k9-orange transition-colors">
            {a.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <ContactForm />
  <Footer />

  <!-- LocalBusiness + Service schema for this area -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "K9 Academy Dog Training Center",
    "address": { "@type": "PostalAddress", "streetAddress": "16-30 Canvarco Rd", "addressLocality": "Toronto", "addressRegion": "ON", "postalCode": "M4G 1L3", "addressCountry": "CA" },
    "telephone": "437-778-5273",
    "url": "https://k9academytraining.ca",
    "areaServed": { "@type": "Place", "name": `${area.name}, Toronto` },
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "250", "bestRating": "5" },
    "description": area.description,
  })} />
</Layout>
