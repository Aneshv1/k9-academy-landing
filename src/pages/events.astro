---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

// ============================================================
// EDIT EVENTS HERE — add/remove events as needed
// Only events listed below will appear on the page
// Set stripeLink to the Stripe Payment Link URL for each event
// ============================================================
const events = [
  // ── DROP-IN IMPULSE CONTROL ──
  // Uncomment and update date/time/stripeLink when scheduling a session
  // {
  //   type: 'impulse',
  //   name: 'Drop-In Impulse Control Class',
  //   date: '2026-06-14',
  //   time: '10:00 AM',
  //   duration: '1 hour',
  //   location: 'Leaside — 16-30 Canvarco Rd, Toronto',
  //   price: 45,
  //   spots: 12,
  //   requirement: 'Must have completed Level 1 or equivalent',
  //   description: 'Focused session on impulse control — stays, leave it, settling under distraction. Perfect for dogs who need a tune-up.',
  //   stripeLink: 'https://buy.stripe.com/YOUR_LINK_HERE',
  // },

  // ── ADULT DOG SOCIAL ──
  // {
  //   type: 'social',
  //   name: 'Adult Dog Social',
  //   date: '2026-06-15',
  //   time: '2:00 PM',
  //   duration: '1.5 hours',
  //   location: 'Leaside — 16-30 Canvarco Rd, Toronto',
  //   price: 55,
  //   spots: 6,
  //   requirement: 'Must have completed Level 1 or equivalent',
  //   description: 'Structured off-leash social for trained adult dogs. Small group, supervised by our trainers.',
  //   stripeLink: 'https://buy.stripe.com/YOUR_LINK_HERE',
  // },

  // ── PUPPY SOCIAL ──
  // {
  //   type: 'puppy',
  //   name: 'Puppy Social',
  //   date: '2026-06-15',
  //   time: '12:00 PM',
  //   duration: '1 hour',
  //   location: 'Leaside — 16-30 Canvarco Rd, Toronto',
  //   price: 35,
  //   spots: 12,
  //   requirement: 'Puppies 6 months and under only',
  //   description: 'Supervised socialization for puppies. Structured introductions, play, and early confidence building.',
  //   stripeLink: 'https://buy.stripe.com/YOUR_LINK_HERE',
  // },
];

// Event types available (always shown even if no dates scheduled)
const eventTypes = [
  {
    type: 'impulse',
    name: 'Drop-In Impulse Control Class',
    price: 45,
    spots: 12,
    requirement: 'Must have completed Level 1 or equivalent',
    description: 'Focused session on impulse control — stays, leave it, settling under distraction. Perfect for dogs who need a tune-up between classes.',
  },
  {
    type: 'social',
    name: 'Adult Dog Social',
    price: 55,
    spots: 6,
    requirement: 'Must have completed Level 1 or equivalent',
    description: 'Structured off-leash social for trained adult dogs. Small group, supervised by our trainers. Real socialization — not a dog park.',
  },
  {
    type: 'puppy',
    name: 'Puppy Social',
    price: 35,
    spots: 12,
    requirement: 'Puppies 6 months and under only',
    description: 'Supervised socialization for puppies. Structured introductions, play, and early confidence building during the critical window.',
  },
];

const typeConfig: Record<string, { label: string; color: string; icon: string }> = {
  impulse: { label: 'Drop-In Class', color: 'bg-blue-500/10 text-blue-500 border-blue-500/20', icon: '⚡' },
  social: { label: 'Adult Social', color: 'bg-emerald-500/10 text-emerald-500 border-emerald-500/20', icon: '🐕' },
  puppy: { label: 'Puppy Social', color: 'bg-purple-500/10 text-purple-500 border-purple-500/20', icon: '🐶' },
};

function formatDate(dateStr: string) {
  const d = new Date(dateStr + 'T12:00:00');
  return d.toLocaleDateString('en-CA', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' });
}
---

<Layout title="K9 Academy Events — Drop-Ins, Socials & More" description="Drop-in impulse control classes, adult dog socials, and puppy socials at K9 Academy Leaside. Limited spots.">
  <Navbar />

  <section class="pt-28 sm:pt-36 pb-16 sm:pb-24 bg-neutral-950 min-h-screen">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Header -->
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/5 border border-white/10 rounded-full mb-4">
          <svg class="w-3.5 h-3.5 text-k9-orange" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
          </svg>
          <span class="text-neutral-400 font-semibold text-[10px] uppercase tracking-widest">Events & Drop-Ins</span>
        </div>
        <h1 class="text-3xl sm:text-4xl font-extrabold text-white mb-3">
          Upcoming Events
        </h1>
        <p class="text-neutral-400 max-w-lg mx-auto">
          Drop-in classes, dog socials, and puppy socials. Limited spots — book yours below.
        </p>
      </div>

      <!-- Event type cards — always visible -->
      <div class="space-y-6">
        {eventTypes.map((et) => {
          const config = typeConfig[et.type] || typeConfig.impulse;
          const scheduled = events.filter(e => e.type === et.type);
          return (
            <div class="rounded-2xl bg-white/[0.03] border border-white/10 overflow-hidden">
              <!-- Event type header -->
              <div class="p-6 sm:p-8">
                <div class="flex items-center gap-2 mb-3">
                  <span class={`inline-flex items-center gap-1 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider rounded-full border ${config.color}`}>
                    {config.label}
                  </span>
                  <span class="text-neutral-600 text-xs">{et.spots} spots max</span>
                </div>
                <div class="sm:flex sm:items-start sm:justify-between gap-4">
                  <div>
                    <h3 class="text-lg font-bold text-white mb-1">{et.name}</h3>
                    <p class="text-neutral-400 text-sm mb-2">{et.description}</p>
                    <p class="text-neutral-600 text-xs italic">{et.requirement}</p>
                  </div>
                  <p class="text-2xl font-extrabold text-white mt-3 sm:mt-0 flex-shrink-0">${et.price}</p>
                </div>
              </div>

              <!-- Scheduled dates or waitlist -->
              <div class="border-t border-white/5 bg-white/[0.02] px-6 sm:px-8 py-4">
                {scheduled.length > 0 ? (
                  <div class="space-y-3">
                    <p class="text-xs text-neutral-500 uppercase tracking-wide font-semibold mb-2">Upcoming dates</p>
                    {scheduled.map((event) => (
                      <div class="flex items-center justify-between gap-4 py-2 border-b border-white/5 last:border-0">
                        <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-neutral-300">
                          <span class="flex items-center gap-1.5">
                            <svg class="w-3.5 h-3.5 text-neutral-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>
                            {formatDate(event.date)}
                          </span>
                          <span class="flex items-center gap-1.5">
                            <svg class="w-3.5 h-3.5 text-neutral-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                            {event.time}
                          </span>
                        </div>
                        <a href={event.stripeLink} target="_blank" rel="noopener" class="inline-flex items-center px-4 py-2 bg-k9-orange text-white text-xs font-bold rounded-lg hover:bg-k9-orange-dark transition-all whitespace-nowrap">
                          Book Spot
                        </a>
                      </div>
                    ))}
                  </div>
                ) : (
                  <div class="flex items-center justify-between gap-4">
                    <p class="text-neutral-500 text-sm">No dates scheduled yet — get notified when we add one.</p>
                    <a href="/#contact" class="inline-flex items-center gap-1.5 px-4 py-2 bg-white/5 border border-white/10 text-white text-xs font-semibold rounded-lg hover:border-k9-orange/30 hover:bg-white/10 transition-all whitespace-nowrap">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" /></svg>
                      Notify Me
                    </a>
                  </div>
                )}
              </div>
            </div>
          );
        })}
      </div>

      <!-- Info -->
      <div class="mt-10 rounded-xl bg-white/5 border border-white/10 p-5">
        <h3 class="text-white font-bold text-sm mb-2">How it works</h3>
        <ul class="space-y-1.5 text-neutral-400 text-sm">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-k9-orange mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
            Book and pay online — your spot is confirmed immediately
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-k9-orange mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
            Show up at K9 Academy Leaside (16-30 Canvarco Rd) at the scheduled time
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-k9-orange mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
            Spots are limited and non-refundable — please give 24hr notice to reschedule
          </li>
        </ul>
      </div>

      <div class="mt-6 text-center">
        <p class="text-neutral-600 text-xs">Questions? Call <a href="tel:4377785273" class="text-k9-orange hover:underline">437-778-5273</a> or email <a href="mailto:contact@k9academy.ca" class="text-k9-orange hover:underline">contact@k9academy.ca</a></p>
      </div>

    </div>
  </section>

  <Footer />
</Layout>
