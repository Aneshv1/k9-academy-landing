---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

// ============================================================
// EDIT EVENTS HERE — add/remove events as needed
// Only events listed below will appear on the page
// Set stripeLink to the Stripe Payment Link URL for each event
// ============================================================
const events = [
  // DROP-IN IMPULSE CONTROL
  // Copy this block and change date/time/stripeLink for each new session
  // {
  //   type: 'impulse',
  //   name: 'Drop-In Impulse Control Class',
  //   date: '2026-06-14',
  //   time: '10:00 AM',
  //   duration: '1 hour',
  //   location: 'Leaside — 16-30 Canvarco Rd, Toronto',
  //   price: 45,
  //   spots: 12,
  //   requirement: 'Must have completed Level 1 or equivalent',
  //   description: 'Focused session on impulse control — stays, leave it, settling under distraction. Perfect for dogs who need a tune-up.',
  //   stripeLink: 'https://buy.stripe.com/YOUR_LINK_HERE',
  // },

  // ADULT DOG SOCIAL
  // {
  //   type: 'social',
  //   name: 'Adult Dog Social',
  //   date: '2026-06-15',
  //   time: '2:00 PM',
  //   duration: '1.5 hours',
  //   location: 'Leaside — 16-30 Canvarco Rd, Toronto',
  //   price: 55,
  //   spots: 6,
  //   requirement: 'Must have completed Level 1 or equivalent',
  //   description: 'Structured off-leash social for trained adult dogs. Small group, supervised by our trainers.',
  //   stripeLink: 'https://buy.stripe.com/YOUR_LINK_HERE',
  // },

  // PUPPY SOCIAL
  // {
  //   type: 'puppy',
  //   name: 'Puppy Social',
  //   date: '2026-06-15',
  //   time: '12:00 PM',
  //   duration: '1 hour',
  //   location: 'Leaside — 16-30 Canvarco Rd, Toronto',
  //   price: 35,
  //   spots: 12,
  //   requirement: 'Puppies 6 months and under only',
  //   description: 'Supervised socialization for puppies. Structured introductions, play, and early confidence building.',
  //   stripeLink: 'https://buy.stripe.com/YOUR_LINK_HERE',
  // },
];

const typeConfig: Record<string, { label: string; color: string; icon: string }> = {
  impulse: { label: 'Drop-In Class', color: 'bg-blue-500/10 text-blue-500 border-blue-500/20', icon: '⚡' },
  social: { label: 'Adult Social', color: 'bg-emerald-500/10 text-emerald-500 border-emerald-500/20', icon: '🐕' },
  puppy: { label: 'Puppy Social', color: 'bg-purple-500/10 text-purple-500 border-purple-500/20', icon: '🐶' },
};

function formatDate(dateStr: string) {
  const d = new Date(dateStr + 'T12:00:00');
  return d.toLocaleDateString('en-CA', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' });
}
---

<Layout title="K9 Academy Events — Drop-Ins, Socials & More" description="Drop-in impulse control classes, adult dog socials, and puppy socials at K9 Academy Leaside. Limited spots.">
  <Navbar />

  <section class="pt-28 sm:pt-36 pb-16 sm:pb-24 bg-neutral-950 min-h-screen">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Header -->
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/5 border border-white/10 rounded-full mb-4">
          <svg class="w-3.5 h-3.5 text-k9-orange" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
          </svg>
          <span class="text-neutral-400 font-semibold text-[10px] uppercase tracking-widest">Events & Drop-Ins</span>
        </div>
        <h1 class="text-3xl sm:text-4xl font-extrabold text-white mb-3">
          Upcoming Events
        </h1>
        <p class="text-neutral-400 max-w-lg mx-auto">
          Drop-in classes, dog socials, and puppy socials. Limited spots — book yours below.
        </p>
      </div>

      {events.length === 0 ? (
        <!-- No events -->
        <div class="text-center py-16 rounded-2xl bg-white/5 border border-white/10">
          <p class="text-neutral-400 text-lg mb-2">No events scheduled right now.</p>
          <p class="text-neutral-500 text-sm">Check back soon — we add new sessions regularly.</p>
          <a href="/#contact" class="inline-flex items-center mt-6 px-6 py-3 bg-k9-orange text-white text-sm font-bold rounded-xl hover:bg-k9-orange-dark transition-all">
            Get Notified When We Add Events
          </a>
        </div>
      ) : (
        <!-- Event cards -->
        <div class="space-y-4">
          {events.map((event) => {
            const config = typeConfig[event.type] || typeConfig.impulse;
            return (
              <div class="rounded-2xl bg-white/[0.03] border border-white/10 hover:border-white/20 transition-all overflow-hidden">
                <div class="p-6 sm:p-8">
                  <div class="sm:flex sm:items-start sm:justify-between gap-6">
                    <!-- Left -->
                    <div class="flex-grow">
                      <div class="flex items-center gap-2 mb-3">
                        <span class={`inline-flex items-center gap-1 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider rounded-full border ${config.color}`}>
                          {config.label}
                        </span>
                        <span class="text-neutral-600 text-xs">{event.spots} spots</span>
                      </div>
                      <h3 class="text-lg font-bold text-white mb-1">{event.name}</h3>
                      <p class="text-neutral-400 text-sm mb-3">{event.description}</p>
                      <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-neutral-500">
                        <span class="flex items-center gap-1">
                          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>
                          {formatDate(event.date)}
                        </span>
                        <span class="flex items-center gap-1">
                          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                          {event.time} · {event.duration}
                        </span>
                        <span class="flex items-center gap-1">
                          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
                          {event.location}
                        </span>
                      </div>
                      <p class="text-neutral-600 text-xs mt-2 italic">{event.requirement}</p>
                    </div>

                    <!-- Right — Price + CTA -->
                    <div class="flex sm:flex-col items-center gap-3 mt-4 sm:mt-0 sm:text-right flex-shrink-0">
                      <p class="text-2xl font-extrabold text-white">${event.price}</p>
                      <a href={event.stripeLink} target="_blank" rel="noopener" class="inline-flex items-center px-5 py-2.5 bg-k9-orange text-white text-sm font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/20 whitespace-nowrap">
                        Book Spot
                        <svg class="ml-1.5 w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                        </svg>
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      )}

      <!-- Info -->
      <div class="mt-10 rounded-xl bg-white/5 border border-white/10 p-5">
        <h3 class="text-white font-bold text-sm mb-2">How it works</h3>
        <ul class="space-y-1.5 text-neutral-400 text-sm">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-k9-orange mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
            Book and pay online — your spot is confirmed immediately
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-k9-orange mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
            Show up at K9 Academy Leaside (16-30 Canvarco Rd) at the scheduled time
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-k9-orange mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
            Spots are limited and non-refundable — please give 24hr notice to reschedule
          </li>
        </ul>
      </div>

      <div class="mt-6 text-center">
        <p class="text-neutral-600 text-xs">Questions? Call <a href="tel:4377785273" class="text-k9-orange hover:underline">437-778-5273</a> or email <a href="mailto:contact@k9academy.ca" class="text-k9-orange hover:underline">contact@k9academy.ca</a></p>
      </div>

    </div>
  </section>

  <Footer />
</Layout>
