---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Awards from '../components/Awards.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
import GuideBanner from '../components/GuideBanner.astro';
import QuizForm from '../components/QuizForm.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';
import '../styles/global.css';
---

<Layout title="Puppy Start Right — 6-Week Puppy Board & Train Toronto | K9 Academy" description="Puppy board and train in Toronto. Your puppy lives with us for 6 weeks — daily training, socialization, crate training, and real-world proofing. We raise your puppy right. $3,995.">
  <Navbar />

  <!-- HERO -->
  <section class="relative pt-28 sm:pt-32 pb-14 sm:pb-20 overflow-hidden bg-brand-dark">
    <div class="absolute inset-0 bg-gradient-to-br from-k9-orange/5 via-transparent to-transparent pointer-events-none"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">

        <!-- LEFT: Copy -->
        <div>
          <div class="inline-flex items-center gap-2.5 bg-white/5 backdrop-blur-sm rounded-full px-4 py-2 border border-white/10 mb-6">
            <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            <div class="flex items-center gap-0.5">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <span class="text-sm font-semibold text-white">4.9/5</span>
            <span class="w-px h-4 bg-white/20"></span>
            <span class="text-sm text-neutral-400">250+ Google Reviews</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[3.4rem] font-extrabold tracking-tight text-white leading-[1.05]">
            Your puppy.
            <span class="bg-gradient-to-r from-k9-orange to-amber-400 bg-clip-text text-transparent">Trained right from day one.</span>
          </h1>

          <p class="mt-6 text-base sm:text-lg text-neutral-400 max-w-xl leading-relaxed">
            Three 2-week stays spread across your puppy's first year. Because puppies mature and change — one board and train too young doesn't stick. We train them at the stages that matter most.
          </p>

          <!-- Outcomes -->
          <div class="mt-7 grid sm:grid-cols-2 gap-2.5 max-w-xl">
            {[
              'Stay 1: Socialization + confidence',
              'Stay 2: Leash walking + obedience',
              'Stay 3: Full off-leash reliability',
              'Crate + potty + manners',
              'Handover session after each stay',
              'Training that grows with your puppy',
            ].map((item) => (
              <div class="flex items-center gap-2.5 text-sm text-neutral-300">
                <div class="w-5 h-5 rounded-full bg-k9-orange/15 flex items-center justify-center flex-shrink-0">
                  <svg class="w-3 h-3 text-k9-orange" fill="none" stroke="currentColor" stroke-width="3.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                  </svg>
                </div>
                <span>{item}</span>
              </div>
            ))}
          </div>

          <!-- CTAs -->
          <div class="mt-8 flex flex-col sm:flex-row items-start sm:items-center gap-4">
            <a href="#contact" class="inline-flex items-center px-7 py-4 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30 hover:shadow-xl hover:-translate-y-0.5">
              Apply for Puppy Start Right
              <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
            <a href="tel:4377785273" class="inline-flex items-center gap-2 text-neutral-400 font-medium hover:text-white transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              Or call 437-778-5273
            </a>
          </div>

          <!-- Trust line -->
          <div class="mt-6 flex flex-wrap items-center gap-x-5 gap-y-1.5 text-xs text-neutral-500">
            {['3 stays across the first year', 'Puppies under 12 months', '$3,995'].map((item) => (
              <span class="flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5 text-k9-orange flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                {item}
              </span>
            ))}
          </div>
        </div>

        <!-- RIGHT: Video -->
        <div class="rounded-2xl overflow-hidden border border-white/10 shadow-2xl shadow-black/40">
          <YouTubeEmbed videoId="2LY84P1F4n8" title="Puppy Start Right — K9 Academy Puppy Board & Train" />
        </div>
      </div>
    </div>
  </section>

  <Awards />

  <!-- WHY BOARD & TRAIN FOR A PUPPY -->
  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Why start now?</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900 leading-tight">
          One board and train at 12 weeks is not enough
        </h2>
      </div>

      <div class="mt-10 grid sm:grid-cols-2 gap-3">
        {[
          "Your puppy nips, jumps, and ignores you — and it is getting worse every week",
          "You are working full-time and cannot give your puppy the structure they need during the day",
          "Potty training is a disaster and your home is suffering",
          "Your puppy has zero recall and bolts out the door every chance they get",
          "You have read every guide and watched every video — nothing sticks",
          "You want to do it right from the start, not fix problems later at 10x the cost",
        ].map((pain) => (
          <div class="flex items-start gap-3 bg-neutral-50 rounded-xl p-4 border border-neutral-200/60">
            <svg class="w-5 h-5 text-red-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
            </svg>
            <p class="text-neutral-600 text-sm leading-relaxed">{pain}</p>
          </div>
        ))}
      </div>

      <div class="mt-10 text-center">
        <p class="text-lg text-neutral-500 max-w-2xl mx-auto leading-relaxed">
          Puppies change dramatically in their first year. What works at 12 weeks needs reinforcing at 5 months and again at 8 months. That is why Puppy Start Right is three separate 2-week stays — timed to match your puppy's development stages. One board and train too young is a waste. Three at the right times builds a foundation that lasts.
        </p>
      </div>
    </div>
  </section>

  <!-- YOUR PUPPY'S FIRST YEAR — TIMELINE -->
  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-k9-orange font-semibold text-xs tracking-widest uppercase mb-3">Your Puppy's First Year</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900">
          What happens at each stage — and how we help
        </h2>
        <p class="mt-4 text-neutral-500 max-w-2xl mx-auto">Puppies change dramatically in their first year. One board and train too young doesn't stick. Three stays at the right times builds a foundation that lasts.</p>
      </div>

      <!-- Timeline -->
      <div class="relative">
        <!-- Vertical line -->
        <div class="absolute left-6 sm:left-8 top-0 bottom-0 w-px bg-neutral-200"></div>

        <!-- Stay 1 -->
        <div class="relative pl-16 sm:pl-20 pb-14">
          <div class="absolute left-3.5 sm:left-5.5 top-1 w-5 h-5 rounded-full bg-k9-orange flex items-center justify-center">
            <span class="text-white text-[10px] font-bold">1</span>
          </div>
          <div class="flex items-center gap-3 mb-3">
            <span class="text-xs font-bold text-k9-orange uppercase tracking-wide">Stay 1 · ~8-14 weeks</span>
          </div>
          <h3 class="text-xl font-bold text-neutral-900 mb-2">Socialization &amp; Confidence</h3>

          <div class="grid sm:grid-cols-2 gap-4 mt-4">
            <div class="rounded-xl bg-red-50 border border-red-100 p-4">
              <p class="text-xs font-bold text-red-600 uppercase tracking-wide mb-2">What's happening at this age</p>
              <ul class="space-y-1.5 text-sm text-red-900/70">
                <li>Socialization window is open — closes around 14-16 weeks</li>
                <li>Fear periods can develop without proper exposure</li>
                <li>Nipping and biting are constant</li>
                <li>No concept of boundaries or manners</li>
              </ul>
            </div>
            <div class="rounded-xl bg-emerald-50 border border-emerald-100 p-4">
              <p class="text-xs font-bold text-emerald-600 uppercase tracking-wide mb-2">What we do</p>
              <ul class="space-y-1.5 text-sm text-emerald-900/70">
                <li>Daily exposure to people, dogs, sounds, surfaces</li>
                <li>Confidence building in new environments</li>
                <li>No-bite training + puppy manners</li>
                <li>Crate introduction + potty training foundations</li>
              </ul>
            </div>
          </div>

          <p class="mt-4 text-sm text-neutral-500 italic">Your puppy comes home socialized, confident, and with the foundation for everything that follows.</p>
        </div>

        <!-- Stay 2 -->
        <div class="relative pl-16 sm:pl-20 pb-14">
          <div class="absolute left-3.5 sm:left-5.5 top-1 w-5 h-5 rounded-full bg-k9-orange flex items-center justify-center">
            <span class="text-white text-[10px] font-bold">2</span>
          </div>
          <div class="flex items-center gap-3 mb-3">
            <span class="text-xs font-bold text-k9-orange uppercase tracking-wide">Stay 2 · ~4-6 months</span>
          </div>
          <h3 class="text-xl font-bold text-neutral-900 mb-2">Control &amp; Obedience</h3>

          <div class="grid sm:grid-cols-2 gap-4 mt-4">
            <div class="rounded-xl bg-red-50 border border-red-100 p-4">
              <p class="text-xs font-bold text-red-600 uppercase tracking-wide mb-2">What's happening at this age</p>
              <ul class="space-y-1.5 text-sm text-red-900/70">
                <li>Adolescent energy is ramping up fast</li>
                <li>Testing boundaries — ignoring commands that used to work</li>
                <li>Pulling hard on leash, can't settle</li>
                <li>Impulse control is nonexistent</li>
              </ul>
            </div>
            <div class="rounded-xl bg-emerald-50 border border-emerald-100 p-4">
              <p class="text-xs font-bold text-emerald-600 uppercase tracking-wide mb-2">What we do</p>
              <ul class="space-y-1.5 text-sm text-emerald-900/70">
                <li>Leash walking + heel position</li>
                <li>Teaching calmness + place command</li>
                <li>Structured obedience — sit, down, stay, come</li>
                <li>Impulse control + general self-control</li>
              </ul>
            </div>
          </div>

          <p class="mt-4 text-sm text-neutral-500 italic">Your puppy comes home with real control — walks nicely, settles when told, and responds to commands reliably.</p>
        </div>

        <!-- Stay 3 -->
        <div class="relative pl-16 sm:pl-20 pb-4">
          <div class="absolute left-3.5 sm:left-5.5 top-1 w-5 h-5 rounded-full bg-k9-orange flex items-center justify-center">
            <span class="text-white text-[10px] font-bold">3</span>
          </div>
          <div class="flex items-center gap-3 mb-3">
            <span class="text-xs font-bold text-k9-orange uppercase tracking-wide">Stay 3 · ~7-10 months</span>
          </div>
          <h3 class="text-xl font-bold text-neutral-900 mb-2">Off-Leash Reliability</h3>

          <div class="grid sm:grid-cols-2 gap-4 mt-4">
            <div class="rounded-xl bg-red-50 border border-red-100 p-4">
              <p class="text-xs font-bold text-red-600 uppercase tracking-wide mb-2">What's happening at this age</p>
              <ul class="space-y-1.5 text-sm text-red-900/70">
                <li>Full adolescent regression hits — the "teenage" phase</li>
                <li>Selective hearing, testing every rule</li>
                <li>Chasing squirrels, ignoring recall</li>
                <li>Everything you taught at 4 months starts slipping</li>
              </ul>
            </div>
            <div class="rounded-xl bg-emerald-50 border border-emerald-100 p-4">
              <p class="text-xs font-bold text-emerald-600 uppercase tracking-wide mb-2">What we do</p>
              <ul class="space-y-1.5 text-sm text-emerald-900/70">
                <li>Full off-leash training + proofing</li>
                <li>Reliable recall under heavy distractions</li>
                <li>Real-world reliability — parks, trails, crowds</li>
                <li>Lock in everything before bad habits become permanent</li>
              </ul>
            </div>
          </div>

          <p class="mt-4 text-sm text-neutral-500 italic">Your dog graduates fully trained, off-leash reliable, and set for life. No regression to undo later.</p>
        </div>
      </div>

      <!-- Price + CTA -->
      <div class="mt-12 text-center">
        <div class="inline-flex flex-col items-center gap-3 rounded-2xl bg-neutral-950 px-10 py-8">
          <p class="text-neutral-400 text-sm">All 3 stays included</p>
          <p class="text-4xl font-extrabold text-white">$3,995</p>
          <a href="#contact" class="inline-flex items-center px-7 py-3.5 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30">
            Apply for Puppy Start Right
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </a>
          <div class="flex items-center gap-2 mt-2">
            <img src="/affirm-logo.png" alt="Affirm" class="h-3.5 w-auto max-w-[50px] opacity-60" loading="lazy" />
            <p class="text-neutral-500 text-xs">Financing available</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="py-16 sm:py-24 bg-brand-dark">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">The Process</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-white">
          From application to a trained puppy
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { num: '01', title: 'Apply', desc: 'Tell us about your puppy — breed, age, and what you want to achieve. We plan the 3 stays around their age.' },
          { num: '02', title: 'Stay 1', desc: 'Socialization, confidence building, exposure to the world, puppy manners, no-bite training, and crate introduction.' },
          { num: '03', title: 'Stay 2', desc: 'A few months later — leash walking, general control, calmness, and structured obedience as your puppy matures.' },
          { num: '04', title: 'Stay 3', desc: 'Full off-leash training and reliability in all scenarios. Everything locked in before adolescent regression hits.' },
        ].map((step) => (
          <div class="text-center sm:text-left">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-k9-orange text-white text-sm font-bold mb-4">
              {step.num}
            </div>
            <h3 class="text-lg font-bold text-white mb-2">{step.title}</h3>
            <p class="text-neutral-400 text-sm leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>

      <div class="text-center mt-12">
        <a href="#contact" class="inline-flex items-center px-7 py-3.5 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30">
          Apply for Puppy Start Right
        </a>
        <div class="mt-3 flex justify-center gap-4">
          {['Limited spots', 'Quick response'].map((item) => (
            <span class="flex items-center gap-1.5 text-sm text-neutral-500">
              <svg class="w-4 h-4 text-k9-orange" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              {item}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <QuizForm puppy />
  <ContactForm />
  <Footer />
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Puppy Board and Train Toronto",
  "provider": {
    "@type": "LocalBusiness",
    "name": "K9 Academy Dog Training Center",
    "address": { "@type": "PostalAddress", "streetAddress": "16-30 Canvarco Rd", "addressLocality": "Toronto", "addressRegion": "ON", "postalCode": "M4G 1L3", "addressCountry": "CA" }
  },
  "areaServed": { "@type": "City", "name": "Toronto" },
  "description": "Puppy board and train in Toronto. 6-week immersive program for puppies under 12 months. Daily obedience training, socialization, crate training, and real-world proofing.",
  "offers": {
    "@type": "Offer",
    "name": "Puppy Start Right (6 weeks)",
    "price": "3995",
    "priceCurrency": "CAD"
  }
})} />
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How old does my puppy need to be for Puppy Start Right?", "acceptedAnswer": { "@type": "Answer", "text": "We accept puppies up to 12 months old. The earlier you start, the stronger the foundation — but even older puppies benefit enormously from 6 weeks of structured training." }},
    { "@type": "Question", "name": "What will my puppy know when they come home?", "acceptedAnswer": { "@type": "Answer", "text": "Full obedience (sit, down, stay, place, come), loose leash walking, off-leash recall foundations, crate training, potty training, and calm behaviour around people and other dogs." }},
    { "@type": "Question", "name": "How much does puppy board and train cost?", "acceptedAnswer": { "@type": "Answer", "text": "$3,995 for the full 6-week program. Financing is available through Affirm." }}
  ]
})} />
</Layout>
