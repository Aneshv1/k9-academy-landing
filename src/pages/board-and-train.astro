---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Awards from '../components/Awards.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
import GuideBanner from '../components/GuideBanner.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';
import '../styles/global.css';
---

<Layout title="Board and Train Dog Training Toronto. 2 to 8 Weeks | K9 Academy" description="Board and train dog training in Toronto. Your dog lives with us for 2-8 weeks. daily training, socialization, and real-world proofing. Limited spots. Apply now.">
  <Navbar />

  <!-- HERO -->
  <section class="relative pt-28 sm:pt-32 pb-14 sm:pb-20 overflow-hidden bg-brand-dark">
    <div class="absolute inset-0 bg-gradient-to-br from-k9-orange/5 via-transparent to-transparent pointer-events-none"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">

        <!-- LEFT: Copy -->
        <div>
          <div class="inline-flex items-center gap-2.5 bg-white/5 backdrop-blur-sm rounded-full px-4 py-2 border border-white/10 mb-6">
            <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            <div class="flex items-center gap-0.5">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <span class="text-sm font-semibold text-white">4.9/5</span>
            <span class="w-px h-4 bg-white/20"></span>
            <span class="text-sm text-neutral-400">250+ Google Reviews</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[3.4rem] font-extrabold tracking-tight text-white leading-[1.05]">
            A transformed dog —
            <span class="bg-gradient-to-r from-k9-orange to-amber-400 bg-clip-text text-transparent">without doing it yourself</span>
            <span class="block mt-2 text-3xl sm:text-4xl lg:text-[2.5rem] text-neutral-300 font-bold">— in 2 to 8 weeks.</span>
          </h1>

          <p class="mt-6 text-base sm:text-lg text-neutral-400 max-w-xl leading-relaxed">
            Your dog lives with us. Daily training, structured routines, socialization, and real-world proofing. You get back a dog you can trust. anywhere.
          </p>

          <!-- Outcomes -->
          <div class="mt-7 grid sm:grid-cols-2 gap-2.5 max-w-xl">
            {[
              'Off-leash reliability',
              'Reactivity + aggression',
              'Separation anxiety',
              'Leash pulling + barking',
              'Crate + house training',
              'Socialization + confidence',
            ].map((item) => (
              <div class="flex items-center gap-2.5 text-sm text-neutral-300">
                <div class="w-5 h-5 rounded-full bg-k9-orange/15 flex items-center justify-center flex-shrink-0">
                  <svg class="w-3 h-3 text-k9-orange" fill="none" stroke="currentColor" stroke-width="3.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                  </svg>
                </div>
                <span>{item}</span>
              </div>
            ))}
          </div>

          <!-- CTAs -->
          <div class="mt-8 flex flex-col sm:flex-row items-start sm:items-center gap-4">
            <a href="#contact" class="inline-flex items-center px-7 py-4 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30 hover:shadow-xl hover:-translate-y-0.5">
              Apply for Board & Train
              <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
            <a href="tel:4377785273" class="inline-flex items-center gap-2 text-neutral-400 font-medium hover:text-white transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              Or call 437-778-5273
            </a>
          </div>

          <!-- Trust line -->
          <div class="mt-6 flex flex-wrap items-center gap-x-5 gap-y-1.5 text-xs text-neutral-500">
            {['2–8 week programs', 'Financing via Affirm', 'Limited spots each month'].map((item) => (
              <span class="flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5 text-k9-orange flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                {item}
              </span>
            ))}
          </div>
        </div>

        <!-- RIGHT: Video -->
        <div class="rounded-2xl overflow-hidden border border-white/10 shadow-2xl shadow-black/40">
          <YouTubeEmbed videoId="76P1n4JgNRQ" title="K9 Academy Board & Train Program" />
        </div>
      </div>
    </div>
  </section>

  <Awards />

  <!-- PAS -->
  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Sound familiar?</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900 leading-tight">
          You love your dog. But something has to change.
        </h2>
      </div>

      <div class="mt-10 grid sm:grid-cols-2 gap-3">
        {[
          "Your dog is reactive on leash. lunging, barking, pulling toward every dog or person",
          "You have been through other trainers and nothing has stuck long-term",
          "Your dog has shown aggression and you are worried about what comes next",
          "You cannot trust your dog off-leash. recall is non-existent",
          "Your dog is anxious, nervous, or fearful in new environments",
          "You are dealing with resource guarding, territorial behaviour, or multi-dog conflict",
        ].map((pain) => (
          <div class="flex items-start gap-3 bg-neutral-50 rounded-xl p-4 border border-neutral-200/60">
            <svg class="w-5 h-5 text-red-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
            </svg>
            <p class="text-neutral-600 text-sm leading-relaxed">{pain}</p>
          </div>
        ))}
      </div>

      <div class="mt-10 text-center">
        <h3 class="text-2xl sm:text-3xl font-extrabold text-neutral-900 mb-4">
          Board & Train removes you from the equation. and that is often the missing piece.
        </h3>
        <p class="text-lg text-neutral-500 max-w-2xl mx-auto leading-relaxed">
          Your dog lives with our team, trains daily, and learns in a structured environment free from the patterns that have been reinforcing bad behaviour at home.
        </p>
      </div>
    </div>
  </section>

  <!-- VIDEO CAROUSEL. Transformation proof right after pain points -->
  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">See It in Action</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900">
          Watch real Board & Train transformations
        </h2>
        <p class="mt-3 text-neutral-500 max-w-xl mx-auto">Real dogs. Real issues. Real results. from our facility to their homes.</p>
      </div>

      <div class="space-y-3" id="bt-video-carousel">
        <div id="bt-main-video" class="rounded-2xl overflow-hidden border border-neutral-200/60 shadow-md">
          <YouTubeEmbed videoId="9AXqpLAorBM" title="K9 Academy Board & Train. Anxious Dog Transformation" />
        </div>

        <div class="flex gap-2">
          {[
            { id: '9AXqpLAorBM', alt: 'Anxious Dog Transformation', active: true },
            { id: 'uTxxy_-qzrg', alt: 'Board & Train Results', active: false },
            { id: 'gfnMuWAA-LM', alt: 'Dog Training', active: false },
            { id: '3B-EavE1l_U', alt: 'Training Results', active: false },
          ].map((v) => (
            <button data-video={v.id} class={`bt-video-thumb flex-1 rounded-lg overflow-hidden border-2 transition-all ${v.active ? 'border-k9-orange opacity-100' : 'border-transparent opacity-60 hover:opacity-100'}`}>
              <img src={`https://img.youtube.com/vi/${v.id}/mqdefault.jpg`} alt={v.alt} class="w-full aspect-video object-cover" loading="lazy" />
            </button>
          ))}
        </div>
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll('.bt-video-thumb').forEach((btn) => {
      btn.addEventListener('click', () => {
        const videoId = (btn as HTMLElement).dataset.video;
        const container = document.getElementById('bt-main-video')!;
        container.innerHTML = `<div class="relative aspect-video"><iframe src="https://www.youtube.com/embed/${videoId}?rel=0&autoplay=1" title="Video" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen class="absolute inset-0 w-full h-full"></iframe></div>`;

        document.querySelectorAll('.bt-video-thumb').forEach((b) => {
          b.classList.remove('border-k9-orange');
          b.classList.add('border-transparent', 'opacity-60');
        });
        btn.classList.add('border-k9-orange');
        btn.classList.remove('border-transparent', 'opacity-60');
        btn.classList.add('opacity-100');
      });
    });
  </script>

  <!-- PROGRAMS -->
  <section id="programs" class="py-16 sm:py-24 bg-neutral-50 border-y border-neutral-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Our Programs</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900">
          Three programs for three levels of need
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-5">
        <!-- 2 Week Express -->
        <div class="rounded-2xl p-6 sm:p-8 border border-neutral-200/60 bg-white hover:border-neutral-300 hover:shadow-md transition-all">
          <h3 class="text-2xl font-bold text-neutral-900 mb-1">2 Week</h3>
          <p class="text-k9-orange font-medium text-sm mb-3">Basic obedience + manners</p>
          <p class="text-neutral-500 text-sm mb-5 leading-relaxed">Ideal for young dogs that transition easily. Addresses basic behaviour issues like leash pulling, mild reactivity, and off-leash training in a short, focused program.</p>
          <ul class="space-y-2 mb-6">
            {['Leash pulling', 'Off-leash training', 'Mild reactivity', 'Socialization', 'Basic behaviour correction', 'Handler training included'].map((d) => (
              <li class="flex items-start gap-2 text-sm text-neutral-600">
                <svg class="w-4 h-4 text-k9-orange flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                <span>{d}</span>
              </li>
            ))}
          </ul>
          <div class="flex items-center justify-between pt-5 border-t border-neutral-100">
            <span class="text-2xl font-extrabold text-neutral-900">$2,995</span>
            <a href="#contact" class="inline-flex items-center px-5 py-2.5 text-sm font-semibold rounded-lg bg-neutral-100 text-neutral-700 hover:bg-k9-orange hover:text-white transition-all">Apply</a>
          </div>
        </div>

        <!-- 4 Week / Behaviour Modification -->
        <div class="relative rounded-2xl p-6 sm:p-8 border border-k9-orange/30 bg-k9-orange-light/40 ring-1 ring-k9-orange/10 hover:shadow-md transition-all">
          <div class="absolute -top-3 left-6">
            <span class="inline-flex items-center px-3 py-1 bg-k9-orange text-white text-xs font-bold rounded-lg uppercase tracking-wide">Most Popular</span>
          </div>
          <h3 class="text-2xl font-bold text-neutral-900 mb-1 mt-2">4 Week</h3>
          <p class="text-k9-orange font-medium text-sm mb-3">Behaviour modification</p>
          <p class="text-neutral-500 text-sm mb-5 leading-relaxed">For fearful, nervous, reactive, or over-excitable dogs. Dogs showing aggression toward humans or other dogs. Constantly anxious dogs and resource guarders. This is the program most clients choose.</p>
          <ul class="space-y-2 mb-6">
            {['Fear + nervousness', 'Reactivity + aggression', 'Over-excitability', 'Resource guarding', 'Advanced obedience', 'Full socialization program'].map((d) => (
              <li class="flex items-start gap-2 text-sm text-neutral-600">
                <svg class="w-4 h-4 text-k9-orange flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                <span>{d}</span>
              </li>
            ))}
          </ul>
          <div class="flex items-center justify-between pt-5 border-t border-neutral-100">
            <span class="text-2xl font-extrabold text-neutral-900">$3,995</span>
            <a href="#contact" class="inline-flex items-center px-5 py-2.5 text-sm font-semibold rounded-lg bg-k9-orange text-white hover:bg-k9-orange-dark shadow-sm transition-all">Apply</a>
          </div>
        </div>

        <!-- 6 Week / Severe Cases -->
        <div class="rounded-2xl p-6 sm:p-8 border border-neutral-200/60 bg-white hover:border-neutral-300 hover:shadow-md transition-all">
          <h3 class="text-2xl font-bold text-neutral-900 mb-1">6 Week</h3>
          <p class="text-k9-orange font-medium text-sm mb-3">Aggression, anxiety + severe cases</p>
          <p class="text-neutral-500 text-sm mb-5 leading-relaxed">For very nervous, anxious, or aggressive dogs. Multiple bite incidents, severe human and dog aggression, emergency cases, multi-dog conflict, and deep-rooted behavioural issues.</p>
          <ul class="space-y-2 mb-6">
            {['Severe aggression', 'Multiple bite incidents', 'Emergency cases', 'Multi-dog conflict', 'Deep-rooted anxiety', 'Extended rehabilitation'].map((d) => (
              <li class="flex items-start gap-2 text-sm text-neutral-600">
                <svg class="w-4 h-4 text-k9-orange flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                <span>{d}</span>
              </li>
            ))}
          </ul>
          <div class="flex items-center justify-between pt-5 border-t border-neutral-100">
            <span class="text-2xl font-extrabold text-neutral-900">$4,995</span>
            <a href="#contact" class="inline-flex items-center px-5 py-2.5 text-sm font-semibold rounded-lg bg-neutral-100 text-neutral-700 hover:bg-k9-orange hover:text-white transition-all">Apply</a>
          </div>
        </div>
      </div>

      <!-- 8 Week note -->
      <div class="mt-6 rounded-xl bg-neutral-50 border border-neutral-200 p-5 sm:flex sm:items-center sm:justify-between gap-4">
        <div>
          <h4 class="font-bold text-neutral-900 text-sm mb-1">8-Week Intensive Rehabilitation: $7,995</h4>
          <p class="text-neutral-500 text-sm">For complex bite history, emergency cases, multi-dog aggression, and dogs that need the most comprehensive rehabilitation program available. Full behavioural reset with extended support.</p>
        </div>
        <a href="#contact" class="inline-flex items-center mt-3 sm:mt-0 px-5 py-2.5 text-sm font-semibold rounded-lg bg-neutral-900 text-white hover:bg-neutral-800 transition-all whitespace-nowrap">
          Discuss Your Case
        </a>
      </div>

      <!-- LIFETIME SUPPORT BANNER -->
      <div class="mt-8 rounded-2xl bg-neutral-900 p-6 sm:p-8 border border-white/10">
        <div class="sm:flex sm:items-center sm:justify-between gap-6">
          <div>
            <div class="flex items-center gap-2 mb-2">
              <svg class="w-5 h-5 text-k9-orange" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
              <h3 class="text-lg font-bold text-white">Included with every Board & Train: lifetime support</h3>
            </div>
            <p class="text-neutral-400 text-sm leading-relaxed">This is the last training investment you'll ever make. Every B&T graduate gets unlimited access to group classes, drop-in sessions, and ongoing trainer support for life. No extra cost. No expiry. If your dog ever needs a tune-up, we're here.</p>
          </div>
          <div class="mt-4 sm:mt-0 flex-shrink-0">
            <div class="flex flex-col items-center gap-1 text-center px-6 py-4 rounded-xl bg-white/5 border border-white/10">
              <span class="text-2xl font-extrabold text-k9-orange">∞</span>
              <span class="text-[10px] text-neutral-500 uppercase tracking-widest">Lifetime access</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Puppy Board & Train -->
      <div class="mt-8 rounded-2xl p-6 border border-k9-orange/20 bg-k9-orange/5 flex flex-col sm:flex-row items-center justify-between gap-4">
        <div>
          <h3 class="text-lg font-bold text-neutral-900">Got a puppy?</h3>
          <p class="text-neutral-600 text-sm">Our Puppy Start Right program is a 6-week board & train designed specifically for puppies. $3,995.</p>
        </div>
        <a href="/puppy-start-right" class="inline-flex items-center px-5 py-2.5 text-sm font-semibold rounded-lg bg-k9-orange text-white hover:bg-k9-orange-dark transition-all whitespace-nowrap">
          Puppy Start Right
          <svg class="ml-1.5 w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>

      <!-- Financing -->
      <div class="mt-8 flex items-center justify-center gap-3">
        <img src="/affirm-logo.png" alt="Affirm" class="h-4 w-auto max-w-[60px]" loading="lazy" />
        <p class="text-neutral-500 text-sm">Financing available. buy now, pay over time.</p>
      </div>
    </div>
  </section>

  <!-- WHAT THEY LEARN -->
  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">What Your Dog Learns</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900">
          Your dog graduates with real-world skills. not tricks
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {[
          { title: 'Loose leash walking', desc: 'Calm, controlled walking in any environment. No more pulling, lunging, or crossing the street to avoid other dogs.' },
          { title: 'Off-leash recall', desc: 'Reliable recall anywhere. parks, trails, the neighbourhood. Come when called, every time.' },
          { title: 'Obedience in any environment', desc: 'Sit, down, stay, place; not just at home, but in real-world situations with real distractions.' },
          { title: 'Socialization', desc: 'Structured interaction with dogs and people. Calm confidence replaces anxiety, fear, and reactivity.' },
        ].map((item) => (
          <div class="rounded-2xl p-6 bg-neutral-50 border border-neutral-200/60">
            <h3 class="text-base font-bold text-neutral-900 mb-2">{item.title}</h3>
            <p class="text-neutral-500 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>

      <div class="mt-8 bg-neutral-50 rounded-2xl p-6 border border-neutral-200/60">
        <h3 class="text-lg font-bold text-neutral-900 mb-3">By graduation, your dog will have eliminated:</h3>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
          {['Excessive barking', 'Nervousness + anxiety', 'Leash pulling + reactivity', 'Resource guarding'].map((item) => (
            <div class="flex items-center gap-2 text-sm text-neutral-600">
              <svg class="w-4 h-4 text-k9-orange flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              <span>{item}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- SOCIAL PROOF -->
  <section class="py-16 sm:py-24 bg-neutral-50 border-y border-neutral-100">
