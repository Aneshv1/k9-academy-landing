---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Awards from '../components/Awards.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
import GuideBanner from '../components/GuideBanner.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';
import '../styles/global.css';
---

<Layout title="Board and Train Dog Training Toronto. 2 to 8 Weeks | K9 Academy" description="Board and train dog training in Toronto. Your dog lives with us for 2-8 weeks. daily training, socialization, and real-world proofing. Limited spots. Apply now.">
  <Navbar />

  <!-- HERO -->
  <section class="relative pt-28 sm:pt-32 pb-14 sm:pb-20 overflow-hidden bg-brand-dark">
    <div class="absolute inset-0 bg-gradient-to-br from-k9-orange/5 via-transparent to-transparent pointer-events-none"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">

        <!-- LEFT: Copy -->
        <div>
          <div class="inline-flex items-center gap-2.5 bg-white/5 backdrop-blur-sm rounded-full px-4 py-2 border border-white/10 mb-6">
            <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            <div class="flex items-center gap-0.5">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <span class="text-sm font-semibold text-white">4.9/5</span>
            <span class="w-px h-4 bg-white/20"></span>
            <span class="text-sm text-neutral-400">250+ Google Reviews</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[3.4rem] font-extrabold tracking-tight text-white leading-[1.05]">
            Let professionals transform your dog<br/>
            <span class="bg-gradient-to-r from-k9-orange to-amber-400 bg-clip-text text-transparent">in as little as 2 weeks.</span>
          </h1>

          <p class="mt-6 text-base sm:text-lg text-neutral-400 max-w-xl leading-relaxed">
            Your dog lives with us. Daily training, structured routines, socialization, and real-world proofing. You get back a dog you can trust. anywhere.
          </p>

          <!-- Outcomes -->
          <div class="mt-7 grid sm:grid-cols-2 gap-2.5 max-w-xl">
            {[
              'Off-leash reliability',
              'Reactivity + aggression',
              'Separation anxiety',
              'Leash pulling + barking',
              'Crate + house training',
              'Socialization + confidence',
            ].map((item) => (
              <div class="flex items-center gap-2.5 text-sm text-neutral-300">
                <div class="w-5 h-5 rounded-full bg-k9-orange/15 flex items-center justify-center flex-shrink-0">
                  <svg class="w-3 h-3 text-k9-orange" fill="none" stroke="currentColor" stroke-width="3.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                  </svg>
                </div>
                <span>{item}</span>
              </div>
            ))}
          </div>

          <!-- CTAs -->
          <div class="mt-8 flex flex-col sm:flex-row items-start sm:items-center gap-4">
            <a href="#contact" class="inline-flex items-center px-7 py-4 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30 hover:shadow-xl hover:-translate-y-0.5">
              Apply for Board & Train
              <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
            <a href="tel:4377785273" class="inline-flex items-center gap-2 text-neutral-400 font-medium hover:text-white transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              Or call 437-778-5273
            </a>
          </div>

          <!-- Trust line -->
          <div class="mt-6 flex flex-wrap items-center gap-x-5 gap-y-1.5 text-xs text-neutral-500">
            {['2–8 week programs', 'Financing via Affirm', 'Limited spots each month'].map((item) => (
              <span class="flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5 text-k9-orange flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                {item}
              </span>
            ))}
          </div>
        </div>

        <!-- RIGHT: Video -->
        <div class="rounded-2xl overflow-hidden border border-white/10 shadow-2xl shadow-black/40">
          <YouTubeEmbed videoId="76P1n4JgNRQ" title="K9 Academy Board & Train Program" />
        </div>
      </div>
    </div>
  </section>

  <Awards />

  <!-- PAS -->
  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Sound familiar?</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900 leading-tight">
          You love your dog. But something has to change.
        </h2>
      </div>

      <!-- 3 pain points -->
      <div class="grid md:grid-cols-3 gap-5 mb-10">
        {[
          {
            pain: 'Every walk is a battle',
            detail: 'Lunging, barking, pulling toward every dog and person. You\'ve stopped going to certain parks. You dread leaving the house.',
            iconPath: 'M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z',
          },
          {
            pain: 'Other trainers couldn\'t fix it',
            detail: 'You\'ve spent thousands. Tried positive-only. Tried YouTube. Tried 2 or 3 different trainers. Nothing lasted more than a week.',
            iconPath: 'M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636',
          },
          {
            pain: 'You\'re scared of what comes next',
            detail: 'Aggression is escalating. A bite. A lawsuit. A conversation about euthanasia. You know something has to change before it\'s too late.',
            iconPath: 'M2.25 6L9 12.75l4.286-4.286a11.948 11.948 0 014.306 6.43l.776 2.898m0 0l3.182-5.511m-3.182 5.51l-5.511-3.181',
          },
        ].map((item) => (
          <div class="rounded-2xl bg-neutral-50 border border-neutral-200 p-6 text-center hover:border-red-200 hover:bg-red-50/30 transition-all group">
            <div class="w-12 h-12 rounded-full bg-red-50 border border-red-100 flex items-center justify-center mx-auto mb-4 group-hover:bg-red-100 transition-colors">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d={item.iconPath} />
              </svg>
            </div>
            <h3 class="text-lg font-extrabold text-neutral-900 mb-2">{item.pain}</h3>
            <p class="text-neutral-500 text-sm leading-relaxed">{item.detail}</p>
          </div>
        ))}
      </div>

      <!-- Real client quote -->
      <div class="rounded-2xl bg-neutral-50 border border-neutral-200 p-6 sm:p-8 mb-10">
        <div class="flex items-center gap-0.5 mb-3">
          {[1,2,3,4,5].map(() => (
            <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <blockquote class="text-lg font-semibold text-neutral-900 leading-relaxed mb-3">
          "Before we brought Simba in I saw all the 5 star ratings and thought this is too good to be true. Well it's not. After two weeks he comes instantly when called and sits when other dogs come by. We honestly cannot believe he is the same dog."
        </blockquote>
        <p class="text-neutral-400 text-sm">Hugh M. · Hound rescue · 2-week Board & Train</p>
      </div>

      <!-- Outcome + CTA -->
      <div class="text-center">
        <h3 class="text-2xl sm:text-3xl font-extrabold text-neutral-900 mb-3">
          What if this was all behind you in 4 weeks?
        </h3>
        <p class="text-neutral-500 max-w-xl mx-auto mb-6">
          Your dog lives with our team, trains 3-4 hours daily, and comes home a different animal. You get lifetime support after graduation. This is the last training program you'll ever need.
        </p>
        <a href="#contact" class="inline-flex items-center px-8 py-4 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30 hover:shadow-xl hover:-translate-y-0.5">
          Apply for Board & Train
          <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
        <p class="text-neutral-400 text-xs mt-3">Limited spots each month. We respond within hours.</p>
      </div>
    </div>
  </section>

  <!-- TRANSFORMATION PROOF -->
  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">See It in Action</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900">
          Watch real Board & Train transformations
        </h2>
      </div>

      <div class="space-y-8">
        <!-- Transformation 1: Doberman -->
        <div class="grid md:grid-cols-[1.5fr_1fr] gap-6 items-center">
          <div class="rounded-2xl overflow-hidden border border-neutral-200 shadow-md">
            <YouTubeEmbed videoId="gfnMuWAA-LM" title="Doberman Board & Train Transformation" />
          </div>
          <div class="p-2">
            <span class="inline-flex items-center px-2.5 py-1 rounded-full bg-red-50 text-red-500 text-[10px] font-bold uppercase tracking-wide border border-red-100 mb-3">Aggression</span>
            <blockquote class="text-lg font-semibold text-neutral-900 leading-relaxed mb-3">
              "Too aggressive to be outside."
            </blockquote>
            <p class="text-neutral-500 text-sm leading-relaxed mb-3">Her vet, dog walker, and previous trainers all said the same thing. She couldn't be walked. Couldn't be around other dogs. Couldn't be trusted.</p>
            <p class="text-k9-orange font-semibold text-sm">4 weeks later, she walks off-leash beside other dogs.</p>
            <p class="text-neutral-400 text-xs mt-2">Doberman, 3 years. 4-week Board & Train.</p>
          </div>
        </div>

        <!-- Transformation 2: Malinois -->
        <div class="grid md:grid-cols-[1fr_1.5fr] gap-6 items-center">
          <div class="p-2 md:order-1 order-2">
            <span class="inline-flex items-center px-2.5 py-1 rounded-full bg-purple-50 text-purple-500 text-[10px] font-bold uppercase tracking-wide border border-purple-100 mb-3">Reactivity</span>
            <blockquote class="text-lg font-semibold text-neutral-900 leading-relaxed mb-3">
              "Uncontrollable. Couldn't be walked."
            </blockquote>
            <p class="text-neutral-500 text-sm leading-relaxed mb-3">Every trainer they saw said the dog was too much. Too reactive. Too strong. Too dangerous. They were told to consider rehoming.</p>
            <p class="text-k9-orange font-semibold text-sm">6 weeks later, fully off-leash reliable with perfect recall.</p>
            <p class="text-neutral-400 text-xs mt-2">Belgian Malinois, 4 years. 6-week Board & Train.</p>
          </div>
          <div class="rounded-2xl overflow-hidden border border-neutral-200 shadow-md md:order-2 order-1">
            <YouTubeEmbed videoId="3B-EavE1l_U" title="Malinois Board & Train Transformation" />
          </div>
        </div>
        <!-- Transformation 3: Golden Retriever -->
        <div class="grid md:grid-cols-[1.5fr_1fr] gap-6 items-center">
          <div class="rounded-2xl overflow-hidden border border-neutral-200 shadow-md">
            <YouTubeEmbed videoId="YkufSLdxWSw" title="Golden Retriever Board & Train Transformation" />
          </div>
          <div class="p-2">
            <span class="inline-flex items-center px-2.5 py-1 rounded-full bg-amber-50 text-amber-600 text-[10px] font-bold uppercase tracking-wide border border-amber-100 mb-3">Leash Pulling + Recall</span>
            <blockquote class="text-lg font-semibold text-neutral-900 leading-relaxed mb-3">
              "Pulled like a truck. Wouldn't listen. Ran away outdoors."
            </blockquote>
            <p class="text-neutral-500 text-sm leading-relaxed mb-3">A young male Golden who was impossible on leash and had zero recall. Let him off and he was gone. Every walk was a fight.</p>
            <p class="text-k9-orange font-semibold text-sm">Now walks on a loose leash and recalls reliably off-leash.</p>
            <p class="text-neutral-400 text-xs mt-2">Golden Retriever, young male. Board & Train.</p>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- SOCIAL PROOF -->
  <section class="py-16 sm:py-24 bg-neutral-50 border-y border-neutral-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Board & Train Results</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900">
          The dogs other trainers gave up on
        </h2>
        <p class="mt-4 text-neutral-500 max-w-2xl mx-auto">Real reviews from real board & train clients. Every one of these dogs came to us after something else failed.</p>
      </div>

      <!-- Google Reviews -->
      <div class="mb-16">
        <div class="flex items-center justify-center gap-2 mb-8">
          <svg class="w-5 h-5" viewBox="0 0 24 24">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" />
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
          </svg>
          <h3 class="text-sm font-bold uppercase tracking-wide text-neutral-500">Google Reviews</h3>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {[
            { initial: 'H', bg: 'bg-purple-500', issue: 'Reactivity + recall', headline: 'I\'d give 6 stars if I could', text: 'Before we brought Simba in I saw all the 5 star ratings and thought this is too good to be true. Well it\'s not. Simba is a rescue hound that was not house trained, pulled on his leash, went nuts around other dogs and ran away any time you let him off leash. After two weeks he comes instantly when called and sits when other dogs come by. We honestly cannot believe he is the same dog.', name: 'Hugh M.', detail: 'Hound rescue · 2 week board and train', when: '3 months ago' },
            { initial: 'A', bg: 'bg-amber-500', issue: 'Separation anxiety', headline: 'Board and train changed our lives', text: 'Our cockapoo\'s anxiety was out of control after relocating to Toronto. Could not leave him alone at home. After 4 weeks he is a much calmer and happier version of himself. Walking at heel, crate trained, and situations we used to avoid are now enjoyable. Throughout the program we received weekly updates with photos. Best investment we could have made.', name: 'Annie & Sam', detail: 'Cockapoo · 4 week board and train', when: '2 months ago' },
            { initial: 'G', bg: 'bg-blue-500', issue: 'Resource guarding', headline: 'Came home a completely different dog', text: 'My mini goldendoodle only listened if there was a treat involved. Poor recall, reactive, anxious, resource guarding. After one month board and train he came home a completely different dog. Calmer, happier, so much more confident. Listens to all commands and consistently looks to me for direction.', name: 'Greg M.', detail: 'Mini Goldendoodle · Board and train', when: '5 weeks ago' },
            { initial: 'I', bg: 'bg-emerald-500', issue: 'Leash pulling', headline: 'After two years and multiple trainers', text: 'Struggled for almost two years with multiple trainers across Toronto and the GTA. Nobody could properly train our Husky. Anesh did what felt almost impossible. Sky is extremely well behaved, listens perfectly, walks without pulling. We still send him for refreshers because Anesh is always accommodating.', name: 'Inderpal O.', detail: 'Husky · Board and train + refreshers', when: '1 month ago' },
            { initial: 'S', bg: 'bg-orange-500', issue: 'Aggression', headline: 'What a difference', text: 'Had my 1 year old border collie mix checked in for 1 month due to obedience issues and extreme aggression towards strangers. Anesh came to our home to pick him up, very professional and knowledgeable. His obedience is now 100% better and his aggression is now limited to just looking at strangers, minimal to no barking. I feel that he is much more relaxed and happier.', name: 'S. Indrawes', detail: 'Border Collie mix · 1 month board and train', when: '3 months ago' },
            { initial: 'F', bg: 'bg-teal-500', issue: 'General obedience', headline: 'Outstanding. the follow up is terrific', text: 'Outstanding board and train by professionals who care. The follow up is terrific as well. Our bully stayed with K9 for a month. She and all of us learned so much. Highly recommend.', name: 'Franklin C.', detail: 'Bully · 1 month board and train', when: '2 months ago' },
            { initial: 'W', bg: 'bg-rose-500', issue: 'Settling + manners', headline: 'Able to settle, walk calmly, better manners', text: 'Highly recommend. Our 9 month old golden retriever came home able to settle in the house, walk calmly, and show noticeably better manners. The ongoing support after returning home has been genuinely valuable.', name: 'Will C.', detail: 'Golden Retriever · Board and train', when: '4 months ago' },
            { initial: 'K', bg: 'bg-indigo-500', issue: 'Barking + hyperactivity', headline: 'Very well behaved since their training', text: 'Had an amazing experience with K9 Academy. Such wonderful kind staff that did a great job with my less than 2 year wild dog. He has been very well behaved since their training. Thank You!', name: 'KayLee B.', detail: 'Mixed · Board and train', when: '4 months ago' },
            { initial: 'S', bg: 'bg-pink-500', issue: 'Fear + nervousness', headline: 'Could not be happier', text: 'All of the trainers are so friendly and knowledgeable. We did the 4 week board and train with our dog and could not be happier!', name: 'Sian L.', detail: '4 week board and train', when: '4 months ago' },
          ].map((t) => (
            <div class="bg-white rounded-2xl p-6 border border-neutral-200/60 flex flex-col hover:shadow-md transition-shadow">
              <div class="flex items-start justify-between gap-3 mb-4">
                <div class="flex items-center gap-3 min-w-0">
                  <div class={`w-10 h-10 rounded-full ${t.bg} flex items-center justify-center text-white font-bold flex-shrink-0`}>{t.initial}</div>
                  <div class="min-w-0">
                    <p class="font-semibold text-neutral-900 text-sm leading-tight truncate">{t.name}</p>
                    <p class="text-xs text-neutral-400">{t.when}</p>
                  </div>
                </div>
                <span class="inline-flex items-center px-2 py-1 rounded-full bg-k9-orange/10 text-k9-orange text-[10px] font-bold uppercase tracking-wide flex-shrink-0">{t.issue}</span>
              </div>
              <div class="flex items-center gap-0.5 mb-3">
                {[1,2,3,4,5].map(() => (
                  <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                ))}
              </div>
              <h3 class="text-base font-bold text-neutral-900 mb-2">{t.headline}</h3>
