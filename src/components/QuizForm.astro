---
interface Props {
  puppy?: boolean;
}
const { puppy = false } = Astro.props;
---

<section id="quiz" class="py-16 sm:py-20 bg-neutral-950 border-y border-white/5" data-puppy-mode={puppy ? 'true' : 'false'}>
  <div class="max-w-2xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-10">
      <p class="text-k9-orange font-semibold text-xs tracking-widest uppercase mb-3">{puppy ? 'Free Puppy Assessment' : 'Free Behaviour Assessment'}</p>
      <h2 class="text-2xl sm:text-3xl font-extrabold text-white leading-tight">
        {puppy ? 'How does your puppy really score?' : 'How does your dog really score?'}
      </h2>
      <p class="mt-3 text-neutral-500 text-sm">{puppy ? '5 quick questions. Get your puppy\'s score by email.' : '7 quick questions. Instant results. Takes 30 seconds.'}</p>
    </div>

    <div id="quiz-container">

      <!-- Step 1: Challenge selector (both paths) -->
      <div class="quiz-step" data-step="1">
        <div class="flex items-center justify-between mb-6">
          <p class="text-neutral-500 text-xs font-medium">1 / 7</p>
          <div class="flex-1 mx-4 h-1 bg-white/10 rounded-full overflow-hidden"><div class="h-full bg-k9-orange rounded-full" style="width:14.3%"></div></div>
        </div>
        <h3 class="text-lg font-bold text-white text-center mb-6">What best describes your situation?</h3>
        <div class="grid gap-3">
          {[
            { val: 'leash', label: 'Pulling on leash' },
            { val: 'reactivity', label: 'Reactivity to dogs or people' },
            { val: 'recall', label: 'Won\'t come when called' },
            { val: 'separation', label: 'Can\'t be left alone' },
            { val: 'settling', label: 'Can\'t settle or relax at home' },
            { val: 'aggression', label: 'Aggression toward people or dogs' },
            { val: 'general', label: 'General obedience — needs a tune-up' },
            { val: 'puppy', label: 'Just got a puppy' },
          ].map((opt) => (
            <button type="button" class="quiz-option group flex items-center justify-center px-4 py-4 rounded-xl border border-white/10 bg-white/5 text-center hover:border-k9-orange/50 hover:bg-k9-orange/5 transition-all" data-field="challenge" data-value={opt.val}>
              <span class="text-sm font-medium text-neutral-300 group-hover:text-white transition-colors">{opt.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- ═══════════════════════════════════ -->
      <!-- ADULT PATH: Steps 2-7              -->
      <!-- ═══════════════════════════════════ -->

      <!-- Adult Step 2: Leash -->
      <div class="quiz-step hidden" data-step="2">
        <div class="flex items-center justify-between mb-6">
          <p class="text-neutral-500 text-xs font-medium">2 / 7</p>
          <div class="flex-1 mx-4 h-1 bg-white/10 rounded-full overflow-hidden"><div class="h-full bg-k9-orange rounded-full" style="width:28.6%"></div></div>
        </div>
        <h3 class="text-lg font-bold text-white text-center mb-6">Does your dog pull on leash?</h3>
        <div class="grid gap-3">
          {[
            { val: '3', label: 'Rarely — walks nicely most of the time' },
            { val: '2', label: 'Sometimes — depends on distractions' },
            { val: '1', label: 'Constantly — every single walk' },
          ].map((opt) => (
            <button type="button" class="quiz-option group flex items-center justify-center px-4 py-4 rounded-xl border border-white/10 bg-white/5 text-center hover:border-k9-orange/50 hover:bg-k9-orange/5 transition-all" data-field="leash" data-value={opt.val}>
              <span class="text-sm font-medium text-neutral-300 group-hover:text-white transition-colors">{opt.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Adult Step 3: Reactivity -->
      <div class="quiz-step hidden" data-step="3">
        <div class="flex items-center justify-between mb-6">
          <p class="text-neutral-500 text-xs font-medium">3 / 7</p>
          <div class="flex-1 mx-4 h-1 bg-white/10 rounded-full overflow-hidden"><div class="h-full bg-k9-orange rounded-full" style="width:42.9%"></div></div>
        </div>
        <h3 class="text-lg font-bold text-white text-center mb-6">How does your dog react to other dogs on walks?</h3>
        <div class="grid gap-3">
          {[
            { val: '3', label: 'Ignores them or stays calm' },
            { val: '2', label: 'Stares, pulls, or sometimes barks' },
            { val: '1', label: 'Lunges, barks, or completely loses it' },
          ].map((opt) => (
            <button type="button" class="quiz-option group flex items-center justify-center px-4 py-4 rounded-xl border border-white/10 bg-white/5 text-center hover:border-k9-orange/50 hover:bg-k9-orange/5 transition-all" data-field="reactivity" data-value={opt.val}>
              <span class="text-sm font-medium text-neutral-300 group-hover:text-white transition-colors">{opt.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Adult Step 4: Recall -->
      <div class="quiz-step hidden" data-step="4">
        <div class="flex items-center justify-between mb-6">
          <p class="text-neutral-500 text-xs font-medium">4 / 7</p>
          <div class="flex-1 mx-4 h-1 bg-white/10 rounded-full overflow-hidden"><div class="h-full bg-k9-orange rounded-full" style="width:57.1%"></div></div>
        </div>
        <h3 class="text-lg font-bold text-white text-center mb-6">Does your dog come when called off leash?</h3>
        <div class="grid gap-3">
          {[
            { val: '3', label: 'Yes, almost every time' },
            { val: '2', label: 'Only when there are no distractions' },
            { val: '1', label: 'Almost never — I don\'t trust it' },
          ].map((opt) => (
            <button type="button" class="quiz-option group flex items-center justify-center px-4 py-4 rounded-xl border border-white/10 bg-white/5 text-center hover:border-k9-orange/50 hover:bg-k9-orange/5 transition-all" data-field="recall" data-value={opt.val}>
              <span class="text-sm font-medium text-neutral-300 group-hover:text-white transition-colors">{opt.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Adult Step 5: Alone -->
      <div class="quiz-step hidden" data-step="5">
        <div class="flex items-center justify-between mb-6">
          <p class="text-neutral-500 text-xs font-medium">5 / 7</p>
          <div class="flex-1 mx-4 h-1 bg-white/10 rounded-full overflow-hidden"><div class="h-full bg-k9-orange rounded-full" style="width:71.4%"></div></div>
        </div>
        <h3 class="text-lg font-bold text-white text-center mb-6">Can you leave your dog alone for 2+ hours?</h3>
        <div class="grid gap-3">
          {[
            { val: '3', label: 'Yes, no issues at all' },
            { val: '2', label: 'Some whining or pacing' },
            { val: '1', label: 'Destroys things, howls, or panics' },
          ].map((opt) => (
            <button type="button" class="quiz-option group flex items-center justify-center px-4 py-4 rounded-xl border border-white/10 bg-white/5 text-center hover:border-k9-orange/50 hover:bg-k9-orange/5 transition-all" data-field="alone" data-value={opt.val}>
              <span class="text-sm font-medium text-neutral-300 group-hover:text-white transition-colors">{opt.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Adult Step 6: Settling -->
      <div class="quiz-step hidden" data-step="6">
        <div class="flex items-center justify-between mb-6">
          <p class="text-neutral-500 text-xs font-medium">6 / 7</p>
          <div class="flex-1 mx-4 h-1 bg-white/10 rounded-full overflow-hidden"><div class="h-full bg-k9-orange rounded-full" style="width:85.7%"></div></div>
        </div>
        <h3 class="text-lg font-bold text-white text-center mb-6">Does your dog settle at home without being told?</h3>
        <div class="grid gap-3">
          {[
            { val: '3', label: 'Yes — relaxes on their own' },
            { val: '2', label: 'Sometimes, but often restless or needy' },
            { val: '1', label: 'Rarely — always pacing, barking, or following me' },
          ].map((opt) => (
            <button type="button" class="quiz-option group flex items-center justify-center px-4 py-4 rounded-xl border border-white/10 bg-white/5 text-center hover:border-k9-orange/50 hover:bg-k9-orange/5 transition-all" data-field="settling" data-value={opt.val}>
              <span class="text-sm font-medium text-neutral-300 group-hover:text-white transition-colors">{opt.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Adult Step 7: Aggression -->
      <div class="quiz-step hidden" data-step="7">
        <div class="flex items-center justify-between mb-6">
          <p class="text-neutral-500 text-xs font-medium">7 / 7</p>
          <div class="flex-1 mx-4 h-1 bg-white/10 rounded-full overflow-hidden"><div class="h-full bg-k9-orange rounded-full" style="width:100%"></div></div>
        </div>
        <h3 class="text-lg font-bold text-white text-center mb-6">Has your dog shown any aggression toward people or dogs?</h3>
        <div class="grid gap-3">
          {[
            { val: '3', label: 'Never' },
            { val: '2', label: 'Growling or stiffening' },
            { val: '1', label: 'Snapping, biting, or lunging to make contact' },
          ].map((opt) => (
            <button type="button" class="quiz-option group flex items-center justify-center px-4 py-4 rounded-xl border border-white/10 bg-white/5 text-center hover:border-k9-orange/50 hover:bg-k9-orange/5 transition-all" data-field="aggression" data-value={opt.val}>
              <span class="text-sm font-medium text-neutral-300 group-hover:text-white transition-colors">{opt.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- ═══════════════════════════════════ -->
      <!-- PUPPY PATH: Steps p2-p7            -->
      <!-- ═══════════════════════════════════ -->

      <!-- Puppy Step 2: Age (not scored) -->
      <div class="quiz-step hidden" data-step="p2">
        <div class="flex items-center justify-between mb-6">
          <p class="text-neutral-500 text-xs font-medium">2 / 7</p>
          <div class="flex-1 mx-4 h-1 bg-white/10 rounded-full overflow-hidden"><div class="h-full bg-k9-orange rounded-full" style="width:28.6%"></div></div>
        </div>
        <h3 class="text-lg font-bold text-white text-center mb-6">How old is your puppy?</h3>
        <div class="grid gap-3">
          {[
            { val: '8to12w', label: '8 - 12 weeks' },
            { val: '3to4m', label: '3 - 4 months' },
            { val: '4to5m', label: '4 - 5.5 months' },
          ].map((opt) => (
            <button type="button" class="quiz-option group flex items-center justify-center px-4 py-4 rounded-xl border border-white/10 bg-white/5 text-center hover:border-k9-orange/50 hover:bg-k9-orange/5 transition-all" data-field="puppy_age" data-value={opt.val}>
              <span class="text-sm font-medium text-neutral-300 group-hover:text-white transition-colors">{opt.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Puppy Step 3: Nipping -->
      <div class="quiz-step hidden" data-step="p3">
        <div class="flex items-center justify-between mb-6">
          <p class="text-neutral-500 text-xs font-medium">3 / 7</p>
          <div class="flex-1 mx-4 h-1 bg-white/10 rounded-full overflow-hidden"><div class="h-full bg-k9-orange rounded-full" style="width:42.9%"></div></div>
        </div>
        <h3 class="text-lg font-bold text-white text-center mb-6">Does your puppy nip or bite?</h3>
        <div class="grid gap-3">
          {[
            { val: '3', label: 'Rarely' },
            { val: '2', label: 'Sometimes — mostly during play' },
            { val: '1', label: 'Constantly — hands, feet, furniture' },
          ].map((opt) => (
            <button type="button" class="quiz-option group flex items-center justify-center px-4 py-4 rounded-xl border border-white/10 bg-white/5 text-center hover:border-k9-orange/50 hover:bg-k9-orange/5 transition-all" data-field="nipping" data-value={opt.val}>
              <span class="text-sm font-medium text-neutral-300 group-hover:text-white transition-colors">{opt.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Puppy Step 4: Potty -->
      <div class="quiz-step hidden" data-step="p4">
        <div class="flex items-center justify-between mb-6">
          <p class="text-neutral-500 text-xs font-medium">4 / 7</p>
          <div class="flex-1 mx-4 h-1 bg-white/10 rounded-full overflow-hidden"><div class="h-full bg-k9-orange rounded-full" style="width:57.1%"></div></div>
        </div>
        <h3 class="text-lg font-bold text-white text-center mb-6">Is your puppy potty trained?</h3>
        <div class="grid gap-3">
          {[
            { val: '3', label: 'Yes, fully' },
            { val: '2', label: 'Getting there — occasional accidents' },
            { val: '1', label: 'Not at all' },
          ].map((opt) => (
            <button type="button" class="quiz-option group flex items-center justify-center px-4 py-4 rounded-xl border border-white/10 bg-white/5 text-center hover:border-k9-orange/50 hover:bg-k9-orange/5 transition-all" data-field="potty" data-value={opt.val}>
              <span class="text-sm font-medium text-neutral-300 group-hover:text-white transition-colors">{opt.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Puppy Step 5: Crate -->
      <div class="quiz-step hidden" data-step="p5">
        <div class="flex items-center justify-between mb-6">
          <p class="text-neutral-500 text-xs font-medium">5 / 7</p>
          <div class="flex-1 mx-4 h-1 bg-white/10 rounded-full overflow-hidden"><div class="h-full bg-k9-orange rounded-full" style="width:71.4%"></div></div>
        </div>
        <h3 class="text-lg font-bold text-white text-center mb-6">Can your puppy settle in a crate?</h3>
        <div class="grid gap-3">
          {[
            { val: '3', label: 'Yes, sleeps calmly' },
            { val: '2', label: 'With some fussing' },
            { val: '1', label: 'Howls, panics, or refuses' },
          ].map((opt) => (
            <button type="button" class="quiz-option group flex items-center justify-center px-4 py-4 rounded-xl border border-white/10 bg-white/5 text-center hover:border-k9-orange/50 hover:bg-k9-orange/5 transition-all" data-field="crate" data-value={opt.val}>
              <span class="text-sm font-medium text-neutral-300 group-hover:text-white transition-colors">{opt.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Puppy Step 6: Recall -->
      <div class="quiz-step hidden" data-step="p6">
        <div class="flex items-center justify-between mb-6">
          <p class="text-neutral-500 text-xs font-medium">6 / 7</p>
          <div class="flex-1 mx-4 h-1 bg-white/10 rounded-full overflow-hidden"><div class="h-full bg-k9-orange rounded-full" style="width:85.7%"></div></div>
        </div>
        <h3 class="text-lg font-bold text-white text-center mb-6">Does your puppy come when called?</h3>
        <div class="grid gap-3">
          {[
            { val: '3', label: 'Usually yes' },
            { val: '2', label: 'Only when no distractions' },
            { val: '1', label: 'Almost never' },
          ].map((opt) => (
            <button type="button" class="quiz-option group flex items-center justify-center px-4 py-4 rounded-xl border border-white/10 bg-white/5 text-center hover:border-k9-orange/50 hover:bg-k9-orange/5 transition-all" data-field="puppy_recall" data-value={opt.val}>
              <span class="text-sm font-medium text-neutral-300 group-hover:text-white transition-colors">{opt.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Puppy Step 7: Socialization -->
      <div class="quiz-step hidden" data-step="p7">
        <div class="flex items-center justify-between mb-6">
          <p class="text-neutral-500 text-xs font-medium">7 / 7</p>
          <div class="flex-1 mx-4 h-1 bg-white/10 rounded-full overflow-hidden"><div class="h-full bg-k9-orange rounded-full" style="width:100%"></div></div>
        </div>
        <h3 class="text-lg font-bold text-white text-center mb-6">How is your puppy around new people, dogs, or environments?</h3>
        <div class="grid gap-3">
          {[
            { val: '3', label: 'Confident and curious' },
            { val: '2', label: 'A bit cautious but warms up' },
            { val: '1', label: 'Very fearful, hides, or overly excitable' },
          ].map((opt) => (
            <button type="button" class="quiz-option group flex items-center justify-center px-4 py-4 rounded-xl border border-white/10 bg-white/5 text-center hover:border-k9-orange/50 hover:bg-k9-orange/5 transition-all" data-field="socialization" data-value={opt.val}>
              <span class="text-sm font-medium text-neutral-300 group-hover:text-white transition-colors">{opt.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- ═══════════════════════════════════ -->
      <!-- Results — email gate               -->
      <!-- ═══════════════════════════════════ -->
      <div class="quiz-step hidden" data-step="result">
        <div class="text-center mb-6">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-k9-orange/10 mb-4">
            <svg class="w-7 h-7 text-k9-orange" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Your results are ready</h3>
          <p class="text-neutral-400 text-sm max-w-sm mx-auto">Enter your email and we'll send your full score, weakest areas, and what to do about each one.</p>
        </div>

        <form id="quiz-form" class="space-y-3 max-w-sm mx-auto">
          <input type="text" name="quiz_name" required placeholder="Your name"
            class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-k9-orange/30 focus:border-k9-orange transition text-sm" />
          <input type="email" name="quiz_email" required placeholder="Email"
            class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-k9-orange/30 focus:border-k9-orange transition text-sm" />
          <button type="submit" id="quiz-submit"
            class="w-full px-6 py-3.5 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30">
            Send My Results
          </button>
          <p class="text-neutral-600 text-xs text-center">No spam. Just your score + actionable tips.</p>
        </form>
        <div class="mt-5 text-center">
          <a href="#contact" class="text-neutral-400 hover:text-white text-sm transition-colors">
            or skip straight to talking to a trainer →
          </a>
        </div>
      </div>

      <!-- Thank you (after email submit) -->
      <div class="quiz-step hidden" data-step="thanks">
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-k9-orange/10 mb-5">
            <svg class="w-8 h-8 text-k9-orange" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Check your inbox</h3>
          <p class="text-neutral-400 text-sm mb-8 max-w-md mx-auto">We're sending your full behaviour breakdown with specific tips for your dog's weakest areas.</p>
          <a href="#contact"
            class="inline-flex items-center px-7 py-3.5 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30">
            Talk to a Trainer
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const quizData: Record<string, string> = {};
  const scores: Record<string, number> = {};
  let stepIndex = 0;

  // Check if puppy mode is set via data attribute
  const quizSection = document.getElementById('quiz');
  const isPuppyMode = quizSection?.dataset.puppyMode === 'true';
  if (isPuppyMode) {
    quizData.challenge = 'puppy';
    // Hide step 1, start at puppy step p2
    const step1 = document.querySelector('.quiz-step[data-step="1"]');
    if (step1) step1.classList.add('hidden');
    const p2 = document.querySelector('.quiz-step[data-step="p2"]');
    if (p2) p2.classList.remove('hidden');
    stepIndex = 1; // Start at index 1 in puppySteps array (which is 'p2')
  }

  const adultLabels: Record<string, string> = {
    leash: 'Leash walking',
    reactivity: 'Reactivity',
    recall: 'Off-leash recall',
    alone: 'Separation tolerance',
    settling: 'Settling at home',
    aggression: 'Aggression',
  };

  const puppyLabels: Record<string, string> = {
    nipping: 'Nipping / Biting',
    potty: 'Potty Training',
    crate: 'Crate Training',
    puppy_recall: 'Coming When Called',
    socialization: 'Socialization',
  };

  const adultSteps = ['1', '2', '3', '4', '5', '6', '7', 'result'];
  const puppySteps = ['1', 'p2', 'p3', 'p4', 'p5', 'p6', 'p7', 'result'];

  function getPath(): string[] {
    return quizData.challenge === 'puppy' ? puppySteps : adultSteps;
  }

  function getLabels(): Record<string, string> {
    return quizData.challenge === 'puppy' ? puppyLabels : adultLabels;
  }

  function showStep(step: string) {
    document.querySelectorAll('.quiz-step').forEach(el => el.classList.add('hidden'));
    const target = document.querySelector(`.quiz-step[data-step="${step}"]`);
    if (target) target.classList.remove('hidden');
  }

  document.querySelectorAll('.quiz-option').forEach(btn => {
    btn.addEventListener('click', () => {
      const field = (btn as HTMLElement).dataset.field!;
      const value = (btn as HTMLElement).dataset.value!;
      quizData[field] = value;

      // Store numeric scores (1-3)
      const numVal = parseInt(value, 10);
      if (!isNaN(numVal) && numVal >= 1 && numVal <= 3) {
        scores[field] = numVal;
      }

      btn.classList.add('border-k9-orange', 'bg-k9-orange/10');

      setTimeout(() => {
        const path = getPath();
        stepIndex++;
        if (stepIndex < path.length) {
          showStep(path[stepIndex]);
        }
      }, 200);
    });
  });

  document.getElementById('quiz-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const name = (form.querySelector('[name="quiz_name"]') as HTMLInputElement).value;
    const email = (form.querySelector('[name="quiz_email"]') as HTMLInputElement).value;

    const btn = document.getElementById('quiz-submit') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Sending...';

    const isPuppy = quizData.challenge === 'puppy';
    const labels = getLabels();
    const total = Object.values(scores).reduce((a, b) => a + b, 0);
    const maxScore = isPuppy ? 15 : 18;
    const scoreBreakdown = Object.entries(scores)
      .map(([k, v]) => `${labels[k] || k}: ${v}/3`)
      .join(', ');

    showStep('thanks');

    try {
      await fetch('/api/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name,
          email,
          phone: '',
          service: 'behaviour_quiz',
          message: `Behaviour quiz score: ${total}/${maxScore}. ${scoreBreakdown}`,
          dog_info: isPuppy ? `Puppy (${quizData.puppy_age || 'unknown age'})` : '',
          quiz_scores: scores,
          quiz_total: total,
          quiz_path: isPuppy ? 'puppy' : 'adult',
        }),
      });
    } catch {}

    try {
      const _learnq = (window as any)._learnq || [];
      const identifyData: Record<string, any> = {
        '$email': email,
        '$first_name': name.split(' ')[0] || '',
        'Source': 'Behaviour Quiz',
        'Quiz Score': total,
        'Quiz Path': isPuppy ? 'puppy' : 'adult',
      };
      const trackData: Record<string, any> = {
        'Name': name,
        'Email': email,
        'Score': total,
        'Path': isPuppy ? 'puppy' : 'adult',
      };

      if (isPuppy) {
        identifyData['Quiz Nipping'] = scores.nipping;
        identifyData['Quiz Potty'] = scores.potty;
        identifyData['Quiz Crate'] = scores.crate;
        identifyData['Quiz Puppy Recall'] = scores.puppy_recall;
        identifyData['Quiz Socialization'] = scores.socialization;
        identifyData['Puppy Age'] = quizData.puppy_age;
        trackData['Nipping'] = scores.nipping;
        trackData['Potty'] = scores.potty;
        trackData['Crate'] = scores.crate;
        trackData['Puppy Recall'] = scores.puppy_recall;
        trackData['Socialization'] = scores.socialization;
        trackData['Puppy Age'] = quizData.puppy_age;
      } else {
        identifyData['Quiz Leash'] = scores.leash;
        identifyData['Quiz Reactivity'] = scores.reactivity;
        identifyData['Quiz Recall'] = scores.recall;
        identifyData['Quiz Alone'] = scores.alone;
        identifyData['Quiz Settling'] = scores.settling;
        identifyData['Quiz Aggression'] = scores.aggression;
        trackData['Leash'] = scores.leash;
        trackData['Reactivity'] = scores.reactivity;
        trackData['Recall'] = scores.recall;
        trackData['Alone'] = scores.alone;
        trackData['Settling'] = scores.settling;
        trackData['Aggression'] = scores.aggression;
      }

      _learnq.push(['identify', identifyData]);
      _learnq.push(['track', 'Behaviour Quiz Completed', trackData]);
    } catch {}
  });
</script>
