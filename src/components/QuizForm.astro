---
---

<section id="quiz" class="py-16 sm:py-20 bg-neutral-950 border-y border-white/5">
  <div class="max-w-2xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-10">
      <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Not sure where to start?</p>
      <h2 class="text-2xl sm:text-3xl font-extrabold text-white">
        Find out what your dog needs — in 30 seconds
      </h2>
    </div>

    <div id="quiz-container">
      <!-- Step 1: Challenge -->
      <div class="quiz-step" data-step="1">
        <p class="text-neutral-400 text-sm font-medium mb-4 text-center">Step 1 of 4</p>
        <h3 class="text-lg font-bold text-white text-center mb-6">What's your biggest challenge right now?</h3>
        <div class="grid grid-cols-2 gap-3">
          {[
            { val: 'pulling', label: 'Pulling on leash', icon: '🐕' },
            { val: 'reactivity', label: 'Reactivity / aggression', icon: '⚡' },
            { val: 'recall', label: 'Won\'t listen off leash', icon: '🏃' },
            { val: 'anxiety', label: 'Separation anxiety', icon: '🏠' },
            { val: 'barking', label: 'Barking', icon: '🔊' },
            { val: 'puppy', label: 'Just got a puppy', icon: '🐶' },
            { val: 'obedience', label: 'General obedience', icon: '🎓' },
            { val: 'other', label: 'Something else', icon: '❓' },
          ].map((opt) => (
            <button
              type="button"
              class="quiz-option group flex items-center gap-3 px-4 py-3.5 rounded-xl border border-white/10 bg-white/5 text-left hover:border-k9-orange/50 hover:bg-k9-orange/5 transition-all"
              data-field="challenge"
              data-value={opt.val}
            >
              <span class="text-lg flex-shrink-0">{opt.icon}</span>
              <span class="text-sm font-medium text-neutral-300 group-hover:text-white transition-colors">{opt.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Step 2: Age -->
      <div class="quiz-step hidden" data-step="2">
        <p class="text-neutral-400 text-sm font-medium mb-4 text-center">Step 2 of 4</p>
        <h3 class="text-lg font-bold text-white text-center mb-6">How old is your dog?</h3>
        <div class="grid grid-cols-2 gap-3">
          {[
            { val: 'under6m', label: 'Under 6 months' },
            { val: '6to12m', label: '6–12 months' },
            { val: '1to3y', label: '1–3 years' },
            { val: '3plus', label: '3+ years' },
          ].map((opt) => (
            <button
              type="button"
              class="quiz-option group flex items-center justify-center px-4 py-4 rounded-xl border border-white/10 bg-white/5 text-center hover:border-k9-orange/50 hover:bg-k9-orange/5 transition-all"
              data-field="dog_age"
              data-value={opt.val}
            >
              <span class="text-sm font-medium text-neutral-300 group-hover:text-white transition-colors">{opt.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Step 3: Experience -->
      <div class="quiz-step hidden" data-step="3">
        <p class="text-neutral-400 text-sm font-medium mb-4 text-center">Step 3 of 4</p>
        <h3 class="text-lg font-bold text-white text-center mb-6">Have you done any training before?</h3>
        <div class="grid gap-3">
          {[
            { val: 'none', label: 'No, this is our first time' },
            { val: 'failed', label: 'Yes, but it didn\'t stick' },
            { val: 'some', label: 'Yes, with some results' },
          ].map((opt) => (
            <button
              type="button"
              class="quiz-option group flex items-center justify-center px-4 py-4 rounded-xl border border-white/10 bg-white/5 text-center hover:border-k9-orange/50 hover:bg-k9-orange/5 transition-all"
              data-field="experience"
              data-value={opt.val}
            >
              <span class="text-sm font-medium text-neutral-300 group-hover:text-white transition-colors">{opt.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Step 4: Style -->
      <div class="quiz-step hidden" data-step="4">
        <p class="text-neutral-400 text-sm font-medium mb-4 text-center">Step 4 of 4</p>
        <h3 class="text-lg font-bold text-white text-center mb-6">What sounds more like you?</h3>
        <div class="grid gap-3">
          {[
            { val: 'self', label: 'I want to learn to train my dog myself' },
            { val: 'done_for_me', label: 'I need someone to train my dog for me' },
            { val: 'unsure', label: 'Not sure yet — help me decide' },
          ].map((opt) => (
            <button
              type="button"
              class="quiz-option group flex items-center justify-center px-4 py-4 rounded-xl border border-white/10 bg-white/5 text-center hover:border-k9-orange/50 hover:bg-k9-orange/5 transition-all"
              data-field="style"
              data-value={opt.val}
            >
              <span class="text-sm font-medium text-neutral-300 group-hover:text-white transition-colors">{opt.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Step 5: Contact -->
      <div class="quiz-step hidden" data-step="5">
        <h3 class="text-lg font-bold text-white text-center mb-2">Almost done — where should we send your result?</h3>
        <p class="text-neutral-500 text-sm text-center mb-6">We'll also reach out to help you get started.</p>
        <form id="quiz-form" class="space-y-3">
          <input type="text" name="quiz_name" required placeholder="Your name"
            class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-k9-orange/30 focus:border-k9-orange transition text-sm" />
          <input type="email" name="quiz_email" required placeholder="Email"
            class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-k9-orange/30 focus:border-k9-orange transition text-sm" />
          <input type="tel" name="quiz_phone" required placeholder="Phone"
            class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-k9-orange/30 focus:border-k9-orange transition text-sm" />
          <button type="submit" id="quiz-submit"
            class="w-full px-6 py-3.5 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30">
            See My Recommendation
          </button>
        </form>
      </div>

      <!-- Result -->
      <div class="quiz-step hidden" data-step="result">
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-k9-orange/10 mb-5">
            <svg class="w-8 h-8 text-k9-orange" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">We recommend:</h3>
          <p id="quiz-recommendation" class="text-2xl font-extrabold bg-gradient-to-r from-k9-orange to-amber-400 bg-clip-text text-transparent mb-3"></p>
          <p id="quiz-reason" class="text-neutral-400 text-sm mb-8 max-w-md mx-auto"></p>
          <a id="quiz-cta-link" href="/private-lessons#contact"
            class="inline-flex items-center px-7 py-3.5 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30">
            Get Started
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <p class="text-neutral-600 text-xs mt-4">Check your email — we sent your full recommendation.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const quizData: Record<string, string> = {};
  let currentStep = 1;

  function showStep(step: number | string) {
    document.querySelectorAll('.quiz-step').forEach(el => el.classList.add('hidden'));
    const target = document.querySelector(`.quiz-step[data-step="${step}"]`);
    if (target) target.classList.remove('hidden');
  }

  document.querySelectorAll('.quiz-option').forEach(btn => {
    btn.addEventListener('click', () => {
      const field = (btn as HTMLElement).dataset.field!;
      const value = (btn as HTMLElement).dataset.value!;
      quizData[field] = value;

      // Brief highlight
      btn.classList.add('border-k9-orange', 'bg-k9-orange/10');
      setTimeout(() => {
        currentStep++;
        showStep(currentStep);
      }, 200);
    });
  });

  const programs: Record<string, { name: string; reason: string; link: string }> = {
    puppy: {
      name: 'Puppy Program',
      reason: 'Starting early is the best investment you can make. Our puppy program builds the foundation before bad habits form.',
      link: '/puppy-classes#contact',
    },
    board_train: {
      name: 'Board & Train',
      reason: 'We take your dog for 2–4 weeks and handle the heavy lifting. You get back a transformed dog with a clear maintenance plan.',
      link: '/board-and-train#contact',
    },
    private_behaviour: {
      name: 'Private Training — Behaviour Modification',
      reason: 'Your dog needs focused 1-on-1 work on specific behavioural issues. 8 sessions with a dedicated trainer.',
      link: '/private-lessons#contact',
    },
    private_obedience: {
      name: 'Private Training — Advanced Obedience',
      reason: '6 private sessions to build reliable obedience, loose leash walking, and off-leash foundations.',
      link: '/private-lessons#contact',
    },
    group_l1: {
      name: 'Group Classes — Level 1',
      reason: 'Learn alongside your dog in a real-world environment with other dogs. The group setting is the secret — real distractions, real results.',
      link: '/group-classes#contact',
    },
    group_l2: {
      name: 'Group Classes — Level 2',
      reason: 'You have a foundation — now build off-leash reliability and distraction proofing with e-collar work and a graduation hike.',
      link: '/group-classes#contact',
    },
  };

  function getRecommendation(): string {
    const { challenge, dog_age, experience, style } = quizData;

    if (challenge === 'puppy' || dog_age === 'under6m') return 'puppy';
    if (style === 'done_for_me') return 'board_train';
    if (['reactivity', 'anxiety'].includes(challenge) && experience === 'failed') return 'private_behaviour';
    if (['reactivity', 'anxiety'].includes(challenge)) return 'private_behaviour';
    if (challenge === 'barking' || challenge === 'other') return 'private_obedience';
    if (experience === 'some' && challenge === 'recall') return 'group_l2';
    if (style === 'self') return 'group_l1';
    return 'private_obedience';
  }

  document.getElementById('quiz-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const name = (form.querySelector('[name="quiz_name"]') as HTMLInputElement).value;
    const email = (form.querySelector('[name="quiz_email"]') as HTMLInputElement).value;
    const phone = (form.querySelector('[name="quiz_phone"]') as HTMLInputElement).value;

    const submitBtn = document.getElementById('quiz-submit') as HTMLButtonElement;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Loading...';

    const recKey = getRecommendation();
    const rec = programs[recKey];

    // Show result immediately
    document.getElementById('quiz-recommendation')!.textContent = rec.name;
    document.getElementById('quiz-reason')!.textContent = rec.reason;
    (document.getElementById('quiz-cta-link') as HTMLAnchorElement).href = rec.link;
    showStep('result');

    // Send to backend
    try {
      await fetch('/api/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name,
          email,
          phone,
          service: recKey,
          message: `Quiz result: ${rec.name}. Challenge: ${quizData.challenge}, Age: ${quizData.dog_age}, Experience: ${quizData.experience}, Style: ${quizData.style}`,
          dog_info: `Challenge: ${quizData.challenge}`,
        }),
      });
    } catch {
      // Silent — result already shown
    }

    // Klaviyo
    try {
      const _learnq = (window as any)._learnq || [];
      _learnq.push(['identify', {
        '$email': email,
        '$first_name': name.split(' ')[0] || '',
        'Phone': phone,
        'Source': 'Quiz',
        'Quiz Challenge': quizData.challenge,
        'Quiz Dog Age': quizData.dog_age,
        'Quiz Experience': quizData.experience,
        'Quiz Style': quizData.style,
        'Recommended Program': rec.name,
      }]);
      _learnq.push(['track', 'Quiz Completed', {
        'Name': name,
        'Email': email,
        'Challenge': quizData.challenge,
        'Dog Age': quizData.dog_age,
        'Experience': quizData.experience,
        'Style': quizData.style,
        'Recommended Program': rec.name,
      }]);
    } catch {
      // Silent
    }
  });
</script>
