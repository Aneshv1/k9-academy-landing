---
---

<section id="quiz" class="py-16 sm:py-20 bg-neutral-950 border-y border-white/5">
  <div class="max-w-2xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-10">
      <p class="text-k9-orange font-semibold text-xs tracking-widest uppercase mb-3">Free Behaviour Assessment</p>
      <h2 class="text-2xl sm:text-3xl font-extrabold text-white leading-tight">
        How does your dog really score?
      </h2>
      <p class="mt-3 text-neutral-500 text-sm">6 quick questions. Instant results. Takes 30 seconds.</p>
    </div>

    <div id="quiz-container">
      <!-- Q1: Leash -->
      <div class="quiz-step" data-step="1">
        <div class="flex items-center justify-between mb-6">
          <p class="text-neutral-500 text-xs font-medium">1 / 6</p>
          <div class="flex-1 mx-4 h-1 bg-white/10 rounded-full overflow-hidden"><div class="h-full bg-k9-orange rounded-full" style="width:16.6%"></div></div>
        </div>
        <h3 class="text-lg font-bold text-white text-center mb-6">Does your dog pull on leash?</h3>
        <div class="grid gap-3">
          {[
            { val: '3', label: 'Rarely — walks nicely most of the time' },
            { val: '2', label: 'Sometimes — depends on distractions' },
            { val: '1', label: 'Constantly — every single walk' },
          ].map((opt) => (
            <button type="button" class="quiz-option group flex items-center justify-center px-4 py-4 rounded-xl border border-white/10 bg-white/5 text-center hover:border-k9-orange/50 hover:bg-k9-orange/5 transition-all" data-field="leash" data-value={opt.val}>
              <span class="text-sm font-medium text-neutral-300 group-hover:text-white transition-colors">{opt.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Q2: Reactivity -->
      <div class="quiz-step hidden" data-step="2">
        <div class="flex items-center justify-between mb-6">
          <p class="text-neutral-500 text-xs font-medium">2 / 6</p>
          <div class="flex-1 mx-4 h-1 bg-white/10 rounded-full overflow-hidden"><div class="h-full bg-k9-orange rounded-full" style="width:33.3%"></div></div>
        </div>
        <h3 class="text-lg font-bold text-white text-center mb-6">How does your dog react to other dogs on walks?</h3>
        <div class="grid gap-3">
          {[
            { val: '3', label: 'Ignores them or stays calm' },
            { val: '2', label: 'Stares, pulls, or sometimes barks' },
            { val: '1', label: 'Lunges, barks, or completely loses it' },
          ].map((opt) => (
            <button type="button" class="quiz-option group flex items-center justify-center px-4 py-4 rounded-xl border border-white/10 bg-white/5 text-center hover:border-k9-orange/50 hover:bg-k9-orange/5 transition-all" data-field="reactivity" data-value={opt.val}>
              <span class="text-sm font-medium text-neutral-300 group-hover:text-white transition-colors">{opt.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Q3: Recall -->
      <div class="quiz-step hidden" data-step="3">
        <div class="flex items-center justify-between mb-6">
          <p class="text-neutral-500 text-xs font-medium">3 / 6</p>
          <div class="flex-1 mx-4 h-1 bg-white/10 rounded-full overflow-hidden"><div class="h-full bg-k9-orange rounded-full" style="width:50%"></div></div>
        </div>
        <h3 class="text-lg font-bold text-white text-center mb-6">Does your dog come when called off leash?</h3>
        <div class="grid gap-3">
          {[
            { val: '3', label: 'Yes, almost every time' },
            { val: '2', label: 'Only when there are no distractions' },
            { val: '1', label: 'Almost never — I don\'t trust it' },
          ].map((opt) => (
            <button type="button" class="quiz-option group flex items-center justify-center px-4 py-4 rounded-xl border border-white/10 bg-white/5 text-center hover:border-k9-orange/50 hover:bg-k9-orange/5 transition-all" data-field="recall" data-value={opt.val}>
              <span class="text-sm font-medium text-neutral-300 group-hover:text-white transition-colors">{opt.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Q4: Alone -->
      <div class="quiz-step hidden" data-step="4">
        <div class="flex items-center justify-between mb-6">
          <p class="text-neutral-500 text-xs font-medium">4 / 6</p>
          <div class="flex-1 mx-4 h-1 bg-white/10 rounded-full overflow-hidden"><div class="h-full bg-k9-orange rounded-full" style="width:66.6%"></div></div>
        </div>
        <h3 class="text-lg font-bold text-white text-center mb-6">Can you leave your dog alone for 2+ hours?</h3>
        <div class="grid gap-3">
          {[
            { val: '3', label: 'Yes, no issues at all' },
            { val: '2', label: 'Some whining or pacing' },
            { val: '1', label: 'Destroys things, howls, or panics' },
          ].map((opt) => (
            <button type="button" class="quiz-option group flex items-center justify-center px-4 py-4 rounded-xl border border-white/10 bg-white/5 text-center hover:border-k9-orange/50 hover:bg-k9-orange/5 transition-all" data-field="alone" data-value={opt.val}>
              <span class="text-sm font-medium text-neutral-300 group-hover:text-white transition-colors">{opt.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Q5: Settling -->
      <div class="quiz-step hidden" data-step="5">
        <div class="flex items-center justify-between mb-6">
          <p class="text-neutral-500 text-xs font-medium">5 / 6</p>
          <div class="flex-1 mx-4 h-1 bg-white/10 rounded-full overflow-hidden"><div class="h-full bg-k9-orange rounded-full" style="width:83.3%"></div></div>
        </div>
        <h3 class="text-lg font-bold text-white text-center mb-6">Does your dog settle at home without being told?</h3>
        <div class="grid gap-3">
          {[
            { val: '3', label: 'Yes — relaxes on their own' },
            { val: '2', label: 'Sometimes, but often restless or needy' },
            { val: '1', label: 'Rarely — always pacing, barking, or following me' },
          ].map((opt) => (
            <button type="button" class="quiz-option group flex items-center justify-center px-4 py-4 rounded-xl border border-white/10 bg-white/5 text-center hover:border-k9-orange/50 hover:bg-k9-orange/5 transition-all" data-field="settling" data-value={opt.val}>
              <span class="text-sm font-medium text-neutral-300 group-hover:text-white transition-colors">{opt.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Q6: Aggression -->
      <div class="quiz-step hidden" data-step="6">
        <div class="flex items-center justify-between mb-6">
          <p class="text-neutral-500 text-xs font-medium">6 / 6</p>
          <div class="flex-1 mx-4 h-1 bg-white/10 rounded-full overflow-hidden"><div class="h-full bg-k9-orange rounded-full" style="width:100%"></div></div>
        </div>
        <h3 class="text-lg font-bold text-white text-center mb-6">Has your dog shown any aggression toward people or dogs?</h3>
        <div class="grid gap-3">
          {[
            { val: '3', label: 'Never' },
            { val: '2', label: 'Growling or stiffening' },
            { val: '1', label: 'Snapping, biting, or lunging to make contact' },
          ].map((opt) => (
            <button type="button" class="quiz-option group flex items-center justify-center px-4 py-4 rounded-xl border border-white/10 bg-white/5 text-center hover:border-k9-orange/50 hover:bg-k9-orange/5 transition-all" data-field="aggression" data-value={opt.val}>
              <span class="text-sm font-medium text-neutral-300 group-hover:text-white transition-colors">{opt.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Results — email gate -->
      <div class="quiz-step hidden" data-step="result">
        <div class="text-center mb-6">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-k9-orange/10 mb-4">
            <svg class="w-7 h-7 text-k9-orange" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Your results are ready</h3>
          <p class="text-neutral-400 text-sm max-w-sm mx-auto">We scored your dog across 6 behavioural areas. Enter your email and we'll send your full score, weakest areas, and what to do about each one.</p>
        </div>

        <form id="quiz-form" class="space-y-3 max-w-sm mx-auto">
          <input type="text" name="quiz_name" required placeholder="Your name"
            class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-k9-orange/30 focus:border-k9-orange transition text-sm" />
          <input type="email" name="quiz_email" required placeholder="Email"
            class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-k9-orange/30 focus:border-k9-orange transition text-sm" />
          <button type="submit" id="quiz-submit"
            class="w-full px-6 py-3.5 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30">
            Send My Results
          </button>
          <p class="text-neutral-600 text-xs text-center">No spam. Just your score + actionable tips.</p>
        </form>
        <div class="mt-5 text-center">
          <a href="#contact" class="text-neutral-400 hover:text-white text-sm transition-colors">
            or skip straight to talking to a trainer →
          </a>
        </div>
      </div>

      <!-- Thank you (after email submit) -->
      <div class="quiz-step hidden" data-step="thanks">
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-k9-orange/10 mb-5">
            <svg class="w-8 h-8 text-k9-orange" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Check your inbox</h3>
          <p class="text-neutral-400 text-sm mb-8 max-w-md mx-auto">We're sending your full behaviour breakdown with specific tips for your dog's weakest areas.</p>
          <a href="#contact"
            class="inline-flex items-center px-7 py-3.5 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30">
            Talk to a Trainer
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const scores: Record<string, number> = {};
  let currentStep = 1;

  const labels: Record<string, string> = {
    leash: 'Leash walking',
    reactivity: 'Reactivity',
    recall: 'Off-leash recall',
    alone: 'Separation tolerance',
    settling: 'Settling at home',
    aggression: 'Aggression',
  };

  function showStep(step: number | string) {
    document.querySelectorAll('.quiz-step').forEach(el => el.classList.add('hidden'));
    const target = document.querySelector(`.quiz-step[data-step="${step}"]`);
    if (target) target.classList.remove('hidden');
  }

  document.querySelectorAll('.quiz-option').forEach(btn => {
    btn.addEventListener('click', () => {
      const field = (btn as HTMLElement).dataset.field!;
      const value = parseInt((btn as HTMLElement).dataset.value!, 10);
      scores[field] = value;

      btn.classList.add('border-k9-orange', 'bg-k9-orange/10');

      setTimeout(() => {
        currentStep++;
        if (currentStep <= 6) {
          showStep(currentStep);
        } else {
          showStep('result');
        }
      }, 200);
    });
  });

  document.getElementById('quiz-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const name = (form.querySelector('[name="quiz_name"]') as HTMLInputElement).value;
    const email = (form.querySelector('[name="quiz_email"]') as HTMLInputElement).value;

    const btn = document.getElementById('quiz-submit') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Sending...';

    const total = Object.values(scores).reduce((a, b) => a + b, 0);
    const scoreBreakdown = Object.entries(scores).map(([k, v]) => `${labels[k]}: ${v}/3`).join(', ');

    showStep('thanks');

    try {
      await fetch('/api/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name,
          email,
          phone: '',
          service: 'behaviour_quiz',
          message: `Behaviour quiz score: ${total}/18. ${scoreBreakdown}`,
          dog_info: '',
          quiz_scores: scores,
          quiz_total: total,
        }),
      });
    } catch {}

    try {
      const _learnq = (window as any)._learnq || [];
      _learnq.push(['identify', {
        '$email': email,
        '$first_name': name.split(' ')[0] || '',
        'Source': 'Behaviour Quiz',
        'Quiz Score': total,
        'Quiz Leash': scores.leash,
        'Quiz Reactivity': scores.reactivity,
        'Quiz Recall': scores.recall,
        'Quiz Alone': scores.alone,
        'Quiz Settling': scores.settling,
        'Quiz Aggression': scores.aggression,
      }]);
      _learnq.push(['track', 'Behaviour Quiz Completed', {
        'Name': name,
        'Email': email,
        'Score': total,
        'Leash': scores.leash,
        'Reactivity': scores.reactivity,
        'Recall': scores.recall,
        'Alone': scores.alone,
        'Settling': scores.settling,
        'Aggression': scores.aggression,
      }]);
    } catch {}
  });
</script>
