---
---

<section id="quiz" class="py-16 sm:py-20 bg-neutral-950 border-y border-white/5">
  <div class="max-w-2xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-10">
      <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Free Training Guide</p>
      <h2 class="text-2xl sm:text-3xl font-extrabold text-white">
        5 things every dog owner gets wrong
      </h2>
      <p class="mt-3 text-neutral-400 text-sm">Answer 5 quick questions and we'll send you a free guide tailored to your dog.</p>
    </div>

    <div id="quiz-container">
      <!-- Step 1: Challenge -->
      <div class="quiz-step" data-step="1">
        <p class="text-neutral-400 text-sm font-medium mb-4 text-center">Question 1 of 5</p>
        <h3 class="text-lg font-bold text-white text-center mb-6">What's your biggest challenge right now?</h3>
        <div class="grid grid-cols-2 gap-3">
          {[
            { val: 'pulling', label: 'Pulling on leash', icon: '🐕' },
            { val: 'reactivity', label: 'Reactivity / aggression', icon: '⚡' },
            { val: 'recall', label: 'Won\'t listen off leash', icon: '🏃' },
            { val: 'anxiety', label: 'Separation anxiety', icon: '🏠' },
            { val: 'barking', label: 'Barking', icon: '🔊' },
            { val: 'puppy', label: 'Just got a puppy', icon: '🐶' },
            { val: 'obedience', label: 'General obedience', icon: '🎓' },
            { val: 'other', label: 'Something else', icon: '❓' },
          ].map((opt) => (
            <button
              type="button"
              class="quiz-option group flex items-center gap-3 px-4 py-3.5 rounded-xl border border-white/10 bg-white/5 text-left hover:border-k9-orange/50 hover:bg-k9-orange/5 transition-all"
              data-field="challenge"
              data-value={opt.val}
            >
              <span class="text-lg flex-shrink-0">{opt.icon}</span>
              <span class="text-sm font-medium text-neutral-300 group-hover:text-white transition-colors">{opt.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Step 2: Age -->
      <div class="quiz-step hidden" data-step="2">
        <p class="text-neutral-400 text-sm font-medium mb-4 text-center">Question 2 of 5</p>
        <h3 class="text-lg font-bold text-white text-center mb-6">How old is your dog?</h3>
        <div class="grid grid-cols-2 gap-3">
          {[
            { val: 'under6m', label: 'Under 6 months' },
            { val: '6to12m', label: '6–12 months' },
            { val: '1to3y', label: '1–3 years' },
            { val: '3plus', label: '3+ years' },
          ].map((opt) => (
            <button
              type="button"
              class="quiz-option group flex items-center justify-center px-4 py-4 rounded-xl border border-white/10 bg-white/5 text-center hover:border-k9-orange/50 hover:bg-k9-orange/5 transition-all"
              data-field="dog_age"
              data-value={opt.val}
            >
              <span class="text-sm font-medium text-neutral-300 group-hover:text-white transition-colors">{opt.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Step 3: Reactivity on walks -->
      <div class="quiz-step hidden" data-step="3">
        <p class="text-neutral-400 text-sm font-medium mb-4 text-center">Question 3 of 5</p>
        <h3 class="text-lg font-bold text-white text-center mb-6">How does your dog react to other dogs on walks?</h3>
        <div class="grid gap-3">
          {[
            { val: 'fine', label: 'Mostly fine — ignores or is friendly' },
            { val: 'sometimes', label: 'Sometimes pulls or barks toward them' },
            { val: 'always', label: 'Lunges, barks, or loses it almost every time' },
          ].map((opt) => (
            <button
              type="button"
              class="quiz-option group flex items-center justify-center px-4 py-4 rounded-xl border border-white/10 bg-white/5 text-center hover:border-k9-orange/50 hover:bg-k9-orange/5 transition-all"
              data-field="reactivity_level"
              data-value={opt.val}
            >
              <span class="text-sm font-medium text-neutral-300 group-hover:text-white transition-colors">{opt.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Step 4: Alone time -->
      <div class="quiz-step hidden" data-step="4">
        <p class="text-neutral-400 text-sm font-medium mb-4 text-center">Question 4 of 5</p>
        <h3 class="text-lg font-bold text-white text-center mb-6">Can you leave your dog alone for 2+ hours?</h3>
        <div class="grid gap-3">
          {[
            { val: 'yes', label: 'Yes, no issues' },
            { val: 'some', label: 'Some whining or pacing but manageable' },
            { val: 'no', label: 'Destroys things, howls, or panics' },
          ].map((opt) => (
            <button
              type="button"
              class="quiz-option group flex items-center justify-center px-4 py-4 rounded-xl border border-white/10 bg-white/5 text-center hover:border-k9-orange/50 hover:bg-k9-orange/5 transition-all"
              data-field="alone_behaviour"
              data-value={opt.val}
            >
              <span class="text-sm font-medium text-neutral-300 group-hover:text-white transition-colors">{opt.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Step 5: Recall -->
      <div class="quiz-step hidden" data-step="5">
        <p class="text-neutral-400 text-sm font-medium mb-4 text-center">Question 5 of 5</p>
        <h3 class="text-lg font-bold text-white text-center mb-6">Does your dog come when called off leash?</h3>
        <div class="grid gap-3">
          {[
            { val: 'reliable', label: 'Yes, almost every time' },
            { val: 'only_no_distractions', label: 'Only when there are no distractions' },
            { val: 'never', label: 'Almost never — I don\'t trust it' },
          ].map((opt) => (
            <button
              type="button"
              class="quiz-option group flex items-center justify-center px-4 py-4 rounded-xl border border-white/10 bg-white/5 text-center hover:border-k9-orange/50 hover:bg-k9-orange/5 transition-all"
              data-field="recall_level"
              data-value={opt.val}
            >
              <span class="text-sm font-medium text-neutral-300 group-hover:text-white transition-colors">{opt.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Step 6: Contact -->
      <div class="quiz-step hidden" data-step="6">
        <h3 class="text-lg font-bold text-white text-center mb-2">Where should we send your free guide?</h3>
        <p class="text-neutral-500 text-sm text-center mb-6">We'll include personalized tips based on your answers.</p>
        <form id="quiz-form" class="space-y-3">
          <input type="text" name="quiz_name" required placeholder="Your name"
            class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-k9-orange/30 focus:border-k9-orange transition text-sm" />
          <input type="email" name="quiz_email" required placeholder="Email"
            class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-k9-orange/30 focus:border-k9-orange transition text-sm" />
          <input type="tel" name="quiz_phone" required placeholder="Phone (optional)"
            class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-k9-orange/30 focus:border-k9-orange transition text-sm" />
          <button type="submit" id="quiz-submit"
            class="w-full px-6 py-3.5 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30">
            Send Me the Free Guide
          </button>
          <p class="text-neutral-600 text-xs text-center">No spam. Just the guide + a few follow-up tips.</p>
        </form>
      </div>

      <!-- Result -->
      <div class="quiz-step hidden" data-step="result">
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-k9-orange/10 mb-5">
            <svg class="w-8 h-8 text-k9-orange" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-2">Your guide is on its way!</h3>
          <p class="text-neutral-400 text-sm mb-3 max-w-md mx-auto">Check your inbox for <strong class="text-white">"5 Things Every Dog Owner Gets Wrong"</strong> — we included personalized notes based on your answers.</p>
          <p id="quiz-tip" class="text-neutral-500 text-sm mb-8 max-w-md mx-auto italic"></p>
          <a href="#contact"
            class="inline-flex items-center px-7 py-3.5 bg-white/10 text-white text-base font-bold rounded-xl hover:bg-white/20 transition-all border border-white/10">
            Want faster results? Talk to us
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const quizData: Record<string, string> = {};
  let currentStep = 1;

  function showStep(step: number | string) {
    document.querySelectorAll('.quiz-step').forEach(el => el.classList.add('hidden'));
    const target = document.querySelector(`.quiz-step[data-step="${step}"]`);
    if (target) target.classList.remove('hidden');
  }

  document.querySelectorAll('.quiz-option').forEach(btn => {
    btn.addEventListener('click', () => {
      const field = (btn as HTMLElement).dataset.field!;
      const value = (btn as HTMLElement).dataset.value!;
      quizData[field] = value;

      btn.classList.add('border-k9-orange', 'bg-k9-orange/10');
      setTimeout(() => {
        currentStep++;
        showStep(currentStep);
      }, 200);
    });
  });

  function getPersonalizedTip(): string {
    const { challenge, reactivity_level, alone_behaviour, recall_level } = quizData;

    if (reactivity_level === 'always') return 'Based on your answers, reactivity is the #1 thing to address. The guide covers why your dog reacts and the first step to fixing it.';
    if (alone_behaviour === 'no') return 'Separation anxiety is one of the most misunderstood issues. The guide has a section specifically on why dogs panic when left alone — and what actually works.';
    if (recall_level === 'never') return 'Off-leash reliability starts with trust, not treats. The guide breaks down why most recall training fails and what to do differently.';
    if (challenge === 'puppy') return 'Puppies are a blank slate — but that window closes fast. The guide covers the 3 things to get right in the first 6 months.';
    if (challenge === 'pulling') return 'Leash pulling is the most common issue we see — and the most fixable. The guide shows you what most owners do wrong on walks.';
    return 'The guide covers the 5 biggest mistakes we see across 10,000+ dogs — at least one of them will click for you.';
  }

  document.getElementById('quiz-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const name = (form.querySelector('[name="quiz_name"]') as HTMLInputElement).value;
    const email = (form.querySelector('[name="quiz_email"]') as HTMLInputElement).value;
    const phone = (form.querySelector('[name="quiz_phone"]') as HTMLInputElement).value;

    const submitBtn = document.getElementById('quiz-submit') as HTMLButtonElement;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';

    // Show result immediately
    document.getElementById('quiz-tip')!.textContent = getPersonalizedTip();
    showStep('result');

    // Build summary for backend
    const quizSummary = `Quiz answers — Challenge: ${quizData.challenge}, Age: ${quizData.dog_age}, Reactivity: ${quizData.reactivity_level}, Alone: ${quizData.alone_behaviour}, Recall: ${quizData.recall_level}`;

    // Send to backend
    try {
      await fetch('/api/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name,
          email,
          phone: phone || '',
          service: 'quiz_guide',
          message: quizSummary,
          dog_info: `Challenge: ${quizData.challenge}`,
        }),
      });
    } catch {
      // Silent — result already shown
    }

    // Klaviyo
    try {
      const _learnq = (window as any)._learnq || [];
      _learnq.push(['identify', {
        '$email': email,
        '$first_name': name.split(' ')[0] || '',
        'Phone': phone || '',
        'Source': 'Quiz',
        'Quiz Challenge': quizData.challenge,
        'Quiz Dog Age': quizData.dog_age,
        'Quiz Reactivity': quizData.reactivity_level,
        'Quiz Alone Behaviour': quizData.alone_behaviour,
        'Quiz Recall': quizData.recall_level,
      }]);
      _learnq.push(['track', 'Guide Requested', {
        'Name': name,
        'Email': email,
        'Challenge': quizData.challenge,
        'Dog Age': quizData.dog_age,
        'Reactivity Level': quizData.reactivity_level,
        'Alone Behaviour': quizData.alone_behaviour,
        'Recall Level': quizData.recall_level,
      }]);
    } catch {
      // Silent
    }
  });
</script>
