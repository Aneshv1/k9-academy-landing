---
---

<section id="about" class="py-16 sm:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Video Carousel -->
      <div class="relative">
        <div class="space-y-3" id="video-carousel">
          <div class="rounded-2xl overflow-hidden border border-neutral-200/60 shadow-md aspect-video">
            <iframe
              src="https://www.youtube.com/embed/gfnMuWAA-LM?rel=0"
              title="K9 Academy Training"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              class="w-full h-full"
              loading="lazy"
              id="carousel-player"
            ></iframe>
          </div>

          <!-- Thumbnail strip -->
          <div class="flex gap-2">
            <button data-video="gfnMuWAA-LM" class="video-thumb flex-1 rounded-lg overflow-hidden border-2 border-k9-orange opacity-100 transition-all">
              <img src="https://img.youtube.com/vi/gfnMuWAA-LM/mqdefault.jpg" alt="Video 1" class="w-full aspect-video object-cover" loading="lazy" />
            </button>
            <button data-video="3B-EavE1l_U" class="video-thumb flex-1 rounded-lg overflow-hidden border-2 border-transparent opacity-60 hover:opacity-100 transition-all">
              <img src="https://img.youtube.com/vi/3B-EavE1l_U/mqdefault.jpg" alt="Video 2" class="w-full aspect-video object-cover" loading="lazy" />
            </button>
          </div>
        </div>
      </div>

      <script>
        document.querySelectorAll('.video-thumb').forEach((btn) => {
          btn.addEventListener('click', () => {
            const videoId = (btn as HTMLElement).dataset.video;
            const player = document.getElementById('carousel-player') as HTMLIFrameElement;
            player.src = `https://www.youtube.com/embed/${videoId}?rel=0&autoplay=1`;

            document.querySelectorAll('.video-thumb').forEach((b) => {
              b.classList.remove('border-k9-orange');
              b.classList.add('border-transparent', 'opacity-60');
            });
            btn.classList.add('border-k9-orange');
            btn.classList.remove('border-transparent', 'opacity-60');
            btn.classList.add('opacity-100');
          });
        });
      </script>

      <div>
        <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">About K9 Academy</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900 mb-6">
          The training company other trainers refer their hardest cases to.
        </h2>

        <div class="space-y-4 text-neutral-500 leading-relaxed">
          <p>
            Most training companies won't tell you this: the biggest reason dogs fail training is because the trainer doesn't understand the dog in front of them. They use cookie-cutter methods and hope something sticks.
          </p>
          <p>
            K9 Academy was built to be different. Over 15 years, we've trained over 10,000 dogs — including the breeds most trainers refuse. Malinois, GSDs, huskies, dogs with bite histories, the ones other trainers called "too far gone."
          </p>
          <p>
            We use balanced training — including e-collar protocols — because the results speak for themselves. We're not interested in trends. We're interested in outcomes.
          </p>
          <p class="font-semibold text-neutral-900">
            Award-winning. Published in over 100 outlets. And we still answer every inquiry personally.
          </p>
        </div>

        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a
            href="#contact"
            class="inline-flex items-center justify-center px-6 py-3 bg-neutral-900 text-white text-sm font-semibold rounded-xl hover:bg-neutral-800 transition-all"
          >
            Get in Touch
          </a>
          <a
            href="tel:4377785273"
            class="inline-flex items-center justify-center gap-2 px-6 py-3 text-neutral-600 text-sm font-semibold rounded-xl border border-neutral-200 hover:border-neutral-300 hover:bg-neutral-50 transition-all"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            437-778-5273
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
