---
interface Props {
  defaultService?: string;
  sourcePage?: string;
  formHeading?: string;
  formSubheading?: string;
  submitText?: string;
}
const {
  defaultService = '',
  sourcePage = 'Main Landing Page',
  formHeading = 'Get your free consultation',
  formSubheading = "Fill this out and we'll be in touch shortly.",
  submitText = "Start My Dog's Transformation",
} = Astro.props;
---

<section id="contact" class="py-16 sm:py-24 bg-neutral-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
      <!-- Left -->
      <div class="text-white">
        <h2 class="text-3xl sm:text-4xl font-extrabold leading-tight">
          Start your dog's<br />transformation today
        </h2>
        <p class="mt-4 text-lg text-neutral-400">
          Tell us about your dog and we will be in touch shortly.
        </p>

        <ul class="mt-8 space-y-3">
          {[
            'We typically respond within hours',
            'For serious inquiries only',
            'Spots are limited each month',
            'Talk directly to a head trainer',
            'Results guaranteed or we keep working',
          ].map((item) => (
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-k9-green flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              <span class="text-neutral-300">{item}</span>
            </li>
          ))}
        </ul>

        <div class="mt-10 bg-white/5 rounded-2xl p-6 border border-white/10">
          <div class="flex items-center gap-0.5 mb-3">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-neutral-300 text-sm leading-relaxed italic">
            "Three trainers told us our GSD was a lost cause. K9 Academy took him on without hesitation. After 4 weeks of Board & Train, we have a completely different dog. Best decision we ever made."
          </p>
          <p class="mt-3 text-neutral-500 text-sm">— David & Kim L. &middot; German Shepherd, 3 years</p>
        </div>
      </div>

      <!-- Right: form -->
      <div>
        <div class="bg-white rounded-2xl p-6 sm:p-8 shadow-2xl">
          <h3 class="text-xl font-bold text-neutral-900 mb-1">{formHeading}</h3>
          <p class="text-sm text-neutral-400 mb-6">{formSubheading}</p>

          <form id="inquiry-form" class="space-y-4">
            <input type="hidden" name="source_page" value={sourcePage} />
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="name" class="block text-sm font-medium text-neutral-700 mb-1">Your Name</label>
                <input type="text" id="name" name="name" required
                  class="w-full px-4 py-3 border border-neutral-200 rounded-xl text-neutral-900 placeholder-neutral-300 focus:outline-none focus:ring-2 focus:ring-k9-orange/30 focus:border-k9-orange transition text-sm"
                  placeholder="First & last name" />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-neutral-700 mb-1">Phone Number</label>
                <input type="tel" id="phone" name="phone" required
                  class="w-full px-4 py-3 border border-neutral-200 rounded-xl text-neutral-900 placeholder-neutral-300 focus:outline-none focus:ring-2 focus:ring-k9-orange/30 focus:border-k9-orange transition text-sm"
                  placeholder="(416) 555-1234" />
              </div>
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-neutral-700 mb-1">Email</label>
              <input type="email" id="email" name="email" required
                class="w-full px-4 py-3 border border-neutral-200 rounded-xl text-neutral-900 placeholder-neutral-300 focus:outline-none focus:ring-2 focus:ring-k9-orange/30 focus:border-k9-orange transition text-sm"
                placeholder="you@email.com" />
            </div>

            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="dog_info" class="block text-sm font-medium text-neutral-700 mb-1">Dog's Name, Age & Breed</label>
                <input type="text" id="dog_info" name="dog_info"
                  class="w-full px-4 py-3 border border-neutral-200 rounded-xl text-neutral-900 placeholder-neutral-300 focus:outline-none focus:ring-2 focus:ring-k9-orange/30 focus:border-k9-orange transition text-sm"
                  placeholder="e.g. Max, 2 years, German Shepherd" />
              </div>
              <div>
                <label for="service" class="block text-sm font-medium text-neutral-700 mb-1">Interested In</label>
                <select id="service" name="service" data-default={defaultService}
                  class="w-full px-4 py-3 border border-neutral-200 rounded-xl text-neutral-900 focus:outline-none focus:ring-2 focus:ring-k9-orange/30 focus:border-k9-orange transition bg-white text-sm">
                  <option value="">Select a program</option>
                  <option value="board_and_train">Board & Train</option>
                  <option value="private_lessons">Private Lessons</option>
                  <option value="group_classes">Group Classes</option>
                  <option value="puppy_classes">Puppy Classes</option>
                  <option value="">Not sure yet</option>
                </select>
              </div>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-neutral-700 mb-1">Tell us about your dog</label>
              <textarea id="message" name="message" rows="3"
                class="w-full px-4 py-3 border border-neutral-200 rounded-xl text-neutral-900 placeholder-neutral-300 focus:outline-none focus:ring-2 focus:ring-k9-orange/30 focus:border-k9-orange transition resize-none text-sm"
                placeholder="Breed, age, what you're dealing with..."></textarea>
            </div>

            <div class="flex items-start gap-3">
              <input type="checkbox" id="tools-consent" name="tools_consent" required
                class="mt-1 w-4 h-4 rounded border-neutral-300 text-k9-orange focus:ring-k9-orange/30 flex-shrink-0 cursor-pointer" />
              <label for="tools-consent" class="text-xs text-neutral-500 leading-relaxed cursor-pointer">
                <strong class="text-neutral-700">I Understand</strong>. By completing this form you acknowledge that our trainers may employ tools they deem necessary to achieve your training goals. This may include a prong collar, slip lead, muzzle, crate and/or E-Collar.
              </label>
            </div>

            <button type="submit" id="submit-btn"
              class="w-full py-4 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/20 hover:shadow-xl disabled:opacity-50 disabled:cursor-not-allowed">
              {submitText}
            </button>

          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('inquiry-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const serviceSelect = document.getElementById('service') as HTMLSelectElement;
  const originalBtnText = submitBtn?.textContent || 'Submit';

  // Auto-select the service based on the page
  if (serviceSelect?.dataset.default) {
    serviceSelect.value = serviceSelect.dataset.default;
  }

  const SERVICE_LABELS: Record<string, string> = {
    'board_and_train': 'Board & Train',
    'private_lessons': 'Private Lessons',
    'group_classes': 'Group Classes',
    'puppy_classes': 'Puppy Classes',
  };

  const EVENT_NAMES: Record<string, string> = {
    'board_and_train': 'Board & Train Inquiry',
    'private_lessons': 'Private Lessons Inquiry',
    'group_classes': 'Group Classes Inquiry',
    'puppy_classes': 'Puppy Classes Inquiry',
  };

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    try {
      // 1. Submit to Supabase via API endpoint
      const res = await fetch('/api/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      // 2. Push to Klaviyo
      try {
        const serviceKey = data.service as string;
        const serviceLabel = SERVICE_LABELS[serviceKey] || 'Not specified';
        const eventName = EVENT_NAMES[serviceKey] || 'Landing Page Inquiry';

        (window as any)._learnq = (window as any)._learnq || [];
        (window as any)._learnq.push(['identify', {
          '$email': data.email,
          '$first_name': (data.name as string)?.split(' ')[0] || '',
          '$last_name': (data.name as string)?.split(' ').slice(1).join(' ') || '',
          '$phone_number': data.phone,
          'Dog Info': data.dog_info || '',
          'Service Interest': serviceLabel,
          'Message': data.message || '',
          'Source': serviceLabel,
        }]);
        // Send the specific event for flow triggers
        (window as any)._learnq.push(['track', eventName, {
          'Name': data.name,
          'Email': data.email,
          'Phone': data.phone,
          'Dog Info': data.dog_info || '',
          'Service': serviceLabel,
          'Message': data.message || '',
        }]);
        // Also send generic event for catch-all
        if (eventName !== 'Landing Page Inquiry') {
          (window as any)._learnq.push(['track', 'Landing Page Inquiry', {
            'Name': data.name,
            'Email': data.email,
            'Phone': data.phone,
            'Dog Info': data.dog_info || '',
            'Service': serviceLabel,
            'Message': data.message || '',
          }]);
        }
      } catch (klaviyoErr) {
        console.error('Klaviyo push failed:', klaviyoErr);
      }

      if (res.ok) {
        // Short delay to let Klaviyo flush queued events before redirect
        setTimeout(() => { window.location.href = '/thank-you'; }, 500);
      } else {
        throw new Error('Submission failed');
      }
    } catch {
      submitBtn.disabled = false;
      submitBtn.textContent = originalBtnText;
      alert('Something went wrong. Please call us at 437-778-5273 instead.');
    }
  });
</script>
