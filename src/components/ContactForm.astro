---
---

<section id="contact" class="py-16 sm:py-24 bg-neutral-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
      <!-- Left -->
      <div class="text-white">
        <h2 class="text-3xl sm:text-4xl font-extrabold leading-tight">
          Start your dog's<br />transformation today
        </h2>
        <p class="mt-4 text-lg text-neutral-400">
          Anesh responds personally, same day. No obligation — just a real conversation about your dog.
        </p>

        <ul class="mt-8 space-y-3">
          {[
            'Same-day response from Anesh',
            'No obligation — just a conversation',
            'Spots are limited each month',
            'Talk directly to the head trainer',
            'Results guaranteed or we keep working',
          ].map((item) => (
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-k9-green flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              <span class="text-neutral-300">{item}</span>
            </li>
          ))}
        </ul>

        <div class="mt-10 bg-white/5 rounded-2xl p-6 border border-white/10">
          <div class="flex items-center gap-0.5 mb-3">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-neutral-300 text-sm leading-relaxed italic">
            "Three trainers told us our GSD was a lost cause. Anesh took him on without hesitation. After 4 weeks of Board & Train, we have a completely different dog. Best decision we ever made."
          </p>
          <p class="mt-3 text-neutral-500 text-sm">— David & Kim L. &middot; German Shepherd, 3 years</p>
        </div>
      </div>

      <!-- Right: form -->
      <div>
        <div class="bg-white rounded-2xl p-6 sm:p-8 shadow-2xl">
          <h3 class="text-xl font-bold text-neutral-900 mb-1">Get your free consultation</h3>
          <p class="text-sm text-neutral-400 mb-6">Fill this out and Anesh will call you — same day.</p>

          <form id="inquiry-form" class="space-y-4">
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="name" class="block text-sm font-medium text-neutral-700 mb-1">Your Name</label>
                <input type="text" id="name" name="name" required
                  class="w-full px-4 py-3 border border-neutral-200 rounded-xl text-neutral-900 placeholder-neutral-300 focus:outline-none focus:ring-2 focus:ring-k9-green/30 focus:border-k9-green transition text-sm"
                  placeholder="First & last name" />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-neutral-700 mb-1">Phone Number</label>
                <input type="tel" id="phone" name="phone" required
                  class="w-full px-4 py-3 border border-neutral-200 rounded-xl text-neutral-900 placeholder-neutral-300 focus:outline-none focus:ring-2 focus:ring-k9-green/30 focus:border-k9-green transition text-sm"
                  placeholder="(416) 555-1234" />
              </div>
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-neutral-700 mb-1">Email</label>
              <input type="email" id="email" name="email" required
                class="w-full px-4 py-3 border border-neutral-200 rounded-xl text-neutral-900 placeholder-neutral-300 focus:outline-none focus:ring-2 focus:ring-k9-green/30 focus:border-k9-green transition text-sm"
                placeholder="you@email.com" />
            </div>

            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="dog_name" class="block text-sm font-medium text-neutral-700 mb-1">Dog's Name</label>
                <input type="text" id="dog_name" name="dog_name"
                  class="w-full px-4 py-3 border border-neutral-200 rounded-xl text-neutral-900 placeholder-neutral-300 focus:outline-none focus:ring-2 focus:ring-k9-green/30 focus:border-k9-green transition text-sm"
                  placeholder="Your dog's name" />
              </div>
              <div>
                <label for="service" class="block text-sm font-medium text-neutral-700 mb-1">Interested In</label>
                <select id="service" name="service"
                  class="w-full px-4 py-3 border border-neutral-200 rounded-xl text-neutral-900 focus:outline-none focus:ring-2 focus:ring-k9-green/30 focus:border-k9-green transition bg-white text-sm">
                  <option value="">Select a program</option>
                  <option value="bt_4wk">Board & Train</option>
                  <option value="private_single">Private Lessons</option>
                  <option value="group_puppy">Group Classes</option>
                  <option value="daycare">Daycare</option>
                  <option value="">Not sure yet</option>
                </select>
              </div>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-neutral-700 mb-1">Tell us about your dog</label>
              <textarea id="message" name="message" rows="3"
                class="w-full px-4 py-3 border border-neutral-200 rounded-xl text-neutral-900 placeholder-neutral-300 focus:outline-none focus:ring-2 focus:ring-k9-green/30 focus:border-k9-green transition resize-none text-sm"
                placeholder="Breed, age, what you're dealing with..."></textarea>
            </div>

            <button type="submit" id="submit-btn"
              class="w-full py-4 bg-k9-green text-white text-base font-bold rounded-xl hover:bg-k9-green-mid transition-all shadow-lg shadow-k9-green/20 hover:shadow-xl disabled:opacity-50 disabled:cursor-not-allowed">
              Start My Dog's Transformation
            </button>

            <p class="text-center text-xs text-neutral-400">
              No spam. No sales pitch. Just a real conversation with Anesh about your dog.
            </p>
          </form>

          <!-- Success message (hidden by default) -->
          <div id="success-message" class="hidden text-center py-8">
            <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-k9-green/10 flex items-center justify-center">
              <svg class="w-8 h-8 text-k9-green" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-neutral-900 mb-2">You're in!</h3>
            <p class="text-neutral-500">Anesh will call you today. Keep an eye on your phone.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('inquiry-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const successMsg = document.getElementById('success-message') as HTMLDivElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    try {
      const res = await fetch('/api/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        form.classList.add('hidden');
        successMsg.classList.remove('hidden');

        // Fire Meta Pixel lead event
        if (typeof fbq !== 'undefined') {
          fbq('track', 'Lead');
        }
        // Fire GA4 event
        if (typeof gtag !== 'undefined') {
          gtag('event', 'generate_lead', { event_category: 'form', event_label: data.service || 'unknown' });
        }
      } else {
        throw new Error('Submission failed');
      }
    } catch {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Start My Dog\'s Transformation';
      alert('Something went wrong. Please call us at 437-778-5273 instead.');
    }
  });
</script>
