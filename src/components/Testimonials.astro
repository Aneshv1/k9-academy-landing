---
const testimonials = [
  {
    headline: 'From lunging at everything to off-leash at the park',
    text: 'Our GSD was reactive to every dog on the street. Two trainers told us he was too much. K9 Academy had him walking calmly within the first two weeks of Board & Train. It\'s been 6 months and the results are still holding.',
    name: 'Sarah M.',
    dog: 'German Shepherd, 3 years',
    program: 'Board & Train — 4 weeks',
  },
  {
    headline: 'We can finally have guests over without chaos',
    text: 'Our doodle would jump on everyone, bark non-stop, and destroy furniture when left alone. After 6 private sessions, he\'s a completely different dog. We wish we\'d found K9 Academy sooner.',
    name: 'Mark & Lisa T.',
    dog: 'Goldendoodle, 2 years',
    program: 'Private Lessons — 6 pack',
  },
  {
    headline: 'The trainers who actually understood our malinois',
    text: 'Every trainer we talked to said our malinois was too much to handle. K9 Academy not only took him on — he thrived. The e-collar work was a game changer. Our dog went from unpredictable to reliable.',
    name: 'James K.',
    dog: 'Belgian Malinois, 4 years',
    program: 'Board & Train — 6 weeks',
  },
  {
    headline: 'Started right and never had to fix bad habits',
    text: 'We brought our puppy to K9 Academy at 12 weeks. Best decision we ever made. She learned everything she needed before bad habits had a chance to form. The team made it easy and clear.',
    name: 'Priya S.',
    dog: 'Lab mix, started at 12 weeks',
    program: 'Foundation Program',
  },
  {
    headline: 'My dog bit someone. K9 Academy didn\'t give up on him.',
    text: 'After a bite incident, I was told to consider euthanasia. The K9 Academy team took the time to understand what was going on. 8 weeks later, my dog is safe, calm, and part of the family again.',
    name: 'Rachel D.',
    dog: 'Husky mix, 5 years',
    program: 'Board & Train — 8 weeks',
  },
  {
    headline: 'Finally enjoy our walks again',
    text: 'I used to cross the street every time I saw another dog. After B&T, my dog walks beside me calmly. People stop me to say how well-behaved she is. Night and day difference.',
    name: 'Chris P.',
    dog: 'Pitbull mix, 2 years',
    program: 'Board & Train — 4 weeks',
  },
];
---

<section id="results" class="py-16 sm:py-24 bg-neutral-50 border-y border-neutral-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 sm:mb-16">
      <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Real Results</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900">
        250+ five-star reviews. Here's what owners say.
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {testimonials.map((t) => (
        <div class="bg-white rounded-2xl p-6 border border-neutral-200/60 hover:border-neutral-300 transition-all flex flex-col">
          <div class="flex items-center gap-2 mb-4">
            <svg class="w-5 h-5" viewBox="0 0 24 24">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" />
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
            </svg>
            <div class="flex items-center gap-0.5">
              {[1,2,3,4,5].map(() => (
                <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
          </div>

          <h3 class="text-base font-bold text-neutral-900 mb-2">{t.headline}</h3>
          <p class="text-neutral-500 text-sm leading-relaxed flex-grow mb-4">{t.text}</p>

          <div class="pt-4 border-t border-neutral-100">
            <p class="font-semibold text-neutral-900 text-sm">{t.name}</p>
            <p class="text-xs text-neutral-400">{t.dog} &middot; {t.program}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
