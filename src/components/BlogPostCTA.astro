---
interface Props {
  servicePage: string;
  servicePageLabel: string;
}

const { servicePage, servicePageLabel } = Astro.props;
---

<!-- Primary CTA -->
<div class="mt-12 bg-neutral-950 rounded-2xl border border-white/10 p-6 sm:p-8">
  <div class="text-center">
    <p class="text-k9-orange font-semibold text-xs tracking-wide uppercase mb-2">Ready to Get Started?</p>
    <h3 class="text-xl font-bold text-white mb-2">Talk to a trainer today</h3>
    <p class="text-neutral-500 text-sm mb-5 max-w-md mx-auto">Tell us what you're dealing with. We'll recommend the right program for your dog. No pressure, no sales pitch.</p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
      <a href={servicePage}
        class="inline-flex items-center px-6 py-3 bg-k9-orange text-white text-sm font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/20">
        {servicePageLabel}
        <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
      </a>
      <a href="tel:4377785273" class="inline-flex items-center gap-2 px-6 py-3 text-neutral-400 font-medium hover:text-white transition-colors border border-white/10 rounded-xl hover:border-white/20 text-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
        437-778-5273
      </a>
    </div>
  </div>
</div>

<!-- In-Home Training Promo -->
<div class="mt-6 rounded-2xl border border-k9-orange/20 bg-k9-orange/5 p-6 sm:p-8">
  <div class="sm:flex sm:items-center sm:justify-between gap-4">
    <div>
      <p class="font-bold text-neutral-900 text-sm mb-1">Want a trainer to come to your home?</p>
      <p class="text-neutral-500 text-sm">Private in-home sessions with our senior trainers. $625/session. Your home, your schedule, real results.</p>
    </div>
    <a href="/in-home" class="inline-flex items-center mt-3 sm:mt-0 px-5 py-2.5 bg-k9-orange text-white text-sm font-bold rounded-lg hover:bg-k9-orange-dark transition-all whitespace-nowrap">
      Learn More
    </a>
  </div>
</div>

<!-- Stats bar -->
<div class="mt-6 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-neutral-400 py-4 border-t border-neutral-100">
  <span><strong class="text-neutral-900">10,000+</strong> dogs trained</span>
  <span><strong class="text-neutral-900">15+</strong> years</span>
  <span><strong class="text-neutral-900">4.9★</strong> Google (250+ reviews)</span>
</div>
