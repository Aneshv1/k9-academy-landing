---
interface Props {
  servicePage: string;
  servicePageLabel: string;
}

const { servicePage, servicePageLabel } = Astro.props;
---

<div class="mt-12 bg-neutral-950 rounded-2xl border border-white/10 p-6 sm:p-8">
  <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
    <div class="flex-1">
      <p class="text-k9-orange font-semibold text-xs tracking-wide uppercase mb-1">Ready to Get Started?</p>
      <h3 class="text-lg font-bold text-white">See our {servicePageLabel}</h3>
      <p class="text-neutral-500 text-sm mt-1">Or call us at <a href="tel:4377785273" class="text-neutral-400 hover:text-white transition-colors">437-778-5273</a></p>
    </div>
    <a href={servicePage}
      class="inline-flex items-center px-6 py-2.5 bg-k9-orange text-white text-sm font-bold rounded-lg hover:bg-k9-orange-dark transition-all whitespace-nowrap">
      Learn More
      <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
    </a>
  </div>
</div>
