---
const props = [
  {
    title: 'E-collar protocols other trainers refuse',
    description: 'We address the root cause of reactivity — not just the symptoms. Proven methods that deliver lasting off-leash results.',
  },
  {
    title: 'Two dedicated facilities across the GTA',
    description: 'Leaside for lessons and classes. Stouffville for boarding, Board & Train, and daycare. One seamless experience.',
  },
  {
    title: '15+ years training working breeds',
    description: 'Malinois, GSD, huskies — the dogs most trainers gave up on are our specialty. We understand working dog psychology.',
  },
  {
    title: 'We respond to every inquiry quickly',
    description: 'No call centers. No runaround. You talk directly to our training team from day one.',
  },
  {
    title: 'Results that hold — not temporary fixes',
    description: 'We keep working until your dog performs reliably in real-world situations. If results slip, we\'re here.',
  },
  {
    title: 'Every dog assessed individually',
    description: 'No cookie-cutter methods. Custom training plan based on breed, temperament, history, and your specific goals.',
  },
];
---

<section class="py-16 sm:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 sm:mb-16">
      <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">Why K9 Academy</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900">
        What makes us different from every<br class="hidden sm:block" /> other trainer in Toronto
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {props.map((prop, i) => (
        <div class="rounded-2xl p-6 bg-neutral-50 border border-neutral-200/60 hover:border-neutral-300 transition-all">
          <div class="w-8 h-8 rounded-lg bg-k9-orange/10 flex items-center justify-center mb-4">
            <span class="text-k9-orange font-bold text-sm">{String(i + 1).padStart(2, '0')}</span>
          </div>
          <h3 class="text-base font-bold text-neutral-900 mb-2">{prop.title}</h3>
          <p class="text-neutral-500 text-sm leading-relaxed">{prop.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
