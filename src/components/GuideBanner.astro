---
---

<div class="bg-neutral-950 rounded-2xl border border-white/10 p-6 sm:p-8">
  <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
    <div class="flex-1">
      <p class="text-k9-orange font-semibold text-xs tracking-wide uppercase mb-1">Free Guide</p>
      <h3 class="text-lg font-bold text-white">5 Things Every Dog Owner Gets Wrong</h3>
      <p class="text-neutral-500 text-sm mt-1">Quick tips you can try today — no commitment.</p>
    </div>
    <form id="guide-form" class="flex flex-col sm:flex-row gap-2 w-full sm:w-auto">
      <input type="text" name="guide_name" required placeholder="Name"
        class="px-3 py-2.5 bg-white/5 border border-white/10 rounded-lg text-white placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-k9-orange/30 focus:border-k9-orange transition text-sm w-full sm:w-32" />
      <input type="email" name="guide_email" required placeholder="Email"
        class="px-3 py-2.5 bg-white/5 border border-white/10 rounded-lg text-white placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-k9-orange/30 focus:border-k9-orange transition text-sm w-full sm:w-48" />
      <button type="submit" id="guide-submit"
        class="px-5 py-2.5 bg-k9-orange text-white text-sm font-bold rounded-lg hover:bg-k9-orange-dark transition-all whitespace-nowrap">
        Send It
      </button>
    </form>
  </div>
  <p id="guide-success" class="hidden text-k9-orange text-sm font-medium mt-3">Check your inbox — guide is on its way!</p>
</div>

<script>
  document.getElementById('guide-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const name = (form.querySelector('[name="guide_name"]') as HTMLInputElement).value;
    const email = (form.querySelector('[name="guide_email"]') as HTMLInputElement).value;

    const btn = document.getElementById('guide-submit') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Sent!';
    document.getElementById('guide-success')?.classList.remove('hidden');

    try {
      await fetch('/api/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name,
          email,
          phone: '',
          service: 'guide_download',
          message: 'Requested free training guide from program page',
          dog_info: '',
        }),
      });
    } catch {}

    try {
      const _learnq = (window as any)._learnq || [];
      _learnq.push(['identify', {
        '$email': email,
        '$first_name': name.split(' ')[0] || '',
        'Source': 'Guide Banner',
      }]);
      _learnq.push(['track', 'Guide Requested', {
        'Name': name,
        'Email': email,
        'Source': 'Program Page Banner',
      }]);
    } catch {}
  });
</script>
