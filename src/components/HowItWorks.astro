---
const steps = [
  {
    number: '01',
    title: 'Reach out',
    description: 'Fill out the form or call 437-778-5273. Our team will be in touch shortly. No sales pitch.',
  },
  {
    number: '02',
    title: 'Get a personalized plan',
    description: 'We assess your dog\'s breed, temperament, and specific issues to recommend the right program for you.',
  },
  {
    number: '03',
    title: 'Watch the transformation',
    description: 'Your dog gets trained by specialists who handle the hard cases. Weekly updates, midway session, detailed go-home plan.',
  },
];
---

<section class="py-16 sm:py-24 bg-brand-dark">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 sm:mb-16">
      <p class="text-k9-orange font-semibold text-sm tracking-wide uppercase mb-3">How It Works</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-white">
        From first call to a dog you're proud of
      </h2>
    </div>

    <div class="grid sm:grid-cols-3 gap-6">
      {steps.map((step) => (
        <div class="text-center sm:text-left">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-k9-orange text-white text-sm font-bold mb-4">
            {step.number}
          </div>
          <h3 class="text-lg font-bold text-white mb-2">{step.title}</h3>
          <p class="text-neutral-400 text-sm leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>

    <div class="text-center mt-12">
      <a
        href="#contact"
        class="inline-flex items-center px-7 py-3.5 bg-k9-orange text-white text-base font-bold rounded-xl hover:bg-k9-orange-dark transition-all shadow-lg shadow-k9-orange/30"
      >
        Start Step 1 — Takes 30 Seconds
      </a>
      <div class="mt-3 flex justify-center gap-4">
        {['No obligation', 'Quick response'].map((item) => (
          <span class="flex items-center gap-1.5 text-sm text-neutral-500">
            <svg class="w-4 h-4 text-k9-orange" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
            {item}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
