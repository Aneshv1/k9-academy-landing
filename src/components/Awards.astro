---
const awards = [
  { src: '/badges/readers-choice.png', alt: "Toronto Star Readers' Choice 2023 — Platinum Winner" },
  { src: '/badges/quality-2025.jpg', alt: '2025 Quality Business Awards Winner' },
  { src: '/badges/consumer-choice.png', alt: 'Consumer Choice Award — Business Excellence' },
  { src: '/badges/threebest-rated.png', alt: 'ThreeBest Rated — Best Business of 2025' },
  { src: '/badges/trustanalytica.png', alt: 'Top 10 Toronto Dog Obedience — TrustAnalytica 2025' },
  { src: '/badges/canadian-choice-trophy.png', alt: 'Canadian Choice Award 2025' },
];
---

<section class="py-6 sm:py-8 bg-neutral-950 border-b border-white/5">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row items-center gap-6 sm:gap-10">
      <!-- Label -->
      <p class="text-xs font-semibold text-neutral-500 uppercase tracking-widest whitespace-nowrap">
        As Featured In
      </p>

      <!-- Divider (desktop only) -->
      <div class="hidden sm:block w-px h-10 bg-white/10"></div>

      <!-- Logos -->
      <div class="flex flex-wrap items-center justify-center sm:justify-start gap-6 sm:gap-8">
        {awards.map((award) => (
          <img
            src={award.src}
            alt={award.alt}
            class="h-10 sm:h-12 w-auto object-contain opacity-50 hover:opacity-90 transition-all duration-300 grayscale hover:grayscale-0"
            loading="lazy"
          />
        ))}
      </div>
    </div>
  </div>
</section>
