---
const awards = [
  { src: '/badges/readers-choice.png', alt: "Toronto Star Readers' Choice 2023 — Platinum Winner" },
  { src: '/badges/quality-2025.jpg', alt: '2025 Quality Business Awards Winner' },
  { src: '/badges/consumer-choice.png', alt: 'Consumer Choice Award — Business Excellence' },
  { src: '/badges/threebest-rated.png', alt: 'ThreeBest Rated — Best Business of 2025' },
  { src: '/badges/trustanalytica.png', alt: 'Top 10 Toronto Dog Obedience — TrustAnalytica 2025' },
  { src: '/badges/canadian-choice-trophy.png', alt: 'Canadian Choice Award 2025' },
];
---

<section class="py-8 sm:py-10 bg-neutral-50 border-y border-neutral-100">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <p class="text-center text-[11px] font-semibold text-neutral-400 uppercase tracking-[0.2em] mb-6">
      Award-Winning Training — As Featured In
    </p>

    <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-6">
      {awards.map((award) => (
        <img
          src={award.src}
          alt={award.alt}
          class="h-14 sm:h-16 w-auto object-contain opacity-80 hover:opacity-100 transition-opacity duration-300"
          loading="lazy"
        />
      ))}
    </div>
  </div>
</section>
