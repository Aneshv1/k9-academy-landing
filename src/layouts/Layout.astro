---
interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description = "K9 Academy Training — Toronto's dog training specialists. Board & Train, Private Lessons, Group Classes. 15+ years, 10,000+ dogs trained. Results guaranteed.",
  canonical,
  ogImage = '/og-image.jpg',
  noindex = false,
} = Astro.props;
import ChatBot from '../components/ChatBot.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical || Astro.url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical || Astro.url.href} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <title>{title}</title>

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "K9 Academy Dog Training Center",
      "image": "https://training.k9academy.ca/logo.png",
      "url": "https://training.k9academy.ca",
      "telephone": "+14377785273",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "16-30 Canvarco Rd",
        "addressLocality": "Toronto",
        "addressRegion": "ON",
        "postalCode": "M4G 1L3",
        "addressCountry": "CA"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 43.7085,
        "longitude": -79.3649
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "250"
      },
      "priceRange": "$595-$4995"
    })} />

    <!-- Klaviyo -->
    <script async src="https://static.klaviyo.com/onsite/js/klaviyo.js?company_id=Y8jyJQ"></script>

    <!-- Microsoft Clarity — uncomment and replace YOUR_CLARITY_PROJECT_ID when ready
    <script type="text/javascript">
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/YOUR_CLARITY_PROJECT_ID";
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script");
    </script>
    -->

    <!-- Google Analytics 4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-450PG6DTXP"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-450PG6DTXP');
    </script>

    <!-- Meta Pixel -->
    <script>
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window, document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', '886775375816530');
      fbq('track', 'PageView');
    </script>
  </head>
  <body>
    <slot />
    <ChatBot />
  </body>
</html>
